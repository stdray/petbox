# Copy to `secrets.local.env` (gitignored) and fill in real values, then run:
#   scripts/set-gh-secrets.sh
# Values are pushed to GitHub Actions secrets via `gh secret set`.

# restic repository password — GENERATE with `openssl rand -base64 48`, store in
# KeePass. Losing it makes every offsite backup unrecoverable.
RESTIC_PASSWORD=

# Cloudflare R2 (compact backup, data minus logs)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=petbox

# FirstVDS S3 (full backup, incl. logs)
FVDS_ACCESS_KEY_ID=
FVDS_SECRET_ACCESS_KEY=
FVDS_S3_ENDPOINT=https://s3.firstvds.ru
FVDS_BUCKET=petbox

# Optional: failure alert + success heartbeat for the backup sidecar. All three
# are no-ops if left blank — leave them empty to skip alerting entirely.

# Telegram bot token (from @BotFather) used to send a "backup failed"/"recovered" message.
TELEGRAM_BOT_TOKEN=
# Telegram chat/user id the bot messages (e.g. your own numeric user id from @userinfobot).
TELEGRAM_CHAT_ID=
# healthchecks.io (or similar) ping URL hit once per successful backup run (dead-man's-switch).
HEALTHCHECK_URL=
