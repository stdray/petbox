yobabox.3po.su {
	# Container publishes to 127.0.0.1:8083 (shared-host convention: yobaconf=8081, yobalog=8082, yobabox=8083).
	reverse_proxy 127.0.0.1:8083 {
		flush_interval -1
	}

	encode gzip zstd

	log {
		output file /var/log/caddy/yobabox.access.log {
			roll_size 50mb
			roll_keep 5
		}
		format json
	}
}
