yobabox.3po.su {
	# Container publishes to 127.0.0.1:8082 (shared-host convention: yobaconf=8081, yobabox=8082).
	reverse_proxy 127.0.0.1:8082 {
		flush_interval -1
	}

	encode gzip zstd

	log {
		output file /var/log/caddy/yobabox.access.log {
			roll_size 50mb
			roll_keep 5
		}
		format json
	}
}
