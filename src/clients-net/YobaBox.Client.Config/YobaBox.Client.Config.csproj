<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<RootNamespace>YobaBox.Client.Config</RootNamespace>
		<AssemblyName>YobaBox.Client.Config</AssemblyName>
		<Description>YobaBox config client SDK — fetches resolved config into Microsoft.Extensions.Configuration with ETag-aware polling.</Description>
		<PackageId>YobaBox.Client.Config</PackageId>
		<Authors>stdray</Authors>
		<Company>stdray</Company>
		<PackageProjectUrl>https://github.com/stdray/yobabox</PackageProjectUrl>
		<RepositoryUrl>https://github.com/stdray/yobabox</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<PackageTags>yobabox;configuration;config</PackageTags>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>

		<!-- NU5127: package readme not needed for internal tool; description in .csproj metadata suffices -->
		<NoWarn>$(NoWarn);NU5127</NoWarn>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.Extensions.Configuration" />
		<PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" />
	</ItemGroup>

</Project>
