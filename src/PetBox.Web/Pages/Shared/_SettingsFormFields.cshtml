@using System.Reflection
@using PetBox.Core.Settings
@using PetBox.Web.Settings
@model PetBox.Web.Settings.SettingsFormFieldsModel
@{
	var visible = SettingsFormFieldSelector.GetEditable(Model.RecordType, Model.CurrentScope);
}
@foreach (var (prop, attr) in visible)
{
	var current = prop.GetValue(Model.Current);
	var fieldId = $"setting-{prop.Name}";
	var inputName = prop.Name;
	var underlying = Nullable.GetUnderlyingType(prop.PropertyType) ?? prop.PropertyType;

	<label class="form-control mb-3" for="@fieldId">
		<span class="label-text">@prop.Name</span>
		@if (attr.IsSecret)
		{
			<input id="@fieldId" type="password" name="@inputName"
				class="input input-bordered input-sm font-mono"
				data-testid="setting-input-@prop.Name"
				placeholder="(unchanged)" />
			<span class="text-xs opacity-60 mt-1">Stored encrypted. Leave blank to keep current value.</span>
		}
		else if (underlying.IsEnum)
		{
			<select id="@fieldId" name="@inputName" class="select select-bordered select-sm" data-testid="setting-input-@prop.Name">
				@foreach (var name in Enum.GetNames(underlying))
				{
					<option value="@name" selected="@(string.Equals(name, current?.ToString(), StringComparison.Ordinal))">@name</option>
				}
			</select>
		}
		else if (underlying == typeof(bool))
		{
			<label class="cursor-pointer flex items-center gap-2">
				<input id="@fieldId" type="checkbox" name="@inputName" value="true"
					class="toggle toggle-primary toggle-sm"
					checked="@((bool)(current ?? false))"
					data-testid="setting-input-@prop.Name" />
				<span class="text-sm">Enabled</span>
			</label>
		}
		else if (underlying == typeof(int) || underlying == typeof(long))
		{
			<input id="@fieldId" type="number" name="@inputName"
				value="@current"
				class="input input-bordered input-sm w-40 font-mono"
				data-testid="setting-input-@prop.Name" />
		}
		else
		{
			<input id="@fieldId" type="text" name="@inputName"
				value="@current"
				class="input input-bordered input-sm"
				data-testid="setting-input-@prop.Name" />
		}
		@if (!string.IsNullOrEmpty(attr.Description))
		{
			<span class="text-xs opacity-60 mt-1">@attr.Description</span>
		}
	</label>
}
