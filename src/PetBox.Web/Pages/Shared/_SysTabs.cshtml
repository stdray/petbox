@{
	var path = Context.Request.Path.Value ?? string.Empty;
	bool At(string url) => string.Equals(path, url, StringComparison.OrdinalIgnoreCase);
	bool Under(string prefix) => path.StartsWith(prefix, StringComparison.OrdinalIgnoreCase);
	var homeUrl = Routes.Sys();
	var wsUrl = Routes.SysWorkspaces();
	var usersUrl = Routes.SysUsers();
}
<div role="tablist" class="tabs tabs-bordered mb-6" data-testid="sys-tabs">
	<a role="tab" class="tab @(At(homeUrl) ? "tab-active" : "")"
		href="@homeUrl"
		data-testid="sys-tab-home">Overview</a>
	<a role="tab" class="tab @(Under(wsUrl) ? "tab-active" : "")"
		href="@wsUrl"
		data-testid="sys-tab-workspaces">Workspaces</a>
	<a role="tab" class="tab @(At(usersUrl) ? "tab-active" : "")"
		href="@usersUrl"
		data-testid="sys-tab-users">Users</a>
</div>
