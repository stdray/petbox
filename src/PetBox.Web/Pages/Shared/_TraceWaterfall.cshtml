@using PetBox.Web.Pages.Logs
@model IReadOnlyList<PetBox.Web.Pages.Logs.TraceModel.WaterfallRow>
<div class="overflow-x-auto">
	<table class="table table-xs" data-testid="trace-waterfall">
		<thead>
			<tr>
				<th class="w-1/3">Span</th>
				<th class="w-20">Duration</th>
				<th>Timeline</th>
			</tr>
		</thead>
		@* One expanded span at a time (accordion): a row click toggles its detail row. *@
		<tbody x-data="{ open: null }">
			@foreach (var row in Model)
			{
				var span = row.Span;
				var color = span.StatusCode == 2 ? "bg-error/60" : span.Kind switch
				{
					1 => "bg-primary/60",
					2 => "bg-info/60",
					3 => "bg-warning/60",
					4 => "bg-success/60",
					_ => "bg-base-content/30",
				};
				var indent = (row.Depth * 12).ToString(System.Globalization.CultureInfo.InvariantCulture);
				var attrs = TraceModel.DisplayAttributes(span);
				<tr data-testid="trace-span-row" data-span-id="@span.SpanId" data-depth="@row.Depth"
					class="cursor-pointer hover:bg-base-200"
					x-on:click="open = open === '@span.SpanId' ? null : '@span.SpanId'">
					<td class="font-mono text-xs">
						<span style="padding-left:@(indent)px" class="inline-block">↳</span>
						<span>@span.Name</span>
					</td>
					<td class="font-mono text-xs">@($"{span.Duration.TotalMilliseconds:0.00} ms")</td>
					<td>
						<div class="relative h-4 bg-base-300 rounded">
							<div class="absolute h-4 rounded @color"
								style="left: @(row.StartPct.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%; width: @(row.WidthPct.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%"
								title="@span.Name · @($"{span.Duration.TotalMilliseconds:0.00} ms")"></div>
						</div>
					</td>
				</tr>
				<tr data-testid="trace-span-detail" data-span-id="@span.SpanId"
					style="display:none" x-show="open === '@span.SpanId'">
					<td colspan="3" class="bg-base-200/50">
						<div class="px-2 py-1 text-xs space-y-1">
							<div class="font-mono opacity-70">
								<span>span @span.SpanId</span>
								@if (!string.IsNullOrEmpty(span.ParentSpanId))
								{
									<span> · parent @span.ParentSpanId</span>
								}
								<span> · @TraceModel.KindName(span.Kind)</span>
								<span> · @TraceModel.StatusName(span.StatusCode)</span>
								@if (!string.IsNullOrEmpty(span.StatusDescription))
								{
									<span class="text-error"> — @span.StatusDescription</span>
								}
							</div>
							@if (attrs.Count == 0)
							{
								<div class="opacity-50">no span attributes</div>
							}
							else
							{
								<table class="table table-xs w-auto">
									<tbody>
										@foreach (var a in attrs)
										{
											<tr>
												<td class="font-mono opacity-60 pr-4">@a.Key</td>
												<td class="font-mono break-all">@a.Value</td>
											</tr>
										}
									</tbody>
								</table>
							}
						</div>
					</td>
				</tr>
			}
		</tbody>
	</table>
</div>
