@model PetBox.Web.Pages.Shared.TaskTableModel
@* The ONE flat task table (board-view-mode-framework's table task): shared by TaskBoard's own
   table view mode (_BoardViewTable.cshtml, ShowScopeColumns=false) and the cross-scope search
   results page (Pages/Search.cshtml, ShowScopeColumns=true — a hit can live on any board in any
   project, so workspace/project/board become real columns instead of implicit page context).
   Sorting/filtering reuse the EXISTING client mechanism (board-sort-impl, ts/board.ts
   initBoardPage) via the same testids/data-* the tree pane uses — not a second parallel one:
   initBoardPage() runs unconditionally on every page and wires up whatever of this markup is
   present, table or tree alike.
   board-view-fields: columns are gated on Model.Fields — null (Search's cross-scope call, which
   never resolves BlockedBy/Body and has no board-view-meta to persist a choice against) falls back
   to the table's original always-on set so search results are unaffected by this feature. *@
@{
	var fields = Model.Fields ?? new PetBox.Web.Rendering.BoardFieldConfig(
		Slug: true, Type: true, Status: true, Priority: true, Tags: true, UpdatedAt: true, Delivery: true, BlockedBy: false, Body: false);
	var viewMode = Model.Fields is not null ? BoardViewModeNames.Table : "";
}
@if (Model.Rows.Count == 0)
{
	<div class="alert" data-testid="board-empty">No tasks.</div>
}
else
{
	var filterSortModel = new BoardFilterSortModel(Fields: fields, ViewMode: viewMode, SortHint: "sort rows:", ActiveOnly: Model.ActiveOnly, SortBy: Model.SortBy, SortDesc: Model.SortDesc);
	<partial name="_BoardFilterSort" model="filterSortModel" />
	<div class="overflow-x-auto">
		<table class="table table-sm" data-testid="board-table">
			<thead>
				<tr>
					@if (Model.ShowScopeColumns)
					{
						<th>workspace</th>
						<th>project</th>
						<th>board</th>
					}
					<th>key</th>
					@if (fields.Type) { <th>type</th> }
					@if (fields.Status) { <th>status</th> }
					@if (fields.Priority) { <th>priority</th> }
					@if (fields.Tags) { <th>tags</th> }
					@if (fields.UpdatedAt) { <th>updated</th> }
					@if (fields.Delivery) { <th>delivery</th> }
					@if (fields.BlockedBy) { <th>blocked by</th> }
					@if (fields.Body) { <th>body</th> }
				</tr>
			</thead>
			<tbody data-testid="board-nodes" data-sort-scope>
				@foreach (var row in Model.Rows)
				{
					var search = $"{row.Title} {row.Key} {string.Join(' ', row.Tags)}".ToLowerInvariant();
					<tr data-testid="@(Model.ShowScopeColumns ? "search-hit" : "task-table-row")"
						data-node-id="@row.NodeId" data-node-key="@row.Key"
						data-status="@row.StatusSlug" data-type="@row.Type" data-priority="@row.Priority" data-title="@row.Title"
						data-created="@(row.CreatedAt?.ToString("o") ?? "")" data-updated="@(row.UpdatedAt?.ToString("o") ?? "")"
						data-search="@search" data-closed="@row.Closed.ToString().ToLowerInvariant()" data-keep-visible="false" data-terminal-cancel="@row.TerminalCancel.ToString().ToLowerInvariant()"
						style="display:@(row.Hidden ? "none" : "")">
						@if (Model.ShowScopeColumns)
						{
							<td class="font-mono text-xs opacity-70" data-testid="row-workspace">@row.Workspace</td>
							<td class="font-mono text-xs opacity-70" data-testid="row-project">@row.ProjectKey</td>
							<td class="font-mono text-xs opacity-70" data-testid="row-board">@row.Board</td>
						}
						<td>
							@* board-terminal-negative-visible: struck through regardless of whether the
							   status COLUMN is on — but only on the spec board (row.IsSpecBoard, review
							   finding) — everywhere else the status is already a displayable property. *@
							<a href="@row.Url" class="link link-hover font-semibold @(row.TerminalCancel && row.IsSpecBoard ? "line-through opacity-60" : "")" data-testid="node-name">@row.Title</a>
							@if (fields.Slug)
							{
								<span class="font-mono text-xs opacity-50">@row.Key</span>
							}
						</td>
						@if (fields.Type)
						{
							<td><span class="badge badge-ghost badge-xs" data-testid="node-type">@row.Type</span></td>
						}
						@if (fields.Status)
						{
							<td>
								@if (row.StatusShow)
								{
									<span class="badge @row.StatusCssClass badge-sm" data-testid="node-status">@row.StatusDisplay</span>
								}
							</td>
						}
						@if (fields.Priority)
						{
							<td data-testid="node-priority">@row.Priority</td>
						}
						@if (fields.Tags)
						{
							<td data-testid="node-tags">
								@foreach (var t in row.Tags)
								{
									<span class="badge badge-outline badge-xs mr-1">@t</span>
								}
							</td>
						}
						@if (fields.UpdatedAt)
						{
							<td>
								@if (row.UpdatedAt is not null)
								{
									<time class="local-time text-xs" datetime="@row.UpdatedAt.Value.ToString("o")" data-testid="node-updated">@row.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm")</time>
								}
							</td>
						}
						@if (fields.Delivery)
						{
							<td>
								@if (row.Delivery is not null)
								{
									<partial name="_DeliveryBadge" model="@(new DeliveryBadgeModel(row.Delivery) { Size = "badge-xs" })" />
								}
							</td>
						}
						@if (fields.BlockedBy)
						{
							<td><partial name="_BlockedByChips" model="@(new BlockedByChipsModel(Model.WorkspaceKey ?? "", Model.ProjectKey ?? "", row.BlockedBy))" /></td>
						}
						@if (fields.Body)
						{
							<td class="max-w-xs">
								@if (!string.IsNullOrEmpty(row.Body))
								{
									var excerpt = row.Body.Length > 120 ? row.Body[..120] + "…" : row.Body;
									<span class="text-xs opacity-70" data-testid="node-body">@excerpt</span>
								}
							</td>
						}
					</tr>
				}
			</tbody>
		</table>
	</div>
}
