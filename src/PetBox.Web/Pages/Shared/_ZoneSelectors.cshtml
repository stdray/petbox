@inject PetBox.Web.Navigation.INavigationContext Nav
@{
	// Unified zone header shared by /ui and admin sidebars: pick a workspace, then a project.
	// Both are onchange-submit forms posting to the sibling switch endpoints, which validate
	// access, persist a cookie (yb_ws / yb_project) and LocalRedirect to the zone landing page.
	var currentWs = Nav.CurrentWorkspaceKey;
	var currentProject = Nav.CurrentProjectKey;
	var projects = Nav.ProjectsInCurrentWorkspace;

	// Zone-preserving switching: the switch endpoints redirect to the same zone the user is
	// currently in. Admin pages live under /ui/admin/...; everything else is the /ui zone.
	// The hidden `zone` field carries this so a project/workspace change in the admin sidebar
	// keeps you in admin (of the new project/ws), and in /ui keeps you in /ui.
	var path = Context.Request.Path.Value ?? string.Empty;
	var zone = path.StartsWith("/ui/admin", StringComparison.OrdinalIgnoreCase) ? "admin" : "ui";
}
<div class="px-2 pt-2 space-y-1" data-testid="nav-zone-selectors">
	<div class="flex items-center gap-1">
		<form method="post" action="/api/ui/workspace" data-testid="nav-workspace-switch" class="flex-1 min-w-0">
			<input type="hidden" name="zone" value="@zone" data-testid="nav-workspace-zone" />
			<select name="ws" onchange="this.form.submit()" aria-label="Switch workspace" title="Switch workspace"
				class="select select-sm select-bordered w-full font-mono text-xs" data-testid="nav-workspace-select">
				@foreach (var w in Nav.AvailableWorkspaces)
				{
					<option value="@w.Key" selected="@(string.Equals(w.Key, currentWs, StringComparison.Ordinal))">@w.Key</option>
				}
			</select>
		</form>
		<partial name="_SidebarPin" />
	</div>
	<form method="post" action="/api/ui/project" data-testid="nav-project-switch">
		<input type="hidden" name="ws" value="@currentWs" />
		<input type="hidden" name="zone" value="@zone" data-testid="nav-project-zone" />
		@if (projects.Count == 0)
		{
			<select disabled aria-label="Select project" title="No projects in this workspace"
				class="select select-sm select-bordered w-full font-mono text-xs opacity-60" data-testid="nav-project-select">
				<option>no projects</option>
			</select>
		}
		else
		{
			<select name="key" onchange="this.form.submit()" aria-label="Switch project" title="Switch project"
				class="select select-sm select-bordered w-full font-mono text-xs" data-testid="nav-project-select">
				@foreach (var p in projects)
				{
					<option value="@p.Key" selected="@(string.Equals(p.Key, currentProject, StringComparison.Ordinal))">@p.Key</option>
				}
			</select>
		}
	</form>
</div>
