@model PetBox.Web.Pages.Shared.StatusBadgeModel
@* The ONE status badge, shared by the board card and the node detail page. Encodes the spec-board
   suppression rule (StatusBadgeModel.Show) so the board and node page can never drift: on a spec
   board a non-terminal status renders NOTHING; every other board (and terminal `deprecated`) shows
   the coloured badge (spec-board-status-noise #9 / ui-spec-status-board-node-mismatch). *@
@if (Model.Show)
{
	<span class="badge @Model.CssClass badge-sm" data-testid="node-status">@Model.Display</span>
}
