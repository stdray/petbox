@inject PetBox.Web.Navigation.INavigationContext Nav
@inject PetBox.Tasks.Contract.ITasksService Tasks
@inject PetBox.Web.Settings.IUiState UiState
@inject PetBox.Data.Contract.IDataDbCatalog DataDbCatalog
@inject PetBox.Log.Core.Data.ILogStore LogStore
@{
	// Null when the user is a member of no workspace at all — the sidebar's workspace/project
	// sections are then skipped entirely (there is nothing to link to; the old "$system" fallback
	// rendered links straight into a 403).
	var currentWs = Nav.CurrentWorkspaceKey;
	var hasWs = currentWs is not null;
	var wsKey = currentWs ?? string.Empty;
	var currentProject = Nav.CurrentProjectKey;
	// Boards are surfaced as Tasks sub-nav ONLY for the project in context (no global
	// fan-out): one cheap metadata read, and only when Tasks is on and a project is active.
	IReadOnlyList<PetBox.Core.Models.TaskBoardMeta> currentProjectBoards = [];
	if (Nav.TasksEnabled && !string.IsNullOrEmpty(currentProject))
	{
		currentProjectBoards = await Tasks.ListBoardsAsync(currentProject, Context.RequestAborted);
	}

	// nav-hide-empty-sections (item 10): Databases and Logs are populated ONLY from the admin
	// zone — the user-zone Databases page's own empty state says "ask a workspace admin" (its
	// create link is even role-gated), and the Logs page's empty state points straight at the
	// admin Logs page. Neither carries the "agents create these via MCP tools" self-service
	// language that Tasks/Memory/Sessions do (see those pages' own empty states) — those stay
	// visible even when empty; these two are pure noise when there is nothing to show AND the
	// user has no way to fill them from here. Same eager-fetch shape as currentProjectBoards
	// above (a cheap catalog metadata read, not a file open) — deciding "show the node at all"
	// is exactly the kind of per-request decision that pattern already exists for.
	var showDatabasesNode = false;
	if (Nav.DataEnabled && !string.IsNullOrEmpty(currentProject))
	{
		var dbs = await DataDbCatalog.ListAsync(currentProject, Context.RequestAborted);
		showDatabasesNode = dbs.Count > 0;
	}
	var showLogsNode = false;
	if (!string.IsNullOrEmpty(currentProject))
	{
		var logs = await LogStore.ListAsync(currentProject, Context.RequestAborted);
		showLogsNode = logs.Count > 0;
	}
	var path = Context.Request.Path.Value ?? string.Empty;
	bool IsActive(string prefix) => path.StartsWith(prefix, StringComparison.OrdinalIgnoreCase);
	bool IsExactly(string url) => string.Equals(path, url, StringComparison.OrdinalIgnoreCase);
	// True on the URL itself or any descendant path (a board's node pages) — but NOT a
	// sibling that merely shares a name prefix (roadmap vs roadmap-v2).
	bool IsUnder(string url) => IsExactly(url) || path.StartsWith(url + "/", StringComparison.OrdinalIgnoreCase);
	var statusUrl = hasWs ? Routes.Workspace(wsKey) : Routes.Home();
	var sharedMemoryUrl = Routes.SharedMemory(wsKey);
	var sharedConfigUrl = Routes.SharedConfig(wsKey);

	// admin-routes-and-pages (item 2): the gear used to jump straight to Server administration —
	// useless to everyone but a sysadmin, and unrelated to whatever the user was just looking at.
	// It now lands on the CURRENT project's admin info page (falling back to the workspace admin
	// overview, then to Sys() only when the user has no workspace at all — e.g. a bare sysadmin
	// account with no membership rows).
	var adminGearUrl = !string.IsNullOrEmpty(currentProject)
		? Routes.ProjectSettings(wsKey, currentProject)
		: hasWs ? Routes.WorkspaceAdmin(wsKey) : Routes.Sys();

	// Combined DB+cookie UI-state record (ui-state-framework + ui-state-theme-unify) — the ONE
	// mechanism for both, resolved via the injected IUiState service (typed, memoized per request)
	// instead of the ViewData bag AND instead of a second, theme-only resolve: sidebarPinned drives
	// the drawer-open class below and Theme drives data-theme, both from this SAME resolve, so the
	// FIRST response already carries the right values — no post-load correction, no cast, no second
	// DB round trip.
	var browserState = await UiState.GetAsync();
	var (dataTheme, systemScript) = PetBox.Web.Settings.ThemeHelper.Resolve(browserState.Theme);
}
<!DOCTYPE html>
<html lang="en" data-theme="@dataTheme" class="h-full">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - PetBox</title>
	<link rel="icon" href="~/favicon.svg" type="image/svg+xml" />
	<link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
	@if (systemScript)
	{
		<partial name="_ThemeScript" />
	}
	<script type="module" src="~/js/site.js" asp-append-version="true"></script>
</head>
<body class="min-h-full">
	<div id="app-drawer" class="drawer @(browserState.SidebarPinned ? "drawer-open" : "")">
		<input id="sidebar-toggle" type="checkbox" class="drawer-toggle" />
		@* min-w-0: a flex/grid item defaults to min-width:auto, so it won't shrink below its
		   content's intrinsic width. Without it, a wide row (e.g. the kanban view's column
		   ribbon, which has its OWN overflow-x-auto) pushes this drawer-content column past
		   the viewport and the BODY scrolls sideways instead — the ribbon's own scrollbar
		   never gets a chance to engage because it's never actually width-constrained
		   (kanban-body-scrolls-not-ribbon, live UI review finding). *@
		<div class="drawer-content flex flex-col min-h-screen min-w-0">
			<header class="navbar bg-base-200 border-b border-base-300 px-2 lg:px-4 min-h-12">
				<div class="flex-none">
					<label for="sidebar-toggle" class="btn btn-ghost btn-sm drawer-button" data-testid="nav-toggle" title="Toggle sidebar">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
						</svg>
					</label>
				</div>
				<div class="flex-1 flex items-center gap-3">
					<a href="@statusUrl" class="text-lg font-semibold" data-testid="nav-home">PetBox</a>
					@if (Nav.IsAuthenticated)
					{
						<form method="get" action="/ui/search" class="hidden sm:block ml-auto mr-3" data-testid="nav-search">
							<input type="text" name="q" placeholder="Find a task…" title="Find a task by slug, NodeId, or text — searches every workspace and project you can access"
								class="input input-sm input-bordered w-40 md:w-64" data-testid="nav-search-input" />
						</form>
					}
				</div>
				<div class="flex-none flex items-center gap-1">
					@if (Nav.IsAuthenticated)
					{
						<a href="/ui/me/account" class="text-xs opacity-60 hover:opacity-100 hidden md:inline font-mono" data-testid="nav-username" title="Account settings">@Nav.Username</a>
						<a href="@adminGearUrl" class="btn btn-ghost btn-sm @(IsActive("/ui/admin") ? "btn-active" : "")" data-testid="nav-admin-gear" title="Administration">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
							</svg>
						</a>
						<form method="post" action="@Routes.Logout()" class="m-0">
							@Html.AntiForgeryToken()
							<button type="submit" class="btn btn-ghost btn-sm" data-testid="nav-signout" title="Sign out">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
								</svg>
							</button>
						</form>
					}
				</div>
			</header>

			<main class="flex-1 p-4 lg:p-6">
				<partial name="_Notice" />
				@RenderBody()
			</main>

			<partial name="_Footer" />
		</div>

		<div class="drawer-side">
			<label for="sidebar-toggle" aria-label="close sidebar" class="drawer-overlay"></label>
			<aside class="bg-base-200 w-64 min-h-full border-r border-base-300 flex flex-col">
				@if (Nav.IsAuthenticated)
				{
					<div class="hidden" data-testid="nav-current-ws">@currentWs</div>

					<partial name="_WorkspaceSelector" />

					@if (!hasWs)
					{
						<div class="px-3 py-4 text-xs opacity-60" data-testid="nav-no-workspaces">
							You have no workspace access yet.
						</div>
					}
					else
					{
					<ul class="menu w-full p-2 gap-1">
						<li>
							<a href="@statusUrl" class="@(IsExactly(statusUrl) ? "active" : "")" data-testid="nav-status">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1" />
								</svg>
								Status
							</a>
						</li>
						@if (Nav.MemoryEnabled)
						{
							<li>
								<a href="@sharedMemoryUrl" class="@(IsActive(sharedMemoryUrl) ? "active" : "")" data-testid="nav-ws-memory">
									<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
									</svg>
									Shared memory
								</a>
							</li>
						}
						<li>
							<a href="@sharedConfigUrl" class="@(IsActive(sharedConfigUrl) ? "active" : "")" data-testid="nav-shared-config">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
								</svg>
								Shared config
							</a>
						</li>
					</ul>

					<div class="px-3 pt-2 mt-2 border-t border-base-300">
						<div class="text-xs opacity-50 uppercase tracking-wide">Project</div>
					</div>
					@* nav-project-selector-placement (item 1): the project selector sits right here, next to
					   the project's OWN section block, instead of up top next to the workspace selector —
					   separated from what it controls by the workspace-level items above. *@
					<partial name="_ProjectSelector" />

					@* Flat, single-project section list: the project is chosen by the selector above,
					   so there is no per-project disclosure tree here — only the sections of the
					   project currently in context. *@
					<ul class="menu menu-sm w-full p-2 gap-0.5 flex-1 overflow-y-auto" data-testid="nav-sidebar-projects">
						@if (string.IsNullOrEmpty(currentProject))
						{
							<li class="text-xs opacity-50 px-3 py-2 italic" data-testid="nav-no-projects">No projects in this workspace.</li>
						}
						else
						{
							var pDash = Routes.Project(wsKey, currentProject);
							var pLogs = Routes.ProjectLogs(wsKey, currentProject);
							var pTraces = Routes.ProjectTraces(wsKey, currentProject);
							var pConfig = Routes.ProjectConfig(wsKey, currentProject);
							var pData = Routes.ProjectDatabases(wsKey, currentProject);
							var pTasks = Routes.ProjectTasks(wsKey, currentProject);
							var pMemory = Routes.ProjectMemory(wsKey, currentProject);
							var pSessions = Routes.ProjectSessions(wsKey, currentProject);
							var pLlm = Routes.ProjectLlmRouter(wsKey, currentProject);
							<li class="hidden" data-testid="nav-project" data-project-key="@currentProject"></li>
							<li><a href="@pDash" class="@(IsExactly(pDash) ? "active" : "")" data-testid="nav-proj-dashboard">Dashboard</a></li>
							@* nav-hide-empty-sections (item 10): Logs is populated only from the admin Logs page
							   (see showLogsNode's computation above) — an empty entry here is a dead end the
							   user cannot fill from this page, so it is hidden rather than shown collapsed. *@
							@if (showLogsNode)
							{
								<li data-testid="nav-proj-logs-node">
									<details hx-get="/ui/_nav/tree?handler=Logs&project=@currentProject" hx-trigger="toggle once" hx-target="find ul.tree-lazy" hx-swap="innerHTML">
										<summary class="@(IsActive(pLogs) ? "active" : "")"><a href="@pLogs" data-testid="nav-proj-logs">Logs</a></summary>
										<ul class="tree-lazy"><li class="text-xs opacity-40 italic px-3 py-1" data-testid="nav-logs-loading">loading…</li></ul>
									</details>
								</li>
							}
							<li><a href="@pTraces" class="@(IsActive(pTraces) ? "active" : "")" data-testid="nav-proj-traces">Traces</a></li>
							@* Same rule for Databases — the ORIGINAL example (idea ui-polish, item 10): no
							   databases exist → no Databases item, since creation is admin-only from here. *@
							@if (Nav.DataEnabled && showDatabasesNode)
							{
								<li data-testid="nav-proj-data-node">
									<details hx-get="/ui/_nav/tree?handler=Databases&project=@currentProject" hx-trigger="toggle once" hx-target="find ul.tree-lazy" hx-swap="innerHTML">
										<summary class="@(IsActive(pData) ? "active" : "")"><a href="@pData" data-testid="nav-proj-data">Databases</a></summary>
										<ul class="tree-lazy"><li class="text-xs opacity-40 italic px-3 py-1" data-testid="nav-dbs-loading">loading…</li></ul>
									</details>
								</li>
							}
							<li><a href="@pConfig" class="@(IsActive(pConfig) ? "active" : "")" data-testid="nav-proj-config">Config</a></li>
							@if (Nav.LlmRouterEnabled)
							{
								<li><a href="@pLlm" class="@(IsActive(pLlm) ? "active" : "")" data-testid="nav-proj-llm">LLM router</a></li>
							}
							@if (Nav.TasksEnabled)
							{
								@if (currentProjectBoards.Count > 0)
								{
									<li data-testid="nav-proj-tasks-node">
										<details open="@(IsActive(pTasks))">
											<summary class="@(IsExactly(pTasks) ? "active" : "")"><a href="@pTasks" data-testid="nav-proj-tasks">Tasks</a></summary>
											<ul>
												@foreach (var board in currentProjectBoards)
												{
													var pBoard = Routes.ProjectTaskBoard(wsKey, currentProject, board.Name);
													<li data-testid="nav-proj-task-board-node" data-board-name="@board.Name">
														<a href="@pBoard" class="@(IsUnder(pBoard) ? "active" : "")" data-testid="nav-proj-task-board">
															<span class="font-mono text-xs truncate">@board.Name</span>
															@if (board.ClosedAt is not null)
															{
																<span class="badge badge-ghost badge-xs">closed</span>
															}
														</a>
													</li>
												}
											</ul>
										</details>
									</li>
								}
								else
								{
									<li><a href="@pTasks" class="@(IsActive(pTasks) ? "active" : "")" data-testid="nav-proj-tasks">Tasks</a></li>
								}
							}
							@if (Nav.MemoryEnabled)
							{
								<li><a href="@pMemory" class="@(IsActive(pMemory) ? "active" : "")" data-testid="nav-proj-memory">Memory</a></li>
							}
							@if (Nav.TasksEnabled)
							{
								<li><a href="@pSessions" class="@(IsActive(pSessions) ? "active" : "")" data-testid="nav-proj-agent">Sessions</a></li>
							}
						}
					</ul>
					}

				}
			</aside>
		</div>
	</div>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
