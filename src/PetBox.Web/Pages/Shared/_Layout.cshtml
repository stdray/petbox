@inject PetBox.Web.Navigation.INavigationContext Nav
@inject PetBox.Core.Settings.ISettingsResolver Settings
@{
	var currentWs = Nav.CurrentWorkspaceKey;
	var currentProject = Nav.CurrentProjectKey;
	var fewProjects = Nav.ProjectsInCurrentWorkspace.Count < 3;
	// Tree expand state is persisted client-side in the petbox.sidebar.tree cookie
	// (see ts/sidebar.ts) so we can render <details open> up front — no JS reflow
	// after paint. Only project nodes are tracked here; lazy log/db nodes auto-open
	// solely for the active page (deep-link), never from persisted state.
	var openTree = new HashSet<string>(StringComparer.Ordinal);
	{
		var openTreeRaw = Context.Request.Cookies["petbox.sidebar.tree"];
		if (!string.IsNullOrEmpty(openTreeRaw))
		{
			try
			{
				var decoded = System.Net.WebUtility.UrlDecode(openTreeRaw);
				foreach (var k in System.Text.Json.JsonSerializer.Deserialize<string[]>(decoded) ?? Array.Empty<string>())
				{
					openTree.Add(k);
				}
			}
			catch (System.Text.Json.JsonException) { }
		}
	}
	var path = Context.Request.Path.Value ?? string.Empty;
	bool IsActive(string prefix) => path.StartsWith(prefix, StringComparison.OrdinalIgnoreCase);
	bool IsExactly(string url) => string.Equals(path, url, StringComparison.OrdinalIgnoreCase);
	var statusUrl = Routes.Workspace(currentWs);
	var sharedMemoryUrl = Routes.SharedMemory();
	var sharedConfigUrl = Routes.SharedConfig(currentWs);

	var (dataTheme, systemScript) = await PetBox.Web.Settings.ThemeHelper.ResolveForCurrentUserAsync(Nav, Settings, Context);
}
<!DOCTYPE html>
<html lang="en" data-theme="@dataTheme" class="h-full">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - PetBox</title>
	<link rel="icon" href="~/favicon.svg" type="image/svg+xml" />
	<link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
	@if (systemScript)
	{
		<partial name="_ThemeScript" />
	}
	<meta name="yb-current-ws" content="@currentWs" />
	<script type="module" src="~/js/site.js" asp-append-version="true"></script>
</head>
<body class="min-h-full">
	<div id="app-drawer" class="drawer drawer-open">
		<input id="sidebar-toggle" type="checkbox" class="drawer-toggle" />
		<div class="drawer-content flex flex-col min-h-screen">
			<header class="navbar bg-base-200 border-b border-base-300 px-2 lg:px-4 min-h-12">
				<div class="flex-none">
					<label for="sidebar-toggle" class="btn btn-ghost btn-sm drawer-button" data-testid="nav-toggle" title="Toggle sidebar">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
						</svg>
					</label>
				</div>
				<div class="flex-1 flex items-center gap-3">
					<a href="@statusUrl" class="text-lg font-semibold" data-testid="nav-home">PetBox</a>
					@if (Nav.IsAuthenticated)
					{
						<form method="get" action="/ui/search" class="hidden sm:block ml-auto mr-3" data-testid="nav-search">
							<input type="text" name="q" placeholder="Find a task…" title="Find a task by slug, NodeId, or text — searches every workspace and project you can access"
								class="input input-sm input-bordered w-40 md:w-64" data-testid="nav-search-input" />
						</form>
					}
				</div>
				<div class="flex-none flex items-center gap-1">
					@if (Nav.IsAuthenticated)
					{
						<a href="/ui/me/account" class="text-xs opacity-60 hover:opacity-100 hidden md:inline font-mono" data-testid="nav-username" title="Account settings">@Nav.Username</a>
						<a href="@Routes.Sys()" class="btn btn-ghost btn-sm @(IsActive("/ui/admin/sys") ? "btn-active" : "")" data-testid="nav-sysadmin" title="System administration">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
							</svg>
						</a>
						<form method="post" action="@Routes.Logout()" class="m-0">
							@Html.AntiForgeryToken()
							<button type="submit" class="btn btn-ghost btn-sm" data-testid="nav-signout" title="Sign out">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
								</svg>
							</button>
						</form>
					}
				</div>
			</header>

			<main class="flex-1 p-4 lg:p-6">
				<partial name="_Notice" />
				@RenderBody()
			</main>

			<partial name="_Footer" />
		</div>

		<div class="drawer-side">
			<label for="sidebar-toggle" aria-label="close sidebar" class="drawer-overlay"></label>
			<aside class="bg-base-200 w-64 min-h-full border-r border-base-300 flex flex-col">
				@if (Nav.IsAuthenticated)
				{
					<div class="hidden" data-testid="nav-current-ws">@currentWs</div>

					<div class="px-2 pt-2 flex items-center gap-1">
						<form method="post" action="/api/ui/workspace" data-testid="nav-workspace-switch" class="flex-1">
							<select name="ws" onchange="this.form.submit()" aria-label="Switch workspace" title="Switch workspace"
								class="select select-sm select-bordered w-full font-mono text-xs" data-testid="nav-workspace-select">
								@foreach (var w in Nav.AvailableWorkspaces)
								{
									<option value="@w.Key" selected="@(string.Equals(w.Key, currentWs, StringComparison.Ordinal))">@w.Key</option>
								}
							</select>
						</form>
						<partial name="_SidebarPin" />
					</div>

					<ul class="menu w-full p-2 gap-1">
						<li>
							<a href="@statusUrl" class="@(IsExactly(statusUrl) ? "active" : "")" data-testid="nav-status">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1" />
								</svg>
								Status
							</a>
						</li>
						@if (Nav.MemoryEnabled)
						{
							<li>
								<a href="@sharedMemoryUrl" class="@(IsActive(sharedMemoryUrl) ? "active" : "")" data-testid="nav-ws-memory">
									<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
									</svg>
									Shared memory
								</a>
							</li>
						}
						<li>
							<a href="@sharedConfigUrl" class="@(IsActive(sharedConfigUrl) ? "active" : "")" data-testid="nav-shared-config">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
								</svg>
								Shared config
							</a>
						</li>
					</ul>

					<div class="px-3 py-2 mt-2 border-t border-base-300">
						<div class="text-xs opacity-50 uppercase tracking-wide">Projects</div>
					</div>

					<ul class="menu menu-sm w-full p-2 gap-0.5 flex-1 overflow-y-auto" data-testid="nav-sidebar-projects">
						@if (Nav.ProjectsInCurrentWorkspace.Count == 0)
						{
							<li class="text-xs opacity-50 px-3 py-2 italic" data-testid="nav-no-projects">No projects in this workspace.</li>
						}
						else
						{
							@foreach (var project in Nav.ProjectsInCurrentWorkspace)
							{
								var isCurrent = string.Equals(currentProject, project.Key, StringComparison.Ordinal);
								var pDash = Routes.Project(currentWs, project.Key);
								var pLogs = Routes.ProjectLogs(currentWs, project.Key);
								var pTraces = Routes.ProjectTraces(currentWs, project.Key);
								var pConfig = Routes.ProjectConfig(currentWs, project.Key);
								var pData = Routes.ProjectDatabases(currentWs, project.Key);
								var pTasks = Routes.ProjectTasks(currentWs, project.Key);
								var pMemory = Routes.ProjectMemory(currentWs, project.Key);
								var pSessions = Routes.ProjectSessions(currentWs, project.Key);
								var pLlm = Routes.ProjectLlmRouter(currentWs, project.Key);
								<li data-testid="nav-project" data-project-key="@project.Key">
									<details data-tree-key="proj:@project.Key" open="@(isCurrent || fewProjects || openTree.Contains($"proj:{project.Key}"))">
										<summary class="@(isCurrent ? "active font-semibold" : "")">
											<svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor">
												<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
											</svg>
											<span class="font-mono text-xs truncate">@project.Key</span>
											@if (project.Key == "$system")
											{
												<span class="badge badge-ghost badge-xs">sys</span>
											}
										</summary>
										<ul>
											<li><a href="@pDash" class="@(IsExactly(pDash) ? "active" : "")" data-testid="nav-proj-dashboard">Dashboard</a></li>
											<li data-testid="nav-proj-logs-node">
												<details hx-get="/ui/_nav/tree?handler=Logs&project=@project.Key" hx-trigger="toggle once" hx-target="find ul.tree-lazy" hx-swap="innerHTML">
													<summary class="@(IsActive(pLogs) ? "active" : "")"><a href="@pLogs" data-testid="nav-proj-logs">Logs</a></summary>
													<ul class="tree-lazy"><li class="text-xs opacity-40 italic px-3 py-1" data-testid="nav-logs-loading">loading…</li></ul>
												</details>
											</li>
											<li><a href="@pTraces" class="@(IsActive(pTraces) ? "active" : "")" data-testid="nav-proj-traces">Traces</a></li>
											@if (Nav.DataEnabled)
											{
												<li data-testid="nav-proj-data-node">
													<details hx-get="/ui/_nav/tree?handler=Databases&project=@project.Key" hx-trigger="toggle once" hx-target="find ul.tree-lazy" hx-swap="innerHTML">
														<summary class="@(IsActive(pData) ? "active" : "")"><a href="@pData" data-testid="nav-proj-data">Databases</a></summary>
														<ul class="tree-lazy"><li class="text-xs opacity-40 italic px-3 py-1" data-testid="nav-dbs-loading">loading…</li></ul>
													</details>
												</li>
											}
											<li><a href="@pConfig" class="@(IsActive(pConfig) ? "active" : "")" data-testid="nav-proj-config">Config</a></li>
												@if (Nav.LlmRouterEnabled)
												{
													<li><a href="@pLlm" class="@(IsActive(pLlm) ? "active" : "")" data-testid="nav-proj-llm">LLM router</a></li>
												}
											@if (Nav.TasksEnabled)
											{
												<li><a href="@pTasks" class="@(IsActive(pTasks) ? "active" : "")" data-testid="nav-proj-tasks">Tasks</a></li>
											}
											@if (Nav.MemoryEnabled)
											{
												<li><a href="@pMemory" class="@(IsActive(pMemory) ? "active" : "")" data-testid="nav-proj-memory">Memory</a></li>
											}
											@if (Nav.TasksEnabled)
											{
												<li><a href="@pSessions" class="@(IsActive(pSessions) ? "active" : "")" data-testid="nav-proj-agent">Sessions</a></li>
											}
										</ul>
									</details>
								</li>
							}
						}
					</ul>

				}
			</aside>
		</div>
	</div>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
