@inject PetBox.Web.Navigation.INavigationContext Nav
@inject PetBox.Core.Settings.ISettingsResolver Settings
@{
	var currentWs = Nav.CurrentWorkspaceKey;
	var backUrl = Routes.Workspace(currentWs);
	var backLabel = $"Back to {currentWs}";

	var (dataTheme, systemScript) = await PetBox.Web.Settings.ThemeHelper.ResolveForCurrentUserAsync(Nav, Settings, Context);

	// Combined DB+cookie UI-state record (ui-state-framework), resolved BEFORE render exactly like
	// the theme above — sidebarPinned drives the drawer-open class below so the account zone's
	// first response already carries the right class too (SidebarPinTests covers this zone).
	var uiState = await PetBox.Web.Settings.UiStateResolver.ResolveForCurrentUserAsync<PetBox.Core.Settings.BrowserState>(Nav, Settings, Context);
	ViewData["UiState"] = uiState;
}
<!DOCTYPE html>
<html lang="en" data-theme="@dataTheme" class="h-full">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] · account · PetBox</title>
	<link rel="icon" href="~/favicon.svg" type="image/svg+xml" />
	<link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
	@if (systemScript)
	{
		<partial name="_ThemeScript" />
	}
	<meta name="yb-current-ws" content="@currentWs" />
	<script type="module" src="~/js/site.js" asp-append-version="true"></script>
</head>
<body class="min-h-full bg-base-100">
	<div class="drawer @(uiState.SidebarPinned ? "drawer-open" : "")">
		<input id="account-sidebar-toggle" type="checkbox" class="drawer-toggle" />
		<div class="drawer-content flex flex-col min-h-screen">
			<header class="navbar bg-base-200 border-b border-base-300 px-2 lg:px-4 min-h-12" data-testid="account-navbar">
				<div class="flex-none lg:hidden">
					<label for="account-sidebar-toggle" class="btn btn-ghost btn-sm drawer-button" data-testid="account-nav-toggle">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
						</svg>
					</label>
				</div>
				<div class="flex-1 flex items-center gap-3 min-w-0">
					<a href="@backUrl" class="btn btn-ghost btn-sm gap-1" data-testid="account-back">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
						</svg>
						<span class="hidden sm:inline">@backLabel</span>
					</a>
					<span class="text-sm font-semibold" data-testid="account-context-label">Account settings</span>
				</div>
				<div class="flex-none flex items-center gap-1">
					@if (Nav.IsAuthenticated)
					{
						<form method="post" action="@Routes.Logout()" class="m-0">
							@Html.AntiForgeryToken()
							<button type="submit" class="btn btn-ghost btn-sm" data-testid="nav-signout" title="Sign out">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
								</svg>
							</button>
						</form>
					}
				</div>
			</header>

			<main class="flex-1 p-4 lg:p-6 max-w-4xl w-full mx-auto">
				<partial name="_Notice" />
				@RenderBody()
			</main>

			<partial name="_Footer" />
		</div>

		<div class="drawer-side">
			<label for="account-sidebar-toggle" aria-label="close sidebar" class="drawer-overlay"></label>
			<partial name="_AccountSidebar" />
		</div>
	</div>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
