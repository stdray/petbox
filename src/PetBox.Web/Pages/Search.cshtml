@page "/ui/search"
@model PetBox.Web.Pages.SearchModel
@using PetBox.Web.Pages.Shared
@{
	ViewData["Title"] = "Search";
}

<h1 class="text-2xl font-semibold mb-4" data-testid="search-title">Search</h1>

<form method="get" action="/ui/search" class="mb-6 flex gap-2 max-w-xl" data-testid="search-page-form">
	<input type="text" name="q" value="@Model.Q" placeholder="Slug, NodeId, or search text…"
		class="input input-bordered flex-1" data-testid="search-page-input" autofocus />
	<button type="submit" class="btn btn-primary" data-testid="search-page-submit">Search</button>
</form>

@if (string.IsNullOrWhiteSpace(Model.Q))
{
	<div class="opacity-60" data-testid="search-empty-state">
		Paste a task slug or NodeId, or type a search phrase — results span every workspace and project you can access.
	</div>
	return;
}

@if (Model.Hits.Count == 0)
{
	<div class="alert" data-testid="search-no-results">No tasks found for "@Model.Q".</div>
	return;
}

<div class="text-sm opacity-60 mb-3" data-testid="search-result-count">
	@Model.Hits.Count result@(Model.Hits.Count == 1 ? "" : "s")
</div>

@* board-view-mode-framework: reuse of the SAME table component TaskBoard's table view mode
   renders (_TaskTable.cshtml) — with the workspace/project/board columns switched on, since a
   result's location isn't implicit on this page the way it is inside a single board. Row order
   is Model.Hits' own order (exact-identifier hits first, then full-text, each already
   project-grouped/relevance-sorted) — the table itself does not re-sort unless the user picks a
   sort key (board-sort-impl, reused verbatim). *@
<partial name="_TaskTable" model="new TaskTableModel(Model.Rows, ShowScopeColumns: true)" />
