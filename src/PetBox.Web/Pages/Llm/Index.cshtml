@page "/ui/{workspaceKey}/{projectKey}/llm"
@model PetBox.Web.Pages.Llm.IndexModel
@{
	ViewData["Title"] = $"LLM router — {Model.ProjectKey}";
}

<div class="p-4 space-y-4">
	<h1 class="text-xl font-semibold">LLM router — providers</h1>

	@if (Model.ProjectNotFound)
	{
		<div class="alert alert-error" data-testid="llm-no-project">Project '@Model.ProjectKey' not found.</div>
	}
	else
	{
		@if (Model.Saved)
		{
			<div class="alert alert-success" data-testid="llm-saved">Saved.</div>
		}
		@if (Model.Error is not null)
		{
			<div class="alert alert-error" data-testid="llm-error">@Model.Error</div>
		}

		<p class="text-sm opacity-70">
			Workspace-level registry. API keys are write-only: leave the field blank to keep the current key.
			Cert SHA-256 pin is for a self-signed endpoint (blank = trust the public CA).
			Routes are read-only here (configured via the MCP <code>llm.config_set</code> tool).
		</p>

		<div class="space-y-3">
			<h2 class="font-semibold">Endpoints</h2>
			@if (Model.Endpoints.Count == 0)
			{
				<div class="opacity-60 text-sm" data-testid="llm-no-endpoints">No providers yet — add one below.</div>
			}
			@foreach (var ep in Model.Endpoints)
			{
				<div class="card bg-base-200 p-3 space-y-2" data-testid="llm-endpoint-row">
					<form method="post" asp-page-handler="Save" class="grid grid-cols-1 md:grid-cols-6 gap-2 items-end">
						@Html.AntiForgeryToken()
						<label class="form-control"><span class="label-text">Name</span>
							<input class="input input-bordered input-sm" name="name" value="@ep.Name" readonly /></label>
						<label class="form-control md:col-span-2"><span class="label-text">Base URL</span>
							<input class="input input-bordered input-sm" name="baseUrl" value="@ep.BaseUrl" /></label>
						<label class="form-control"><span class="label-text">Cert SHA-256 pin</span>
							<input class="input input-bordered input-sm" name="certThumbprint" value="@ep.CertThumbprint" placeholder="(public CA)" /></label>
						<label class="form-control"><span class="label-text">Connect ms</span>
							<input class="input input-bordered input-sm" type="number" name="connectTimeoutMs" value="@ep.ConnectTimeoutMs" /></label>
						<label class="form-control"><span class="label-text">Request ms</span>
							<input class="input input-bordered input-sm" type="number" name="requestTimeoutMs" value="@ep.RequestTimeoutMs" /></label>
						<label class="form-control md:col-span-2"><span class="label-text">API key (set/replace)</span>
							<input class="input input-bordered input-sm" type="password" name="newKey" placeholder="blank = keep" autocomplete="new-password" /></label>
						<div><button type="submit" class="btn btn-sm btn-primary" data-testid="llm-save">Save</button></div>
					</form>
					<form method="post" asp-page-handler="Delete" onsubmit="return confirm('Delete endpoint @ep.Name?')">
						@Html.AntiForgeryToken()
						<input type="hidden" name="name" value="@ep.Name" />
						<button type="submit" class="btn btn-xs btn-ghost text-error" data-testid="llm-delete">Delete &laquo;@ep.Name&raquo;</button>
					</form>
				</div>
			}
		</div>

		<div class="card bg-base-100 border p-3 space-y-2">
			<h2 class="font-semibold">Add provider</h2>
			<form method="post" asp-page-handler="Save" class="grid grid-cols-1 md:grid-cols-6 gap-2 items-end" data-testid="llm-add">
				@Html.AntiForgeryToken()
				<label class="form-control"><span class="label-text">Name</span>
					<input class="input input-bordered input-sm" name="name" placeholder="e.g. home" required /></label>
				<label class="form-control md:col-span-2"><span class="label-text">Base URL</span>
					<input class="input input-bordered input-sm" name="baseUrl" placeholder="https://host:port" required /></label>
				<label class="form-control"><span class="label-text">Cert SHA-256 pin</span>
					<input class="input input-bordered input-sm" name="certThumbprint" placeholder="(public CA)" /></label>
				<label class="form-control"><span class="label-text">Connect ms</span>
					<input class="input input-bordered input-sm" type="number" name="connectTimeoutMs" value="2000" /></label>
				<label class="form-control"><span class="label-text">Request ms</span>
					<input class="input input-bordered input-sm" type="number" name="requestTimeoutMs" value="60000" /></label>
				<label class="form-control md:col-span-2"><span class="label-text">API key</span>
					<input class="input input-bordered input-sm" type="password" name="newKey" autocomplete="new-password" /></label>
				<div><button type="submit" class="btn btn-sm btn-primary" data-testid="llm-add-save">Add</button></div>
			</form>
		</div>

		<div class="space-y-2">
			<h2 class="font-semibold">Routes (read-only)</h2>
			@if (Model.Routes.Count == 0)
			{
				<div class="opacity-60 text-sm">No routes configured.</div>
			}
			else
			{
				<table class="table table-sm">
					<thead><tr><th>Capability</th><th>Endpoint</th><th>Model</th><th>Priority</th><th>Tier</th></tr></thead>
					<tbody>
					@foreach (var r in Model.Routes)
					{
						<tr><td>@r.Capability</td><td>@r.Endpoint</td><td>@r.Model</td><td>@r.Priority</td><td>@r.Tier</td></tr>
					}
					</tbody>
				</table>
			}
		</div>
	}
</div>
