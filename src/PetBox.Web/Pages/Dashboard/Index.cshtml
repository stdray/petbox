@page "/ui/{workspaceKey}"
@model PetBox.Web.Pages.Dashboard.IndexModel
@{
	ViewData["Title"] = $"Status — {Model.WorkspaceKey}";
	var now = DateTime.UtcNow;
}

<div class="mb-4 flex items-center gap-3">
	<h1 class="text-xl font-semibold" data-testid="dashboard-title">Status</h1>
	<span class="badge badge-outline font-mono">@Model.WorkspaceKey</span>
</div>

@if (Model.Projects.Count == 0)
{
	<div class="card bg-base-200" data-testid="dashboard-empty">
		<div class="card-body items-center text-center">
			<h2 class="card-title">No projects yet</h2>
			<p class="opacity-70">Create your first project in <a asp-page="/Admin/Projects" class="link">Admin</a>.</p>
		</div>
	</div>
}
else
{
	<div class="grid gap-4 xl:grid-cols-2" data-testid="dashboard-projects">
		@foreach (var project in Model.Projects)
		{
			var rows = Model.ByProject.TryGetValue(project.Key, out var r) ? r : [];
			<div class="card bg-base-200" data-testid="dashboard-project-card" data-project-key="@project.Key">
				<div class="card-body p-4">
					<div class="flex items-center gap-2 mb-2">
						<a href="@Routes.Project(Model.WorkspaceKey, project.Key)"
							class="card-title text-lg link link-hover"
							data-testid="dashboard-project-name">@project.Name</a>
						@if (project.Key == "$system")
						{
							<span class="badge badge-sm badge-ghost">system</span>
						}
					</div>
					@if (!string.IsNullOrWhiteSpace(project.Description))
					{
						<p class="text-sm opacity-70 mb-2">@project.Description</p>
					}

					<div class="flex flex-wrap gap-1 mb-3" data-testid="dashboard-counts">
						<a href="@Routes.Project(Model.WorkspaceKey, project.Key)"
							class="badge badge-sm badge-ghost gap-1" data-testid="count-logs">
							@(Model.LogCount.GetValueOrDefault(project.Key)) logs</a>
						<a href="@Routes.ProjectData(Model.WorkspaceKey, project.Key)"
							class="badge badge-sm badge-ghost gap-1" data-testid="count-dbs">
							@(Model.DbCount.GetValueOrDefault(project.Key)) dbs</a>
						<a href="@Routes.ProjectSettings(Model.WorkspaceKey, project.Key)"
							class="badge badge-sm badge-ghost gap-1" data-testid="count-keys">
							@(Model.KeyCount.GetValueOrDefault(project.Key)) keys</a>
					</div>

					@if (rows.Count > 0)
					{
						<div class="overflow-x-auto">
							<table class="table table-xs" data-testid="dashboard-health-table">
								<thead>
									<tr>
										<th>Service</th>
										<th>Tags</th>
										<th>Status</th>
										<th>Version</th>
										<th>Seen</th>
									</tr>
								</thead>
								<tbody>
									@foreach (var h in rows)
									{
										var stale = (now - h.ReceivedAt).TotalSeconds > Model.StaleSeconds;
										<tr data-testid="dashboard-health-row" data-svc="@h.Svc">
											<td>
												<span class="font-mono text-xs">@h.Svc</span>
												@if (!string.IsNullOrWhiteSpace(h.Name))
												{
													<span class="opacity-60 text-xs ml-1">@h.Name</span>
												}
											</td>
											<td class="text-xs opacity-70 font-mono">
												@string.Join(" ", h.OtherTags.Select(t => $"{t.Key}={t.Value}"))
											</td>
											<td>
												@if (stale)
												{
													<span class="badge badge-xs badge-ghost" data-testid="dashboard-health-status" title="No recent report">stale</span>
												}
												else
												{
													<span class="badge badge-xs @StatusBadge(h.Status)" data-testid="dashboard-health-status">@h.Status</span>
												}
											</td>
											<td>
												<span class="font-mono text-xs opacity-70">
													@(string.IsNullOrWhiteSpace(h.Version) ? "—" : h.Version)
													@if (!string.IsNullOrWhiteSpace(h.Sha))
													{
														<text>·</text><span class="opacity-50">@h.Sha</span>
													}
												</span>
											</td>
											<td class="text-xs opacity-60">
												<time class="local-time" datetime="@h.ReceivedAt.ToString("o")">@h.ReceivedAt.ToString("yyyy-MM-dd HH:mm")</time>
											</td>
										</tr>
									}
								</tbody>
							</table>
						</div>
					}
					else
					{
						<p class="text-sm opacity-50" data-testid="dashboard-health-empty">No health reports.</p>
					}
				</div>
			</div>
		}
	</div>
}

@functions {
	static string StatusBadge(string status) => status.ToLowerInvariant() switch
	{
		"ok" or "healthy" or "up" or "pass" => "badge-success",
		"degraded" or "warn" or "warning" => "badge-warning",
		"down" or "error" or "fail" or "critical" => "badge-error",
		_ => "badge-ghost",
	};
}
