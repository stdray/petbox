@page "/doc/methodology/philosophy"
@model PetBox.Web.Pages.Doc.PhilosophyModel
@{
	ViewData["Title"] = "Methodology (philosophy) — PetBox";
	Layout = "_PublicLayout";
}
	@* Thin shell: the prose is the markdown canon Pages/Doc/content/philosophy.md, rendered on the
	   server through the shared IMarkdownRenderer (via _MdBody). No HTML duplication to hand-sync. *@
	<main class="max-w-3xl mx-auto p-6" data-testid="doc-philosophy">
		<p class="text-sm opacity-60"><a href="@Routes.Doc()">← docs</a> · <a href="@Routes.DocMethodology()">cheatsheet</a></p>
		<article>
			<partial name="_MdBody" model="@(new PetBox.Web.Pages.Shared.MdBodyModel { Body = Model.Markdown, TestId = "doc-philosophy-body" })" />
		</article>
	</main>
