@page "/doc/onboarding"
@model PetBox.Web.Pages.Doc.OnboardingModel
@{
	ViewData["Title"] = "Agent onboarding — docs";
	Layout = "_PublicLayout";
}
	@* Thin shell: the prose is the markdown canon Pages/Doc/content/onboarding.md, rendered on the
	   server through the shared IMarkdownRenderer (via _MdBody). No HTML duplication to hand-sync. *@
	<main class="max-w-3xl mx-auto p-6" data-testid="doc-onboarding">
		<p class="text-sm opacity-60"><a href="@Routes.Doc()">← docs</a></p>
		<article>
			<partial name="_MdBody" model="@(new PetBox.Web.Pages.Shared.MdBodyModel { Body = Model.Markdown, TestId = "doc-onboarding-body" })" />
		</article>
	</main>
