@page "/doc/agent"
@model PetBox.Web.Pages.Doc.AgentModel
@{
	ViewData["Title"] = "Connect a coding agent — PetBox";
	Layout = "_PublicLayout";
}
	@* Thin shell: the prose is the markdown canon Pages/Doc/content/agent.md, rendered on the
	   server through the shared IMarkdownRenderer (via _MdBody). No HTML duplication to hand-sync. *@
	<main class="max-w-3xl mx-auto p-6" data-testid="doc-agent">
		<p class="text-sm opacity-60"><a href="@Routes.Doc()">← docs</a></p>
		<article>
			<partial name="_MdBody" model="@(new PetBox.Web.Pages.Shared.MdBodyModel { Body = Model.Markdown, TestId = "doc-agent-body" })" />
		</article>
	</main>
