@page "/ui/{workspaceKey}/{projectKey}/logs/{logName?}"
@model PetBox.Web.Pages.Logs.IndexModel
@{
	ViewData["Title"] = Model.ProjectName is not null ? $"Logs — {Model.ProjectName}" : "Logs";
	var ws = Model.WorkspaceKey ?? "";
	var logBase = Model.ProjectKey is not null && Model.SelectedLog is not null
		? Routes.ProjectLog(ws, Model.ProjectKey, Model.SelectedLog)
		: null;
}

<div class="mb-2 flex items-baseline gap-3 flex-wrap">
	<h1 class="text-2xl font-semibold">@(Model.ProjectName ?? Model.ProjectKey ?? "Logs")</h1>
	@if (Model.ProjectKey is not null) {
		<span class="font-mono text-sm opacity-60">@Model.ProjectKey</span>
	}
</div>


@if (Model.ProjectKey is not null && Model.AvailableLogs.Count > 0)
{
	<div class="mb-4 flex items-center gap-1 flex-wrap" data-testid="log-selector">
		<span class="text-xs opacity-60 mr-1">Logs:</span>
		@foreach (var log in Model.AvailableLogs)
		{
			<a href="@Routes.ProjectLog(ws, Model.ProjectKey, log)"
				data-testid="log-tab" data-log-name="@log"
				class="btn btn-xs font-mono @(Model.SelectedLog == log ? "btn-primary" : "btn-ghost")">@log</a>
		}
	</div>
}

@if (Model.NoLogs)
{
	<div class="alert" data-testid="logs-none">
		<span>No logs in this project yet.</span>
		<a href="@(Model.ProjectKey is not null ? Routes.ProjectLogsAdmin(ws, Model.ProjectKey) : "#")"
			class="btn btn-sm btn-primary" data-testid="logs-create-link">Create a log</a>
	</div>
	return;
}

<div class="mb-4 flex items-center gap-3 flex-wrap">

	<div class="ml-auto flex items-center gap-1">
		@if (logBase is not null)
		{
			<form method="post" asp-page-handler="save"
				asp-route-workspaceKey="@ws" asp-route-projectKey="@Model.ProjectKey" asp-route-logName="@Model.SelectedLog"
				class="flex items-center gap-1">
				<input type="text" name="name" value="@Model.ActiveSavedName" required
					placeholder="save as…"
					pattern="[A-Za-z0-9 _\-]+"
					data-testid="saved-query-name"
					class="input input-xs input-bordered w-36" />
				<input type="hidden" name="kql" value="@Model.UserKql" />
				<button type="submit" data-testid="saved-query-save" class="btn btn-xs btn-ghost" title="Save current query">Save</button>
			</form>
		}
		@if (!Model.IsShapeChanged && logBase is not null)
		{
			<button type="button" class="btn btn-xs btn-ghost"
				data-share-modal-open
				data-project="@Model.ProjectKey"
				data-log="@Model.SelectedLog"
				data-kql="@Model.UserKql"
				title="Share query as TSV">Share</button>
		}
	</div>
</div>

@if (Model.FlashError is not null)
{
	<div data-testid="logs-flash-error" class="alert alert-error mb-4 text-sm">@Model.FlashError</div>
}

@if (Model.ProjectKey is not null && Model.SelectedLog is not null)
{
	var baseUrl = $"{ViewContext.HttpContext.Request.Scheme}://{ViewContext.HttpContext.Request.Host}";
	var ingestUrl = $"{baseUrl}/api/ingest/{Model.ProjectKey}/{Model.SelectedLog}/clef";
	<details class="bg-base-200 border border-base-300 mb-4 rounded-box">
		<summary class="cursor-pointer font-semibold px-4 py-2 select-none text-sm">Ingestion endpoints</summary>
		<div class="pb-4 px-4">
			<table class="table table-xs">
				<thead>
					<tr>
						<th class="w-32">Protocol</th>
						<th>URL</th>
						<th class="w-48">Auth</th>
						<th class="w-24"></th>
					</tr>
				</thead>
				<tbody>
					<tr>
						<td class="font-mono">CLEF</td>
						<td class="font-mono text-xs">@ingestUrl</td>
						<td class="text-xs"><code>X-Api-Key</code> header + <code>X-Service-Key</code></td>
						<td><button type="button" class="btn btn-xs" data-copy="@ingestUrl">Copy</button></td>
					</tr>
				</tbody>
			</table>
			<p class="mt-2 opacity-60 text-xs"><text>POST one JSON object per line: {@("@t")}:timestring, @("@l"):level, @("@m"):message. The log name is part of the URL path — one key can write to many logs.</text></p>
		</div>
	</details>
}

@if (Model.SavedQueries.Count > 0)
{
	<div class="mb-4 flex flex-wrap items-center gap-2 text-xs">
		<span class="opacity-60">Saved:</span>
		@foreach (var sq in Model.SavedQueries)
		{
			<span class="join">
				<a href="@(logBase)?saved=@Uri.EscapeDataString(sq.Name)"
					data-testid="saved-query-chip"
					class="btn btn-xs join-item font-mono @(Model.ActiveSavedName == sq.Name ? "btn-primary" : "btn-ghost")">@sq.Name</a>
				<form method="post" asp-page-handler="delete"
					asp-route-workspaceKey="@ws" asp-route-projectKey="@Model.ProjectKey" asp-route-logName="@Model.SelectedLog"
					class="join-item">
					<input type="hidden" name="savedId" value="@sq.Id" />
					<button type="submit" class="btn btn-xs btn-ghost"
						onclick="return confirm('Delete saved query @sq.Name?');"
						title="Delete">x</button>
				</form>
			</span>
		}
	</div>
}

<form method="get" id="kql-search-form" class="mb-4 bg-base-200 border border-base-300 rounded-box p-4 flex flex-col gap-3">
	<div class="relative" id="kql-editor">
		<textarea name="kql" rows="6" id="kql-textarea"
			data-testid="kql-input"
			placeholder="events | where Level >= 3 | where Message contains 'error'"
			hx-get="?handler=KqlCompletions"
			hx-trigger="keyup changed delay:250ms, click"
			hx-target="#kql-completions"
			hx-swap="innerHTML"
			hx-vals='js:{ q: document.getElementById("kql-textarea").value, pos: document.getElementById("kql-textarea").selectionStart }'
			class="textarea textarea-sm textarea-bordered w-full font-mono text-xs">@Model.UserKql</textarea>
		<div id="kql-completions" class="absolute left-0 right-0 top-full z-10"></div>
	</div>
	<p class="text-xs opacity-60 -mt-2">Paging (<code>order by</code>, <code>take</code>, cursor) appended automatically.</p>

	<div class="flex gap-2 flex-wrap items-center">
		<button type="submit" data-testid="kql-apply" class="btn btn-sm btn-primary">Apply</button>
		<a href="@logBase" class="btn btn-sm btn-ghost">Reset</a>
		<button type="button" id="kql-pin-toggle" data-testid="kql-pin-toggle"
			class="btn btn-ghost btn-sm"
			aria-pressed="false"
			title="Keep search panel visible when scrolling">Pin</button>
		@if (Model.Services.Count > 0)
		{
			<span class="text-xs opacity-60 ml-auto">Services:</span>
			@foreach (var svc in Model.Services.Take(8))
			{
				<a href="@(logBase)?kql=@Uri.EscapeDataString($"events | where ServiceKey == '{svc}' | take 100")"
					class="badge badge-sm badge-ghost font-mono">@svc</a>
			}
		}
		@if (!Model.IsShapeChanged)
		{
			<label class="label cursor-pointer gap-2">
				<span class="label-text text-xs">Live tail</span>
				<input type="checkbox" id="live-tail-toggle" class="toggle toggle-sm toggle-primary"
					data-project="@Model.ProjectKey"
					data-log="@Model.SelectedLog"
					data-kql="@Model.UserKql" />
			</label>
		}
	</div>
	<input type="hidden" name="liveTail" value="1" id="live-tail-form-field" disabled />
</form>

<dialog id="share-modal" class="modal">
	<div class="modal-box max-w-md">
		<h3 class="text-lg font-semibold mb-1">Share query</h3>
		<p class="text-xs opacity-70 mb-3">The link carries an opaque token — the query text stays on the server. Anyone with the link can view the results until it expires.</p>
		<div class="join w-full">
			<input id="share-url" type="text" readonly class="input input-sm input-bordered join-item w-full font-mono text-xs" />
			<button type="button" class="btn btn-sm join-item" data-share-copy>Copy</button>
		</div>
		<p id="share-expiry" class="text-xs opacity-60 mt-2"></p>
		<form method="dialog" class="mt-3"><button class="btn btn-sm btn-ghost">Close</button></form>
	</div>
	<form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>

@if (Model.KqlError is not null)
{
	<div data-testid="kql-error" class="alert alert-error mb-4">
		<pre class="whitespace-pre-wrap text-xs">@Model.KqlError</pre>
	</div>
}

@if (Model.SchemaMissing)
{
	<div class="alert" data-testid="events-empty">No log entries yet. Ingest some events first.</div>
}
else if (Model.IsShapeChanged)
{
	if (Model.KqlRows.Count == 0)
	{
		<div class="alert">Query returned no rows.</div>
	}
	else
	{
		<div class="overflow-x-auto rounded-box border border-base-300 bg-base-200">
			<table class="table table-sm">
				<thead>
					<tr>
						@foreach (var col in Model.KqlResult!.Columns)
						{
							<th class="font-mono text-xs">@col.Name</th>
						}
					</tr>
				</thead>
				<tbody>
					@foreach (var row in Model.KqlRows)
					{
						<tr class="align-top">
							@foreach (var cell in row)
							{
								<td class="font-mono text-xs">@(cell?.ToString() ?? "")</td>
							}
						</tr>
					}
				</tbody>
			</table>
		</div>
	}
}
else if (Model.Events.Count == 0)
{
	<div data-testid="events-empty" class="alert">No events match the query.</div>
}
else
{
	<div class="overflow-x-auto rounded-box border border-base-300 bg-base-200">
		<table class="table table-sm">
			<thead>
				<tr>
					<th class="w-44">Time</th>
					<th class="w-24">Level</th>
					<th>Message</th>
					<th class="w-40">Service</th>
				</tr>
			</thead>
			<tbody id="events-body" data-testid="events-body">
				<partial name="_RowsFragment" model="Model" />
			</tbody>
		</table>
	</div>
}
