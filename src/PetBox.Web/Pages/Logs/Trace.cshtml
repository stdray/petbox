@page "/ui/{workspaceKey}/{projectKey}/traces/{traceId}"
@model PetBox.Web.Pages.Logs.TraceModel
@{
	ViewData["Title"] = $"Trace {Model.TraceId} — {Model.EffectiveProjectKey}";
	// Build the back URL via Routes.* (not asp-page): asp-page yields an empty href for these
	// custom-routed pages. Carry the resolved log so "← traces" returns to the same view.
	var tracesUrl = PetBox.Web.Routes.ProjectTraces(Model.EffectiveWorkspaceKey, Model.EffectiveProjectKey);
	if (!string.IsNullOrEmpty(Model.SelectedLog))
	{
		tracesUrl += $"?log={Uri.EscapeDataString(Model.SelectedLog)}";
	}
}

<div class="mb-4 flex items-center gap-3">
	<a href="@tracesUrl" class="text-sm opacity-60 hover:opacity-100">&larr; traces</a>
	<h1 class="text-2xl font-semibold">Trace</h1>
	<span class="font-mono text-sm opacity-60">@Model.TraceId</span>
</div>

@if (Model.TraceNotFound)
{
	<div class="alert alert-warning" data-testid="trace-notfound">Trace not found.</div>
}
else
{
	<div class="text-xs opacity-70 mb-3">
		Start: <time class="local-time" datetime="@Model.StartTime.ToString("o")">@Model.StartTime:yyyy-MM-dd HH:mm:ss.fff</time> ·
		Duration: @($"{Model.TotalDuration.TotalMilliseconds:0.0} ms") ·
		Spans: @Model.Rows.Count
	</div>

	<partial name="_TraceWaterfall" model="Model.Rows" />
}
