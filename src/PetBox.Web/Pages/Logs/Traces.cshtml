@page "/ui/{workspaceKey}/{projectKey}/traces"
@model PetBox.Web.Pages.Logs.TracesModel
@{
	ViewData["Title"] = $"Traces — {Model.ProjectName ?? Model.EffectiveProjectKey}";

	string PageHref(int pageNum)
	{
		var href = $"{Routes.ProjectTraces(Model.WorkspaceKey!, Model.EffectiveProjectKey)}?pageNum={pageNum}";
		if (!string.IsNullOrWhiteSpace(Model.SelectedLog)) href += $"&log={Uri.EscapeDataString(Model.SelectedLog)}";
		if (Model.ErrorsOnly) href += "&errorsOnly=true";
		return href;
	}
}

<div class="mb-2 flex items-baseline gap-3 flex-wrap">
	<h1 class="text-2xl font-semibold">@(Model.ProjectName ?? Model.EffectiveProjectKey)</h1>
	<span class="text-sm opacity-60">Traces</span>
</div>

@if (Model.AvailableLogs.Count > 0)
{
	<form method="get" class="mb-3 flex items-center gap-3 flex-wrap" data-testid="traces-filter-form">
		<label class="flex items-center gap-2 text-sm">
			<span class="opacity-60">Log</span>
			<select name="log" class="select select-bordered select-sm" data-testid="traces-log-select">
				@foreach (var log in Model.AvailableLogs)
				{
					if (log == Model.SelectedLog)
					{
						<option value="@log" selected>@log</option>
					}
					else
					{
						<option value="@log">@log</option>
					}
				}
			</select>
		</label>
		<label class="flex items-center gap-2 text-sm cursor-pointer">
			<input type="checkbox" name="errorsOnly" value="true" class="checkbox checkbox-sm" data-testid="traces-errors-only"
				@(Model.ErrorsOnly ? "checked" : "") />
			<span>Errors only</span>
		</label>
		<button type="submit" class="btn btn-sm" data-testid="traces-filter-submit">Apply</button>
	</form>
}

@if (Model.SchemaMissing)
{
	<div class="alert" data-testid="traces-empty">No spans ingested yet.</div>
}
else if (Model.Traces.Count == 0)
{
	<div class="alert" data-testid="traces-empty">@(Model.ErrorsOnly ? "No error traces." : "No traces.")</div>
}
else
{
	<div class="overflow-x-auto">
		<table class="table table-sm" data-testid="traces-table">
			<thead>
				<tr>
					<th class="w-44">Start</th>
					<th>Root span</th>
					<th class="w-24">Duration</th>
					<th class="w-20">Spans</th>
					<th class="w-20">Status</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var t in Model.Traces)
				{
					var statusBadge = t.WorstStatus switch
					{
						2 => "badge-error",
						1 => "badge-success",
						_ => "badge-ghost",
					};
					<tr class="hover" data-testid="trace-row" data-trace-id="@t.TraceId">
						<td class="font-mono text-xs opacity-70">
							<time class="local-time" datetime="@t.StartTime.ToString("o")">@t.StartTime:yyyy-MM-dd HH:mm:ss</time>
						</td>
						<td class="font-mono text-xs">
							<a asp-page="/Logs/Trace" asp-route-workspaceKey="@Model.WorkspaceKey" asp-route-projectKey="@Model.EffectiveProjectKey" asp-route-log="@Model.SelectedLog" asp-route-traceId="@t.TraceId" class="link link-primary">@t.RootName</a>
						</td>
						<td class="font-mono text-xs">@($"{t.Duration.TotalMilliseconds:0.0} ms")</td>
						<td class="text-xs">@t.SpanCount</td>
						<td>
							<span class="badge badge-sm @statusBadge">@(t.WorstStatus == 2 ? "Error" : t.WorstStatus == 1 ? "Ok" : "Unset")</span>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>

	<div class="flex items-center justify-between mt-3 text-sm">
		<span class="opacity-60" data-testid="traces-page-info">page @(Model.PageNum + 1) · @Model.Traces.Count traces</span>
		<div class="join">
			@if (Model.PageNum > 0)
			{
				<a href="@PageHref(Model.PageNum - 1)" class="btn btn-sm join-item" data-testid="traces-prev">‹ Prev</a>
			}
			else
			{
				<button class="btn btn-sm join-item btn-disabled" disabled>‹ Prev</button>
			}
			@if (Model.HasNext)
			{
				<a href="@PageHref(Model.PageNum + 1)" class="btn btn-sm join-item" data-testid="traces-next">Next ›</a>
			}
			else
			{
				<button class="btn btn-sm join-item btn-disabled" disabled>Next ›</button>
			}
		</div>
	</div>
}
