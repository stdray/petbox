@page "/ui/{workspaceKey}/config"
@model PetBox.Web.Pages.Config.IndexModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery antiforgery
@{
	ViewData["Title"] = Model.IsProjectScoped
		? $"Config — {Model.ProjectKey}"
		: $"Shared config — {Model.EffectiveWorkspaceKey}";
	var tokens = antiforgery.GetAndStoreTokens(ViewContext.HttpContext);
	// Build sibling-page URLs via Routes.* rather than asp-page tag helpers: asp-page link
	// generation yields an EMPTY href for these custom-routed Config pages (see _Row / the
	// delete-handler bug fixed in ConfigDeleteBindingTests).
	var ws = Model.EffectiveWorkspaceKey;
	var historyUrl = Model.IsProjectScoped ? PetBox.Web.Routes.ProjectConfigHistory(ws, Model.ProjectKey!) : PetBox.Web.Routes.SharedConfigHistory(ws);
	var previewUrl = Model.IsProjectScoped ? PetBox.Web.Routes.ProjectConfigPreview(ws, Model.ProjectKey!) : PetBox.Web.Routes.SharedConfigPreview(ws);
	var tagsUrl = PetBox.Web.Routes.SharedConfigTags(ws);
	var clearUrl = Model.IsProjectScoped ? PetBox.Web.Routes.ProjectConfig(ws, Model.ProjectKey!) : PetBox.Web.Routes.SharedConfig(ws);
}

@if (Model.IsProjectScoped)
{
	<div class="mb-2 flex items-baseline gap-3 flex-wrap">
		<h1 class="text-2xl font-semibold">@Model.ProjectKey</h1>
		<span class="text-sm opacity-60">Config</span>
	</div>
	<partial name="_ConfigTabs" />
}

<div class="flex items-center gap-3 mb-4 flex-wrap">
	@if (Model.IsProjectScoped)
	{
		<h2 class="text-lg font-semibold" data-testid="config-title">Bindings (@Model.Rows.Count)</h2>
		<span class="badge badge-info badge-sm font-mono" data-testid="config-project-filter" title="Auto-filter: project:@Model.ProjectKey">project:@Model.ProjectKey</span>
	}
	else
	{
		<h1 class="text-xl font-semibold" data-testid="config-title">Shared bindings (@Model.Rows.Count)</h1>
		<span class="badge badge-outline font-mono">@Model.EffectiveWorkspaceKey</span>
	}

	<div class="ml-auto flex items-center gap-2">
		<a href="@historyUrl" class="btn btn-sm btn-ghost" data-testid="config-history-link">History</a>
		<a href="@previewUrl" class="btn btn-sm btn-ghost" data-testid="config-preview-link">Preview</a>
		@if (!Model.IsProjectScoped)
		{
			<a href="@tagsUrl" class="btn btn-sm btn-ghost" data-testid="config-tags-link">Tags</a>
		}
		<a href="@(Model.IsProjectScoped ? PetBox.Web.Routes.ProjectConfigEditor(Model.EffectiveWorkspaceKey, Model.ProjectKey!) : PetBox.Web.Routes.SharedConfigEditor(Model.EffectiveWorkspaceKey))" class="btn btn-sm btn-primary" data-testid="config-new">+ New binding</a>
	</div>
</div>

<input type="hidden" id="__requestVerificationToken" value="@tokens.RequestToken" />
<meta name="config-workspace-key" content="@Model.EffectiveWorkspaceKey" />

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
	<div class="alert alert-error mb-3" data-testid="config-error">@Model.ErrorMessage</div>
}

<form method="get" class="mb-4 flex flex-wrap items-end gap-2" data-testid="config-filter-form">
	<label class="form-control">
		<span class="label-text">Key path</span>
		<input type="text" name="q" value="@Model.KeyQuery"
			placeholder="db.host, cache.*"
			class="input input-bordered input-sm font-mono text-xs"
			data-testid="config-filter-key" />
	</label>

	@foreach (var tagKey in Model.FacetKeys)
	{
		<label class="form-control">
			<span class="label-text font-mono text-xs">@tagKey</span>
			<select name="t.@tagKey" class="select select-bordered select-sm font-mono text-xs"
				data-testid="config-filter-tag" data-tag-key="@tagKey">
				<option value="" selected="@(!Model.TagFilter.ContainsKey(tagKey))">(any)</option>
				@foreach (var v in Model.FacetValues[tagKey])
				{
					<option value="@v" selected="@(Model.TagFilter.TryGetValue(tagKey, out var cur) && cur == v)">@v</option>
				}
			</select>
		</label>
	}

	<button type="submit" class="btn btn-sm" data-testid="config-filter-apply">Apply</button>
	<a href="@clearUrl" class="btn btn-sm btn-ghost" data-testid="config-filter-clear">Clear</a>
</form>

@{
	string ChipHref(string filterTags)
	{
		var parts = PetBox.Web.Pages.Config.IndexModel.ParseTagsDisplay(filterTags)
			.Select(p => $"t.{Uri.EscapeDataString(p.Key)}={Uri.EscapeDataString(p.Value)}");
		return "?" + string.Join("&", parts);
	}
	bool ChipActive(string filterTags)
	{
		var parts = PetBox.Web.Pages.Config.IndexModel.ParseTagsDisplay(filterTags);
		return parts.Count > 0 && parts.Count == Model.TagFilter.Count
			&& parts.All(p => Model.TagFilter.TryGetValue(p.Key, out var v) && v == p.Value);
	}
}

<div class="card card-compact bg-base-200/40 border border-base-300 mb-4" data-testid="config-saved-filters">
	<div class="card-body gap-2">
		<div class="flex items-center gap-2 flex-wrap">
			<span class="text-xs font-semibold uppercase opacity-60">Saved filters</span>
			@if (Model.SavedFilters.Count == 0)
			{
				<span class="text-xs opacity-50 italic" data-testid="config-saved-filters-empty">none yet — apply a tag filter, then save it below</span>
			}
			@foreach (var f in Model.SavedFilters)
			{
				var label = string.Join(" & ", PetBox.Web.Pages.Config.IndexModel.ParseTagsDisplay(f.FilterTags).Select(p => $"{p.Key} = {p.Value}"));
				<span class="join" data-testid="config-saved-filter" data-filter-name="@f.Name">
					<a href="@ChipHref(f.FilterTags)"
						class="btn btn-xs join-item @(ChipActive(f.FilterTags) ? "btn-primary" : "btn-outline")"
						title="@label" data-testid="config-saved-filter-apply">
						<span class="font-medium">@f.Name</span>
						<span class="font-mono opacity-70 ml-1">@label</span>
					</a>
					<form method="post" action="@(clearUrl)?handler=DeleteFilter" class="join-item"
						onsubmit="return confirm('Delete saved filter @f.Name?')">
						@Html.AntiForgeryToken()
						<input type="hidden" name="id" value="@f.Id" />
						<button type="submit" class="btn btn-xs btn-outline btn-error" title="Delete saved filter"
							data-testid="config-saved-filter-delete">✕</button>
					</form>
				</span>
			}
		</div>

		@if (Model.TagFilter.Count > 0)
		{
			<form method="post" action="@(clearUrl)?handler=SaveFilter" class="flex items-end gap-2 flex-wrap"
				data-testid="config-save-filter-form">
				@Html.AntiForgeryToken()
				@foreach (var (k, v) in Model.TagFilter)
				{
					<input type="hidden" name="t.@k" value="@v" />
				}
				@if (!string.IsNullOrEmpty(Model.KeyQuery))
				{
					<input type="hidden" name="q" value="@Model.KeyQuery" />
				}
				<label class="form-control">
					<span class="label-text text-xs">Save current filter
						<span class="font-mono opacity-60">(@string.Join(" & ", Model.TagFilter.Select(p => $"{p.Key} = {p.Value}")))</span>
					</span>
					<input type="text" name="name" required maxlength="200" placeholder="filter name"
						class="input input-bordered input-xs" data-testid="config-save-filter-name" />
				</label>
				<button type="submit" class="btn btn-xs btn-primary" data-testid="config-save-filter-submit">Save</button>
			</form>
		}
	</div>
</div>

@if (Model.Rows.Count == 0)
{
	<div class="text-xs opacity-60 italic mb-4" data-testid="config-empty">No bindings match the current filter.</div>
}
else
{
	<div class="overflow-x-auto">
		<table class="table table-sm" data-testid="config-table">
			<thead>
				<tr>
					<th>Tags</th>
					<th>Key</th>
					<th>Value</th>
					<th>Updated</th>
					<th></th>
				</tr>
			</thead>
			<tbody>
				@foreach (var b in Model.Rows)
				{
					<partial name="_Row" model='new PetBox.Web.Pages.Config.RowViewModel(b, Model.EffectiveWorkspaceKey, Model.ProjectKey, Model.KeyQuery, Model.TagFilter)' />
				}
			</tbody>
		</table>
	</div>
}
