@model PetBox.Web.Pages.Config.RowViewModel
@{
	Layout = null;
	var parsedTags = PetBox.Web.Pages.Config.IndexModel.ParseTagsDisplay(Model.Binding.Tags);
	var isSecret = Model.Binding.Kind == PetBox.Core.Models.BindingKind.Secret;
	// Build URLs via Routes.* (not asp-page tag helpers): asp-page link generation returns an
	// EMPTY href/action for these custom-routed Config pages, so the Del/Edit buttons posted to
	// the current URL with no handler — a 200 no-op. See ConfigDeleteBindingTests.
	var isProjectScoped = !string.IsNullOrEmpty(Model.ProjectKey);
	var editUrl = isProjectScoped
		? PetBox.Web.Routes.ProjectConfigEditor(Model.WorkspaceKey, Model.ProjectKey!, Model.Binding.Id)
		: PetBox.Web.Routes.SharedConfigEditor(Model.WorkspaceKey, Model.Binding.Id);
	var configUrl = isProjectScoped
		? PetBox.Web.Routes.ProjectConfig(Model.WorkspaceKey, Model.ProjectKey!)
		: PetBox.Web.Routes.SharedConfig(Model.WorkspaceKey);
	var deleteUrl = $"{configUrl}?handler=Delete&id={Model.Binding.Id}";
}
<tr data-testid="config-row" data-binding-id="@Model.Binding.Id">
	<td class="text-xs" data-testid="config-tags">
		@if (parsedTags.Count == 0)
		{
			<span class="opacity-50">(root)</span>
		}
		else
		{
			@foreach (var (k, v) in parsedTags)
			{
				<span class="badge badge-sm mr-1">@k=@v</span>
			}
		}
	</td>
	<td class="font-mono text-xs text-primary" data-testid="config-path">@Model.Binding.Path</td>
	<td class="font-mono text-xs max-w-xs" data-testid="config-value">
		@if (isSecret)
		{
			<span data-testid="config-secret-masked" data-binding-id="@Model.Binding.Id">••••••</span>
			<button type="button" class="btn btn-xs btn-ghost ml-2"
				data-testid="config-secret-reveal" data-binding-id="@Model.Binding.Id"
				title="Reveal for 10s">👁</button>
		}
		else
		{
			<span class="truncate inline-block max-w-xs align-bottom" data-testid="config-plain-value">@Model.Binding.Value</span>
			<button type="button" class="btn btn-xs btn-ghost ml-1"
				data-copy="@Model.Binding.Value" title="Copy value">⧉</button>
		}
	</td>
	<td class="text-xs opacity-60" data-testid="config-updated">@Model.Binding.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
	<td class="text-right">
		<div class="flex gap-1 justify-end">
			<a href="@editUrl" class="btn btn-xs btn-ghost" data-testid="config-edit-btn">Edit</a>
			<form method="post" action="@deleteUrl"
				onsubmit="return confirm('Delete binding @Model.Binding.Path?')" style="display:inline">
				@Html.AntiForgeryToken()
				@if (Model.KeyQuery is not null)
				{
					<input type="hidden" name="q" value="@Model.KeyQuery" />
				}
				@foreach (var (k, v) in Model.TagFilter)
				{
					<input type="hidden" name="t.@k" value="@v" />
				}
				<button type="submit" class="btn btn-xs btn-ghost text-error" data-testid="config-delete">Del</button>
			</form>
		</div>
	</td>
</tr>
