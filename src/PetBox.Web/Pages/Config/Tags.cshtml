@page "/ui/{workspaceKey}/config/tags"
@model PetBox.Web.Pages.Config.TagsModel
@{
	ViewData["Title"] = $"Tag Vocabulary — {Model.EffectiveWorkspaceKey}";
	var declaredKeys = Model.Declared.Select(d => d.TagKey).ToHashSet(StringComparer.Ordinal);
}

<div class="mb-4 text-sm">
	<a href="@PetBox.Web.Routes.SharedConfig(Model.EffectiveWorkspaceKey)"
		class="link opacity-70 hover:opacity-100" data-testid="back-to-config">← All bindings</a>
	<span class="badge badge-outline font-mono ml-2">@Model.EffectiveWorkspaceKey</span>
</div>

<h1 class="text-xl font-semibold mb-4" data-testid="config-tags-title">Tag Vocabulary</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
	<div class="alert alert-error mb-3">@Model.ErrorMessage</div>
}

<form method="post" asp-page-handler="Declare" class="card bg-base-200 mb-6" data-testid="config-tags-declare-form">
	@Html.AntiForgeryToken()
	<div class="card-body p-4">
		<div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
			<label class="form-control">
				<span class="label-text">Tag key</span>
				<input type="text" name="TagKey" required
					placeholder="env"
					class="input input-bordered input-sm font-mono text-xs"
					data-testid="config-tags-declare-key" />
			</label>
			<label class="form-control sm:col-span-2">
				<span class="label-text">Description</span>
				<input type="text" name="Description"
					placeholder="Deployment environment (dev | staging | prod)"
					class="input input-bordered input-sm text-xs"
					data-testid="config-tags-declare-desc" />
			</label>
		</div>
		<div class="card-actions mt-3">
			<button type="submit" class="btn btn-sm btn-primary" data-testid="config-tags-declare-submit">Declare</button>
		</div>
	</div>
</form>

<h2 class="text-lg font-semibold mb-2">Declared keys (@Model.Declared.Count)</h2>
<div class="overflow-x-auto mb-6">
	<table class="table table-sm" data-testid="config-tags-declared-table">
		<thead>
			<tr>
				<th>Key</th>
				<th>Description</th>
				<th>Used values</th>
				<th></th>
			</tr>
		</thead>
		<tbody>
			@foreach (var d in Model.Declared)
			{
				<tr data-testid="config-tags-declared-row">
					<td class="font-mono text-xs">@d.TagKey</td>
					<td class="text-xs opacity-70">@d.Description</td>
					<td class="text-xs">
						@if (Model.UsedKeyValues.TryGetValue(d.TagKey, out var values))
						{
							@foreach (var v in values)
							{
								<span class="badge badge-sm mr-1">@v</span>
							}
						}
					</td>
					<td class="text-right">
						<form method="post" asp-page-handler="Retire" asp-route-id="@d.Id" style="display:inline">
							@Html.AntiForgeryToken()
							<button type="submit" class="btn btn-xs btn-ghost text-error" data-testid="config-tags-retire">Retire</button>
						</form>
					</td>
				</tr>
			}
		</tbody>
	</table>
</div>

<h2 class="text-lg font-semibold mb-2">In use, not declared</h2>
<div class="flex flex-wrap gap-2">
	@foreach (var (key, values) in Model.UsedKeyValues.Where(kv => !declaredKeys.Contains(kv.Key)))
	{
		<div class="badge badge-outline text-xs font-mono" data-testid="config-tags-undeclared">@key (@values.Count)</div>
	}
</div>
