@page "/ui/admin/sys"
@model PetBox.Web.Pages.Admin.IndexModel
@{
	ViewData["Title"] = "System administration";
	Layout = "_AdminLayout";
}

<div class="mb-4">
	<h1 class="text-2xl font-semibold" data-testid="sys-title">System administration</h1>
	<p class="text-sm opacity-60">Cross-workspace settings. Affects every tenant.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4" data-testid="sys-cards">
	<a href="@Routes.SysWorkspaces()" class="card bg-base-200 border border-base-300 hover:border-primary transition-colors" data-testid="sys-card-workspaces">
		<div class="card-body p-4">
			<div class="flex items-baseline justify-between">
				<h2 class="card-title text-base">Workspaces</h2>
				<span class="font-mono text-2xl opacity-80">@Model.WorkspaceCount</span>
			</div>
			<p class="text-xs opacity-60">Create, rename, delete tenants. <code class="font-mono">$system</code> is always present.</p>
		</div>
	</a>

	<a href="@Routes.SysUsers()" class="card bg-base-200 border border-base-300 hover:border-primary transition-colors" data-testid="sys-card-users">
		<div class="card-body p-4">
			<div class="flex items-baseline justify-between">
				<h2 class="card-title text-base">Users</h2>
				<span class="font-mono text-2xl opacity-80">@Model.UserCount</span>
			</div>
			<p class="text-xs opacity-60">Accounts that can sign in to the UI. Workspace membership is set per workspace.</p>
		</div>
	</a>

	<a href="@Routes.SysAgentKeys()" class="card bg-base-200 border border-base-300 hover:border-primary transition-colors" data-testid="sys-card-agent-keys">
		<div class="card-body p-4">
			<div class="flex items-baseline justify-between">
				<h2 class="card-title text-base">Agent keys</h2>
				<span class="font-mono text-2xl opacity-80">@Model.AgentKeyCount</span>
			</div>
			<p class="text-xs opacity-60">DB-minted API keys across all projects. Review and revoke.</p>
		</div>
	</a>

	@if (Model.DeployEnabled)
	{
		<a href="@Routes.SysDeploy()" class="card bg-base-200 border border-base-300 hover:border-primary transition-colors" data-testid="sys-card-deploy">
			<div class="card-body p-4">
				<div class="flex items-baseline justify-between">
					<h2 class="card-title text-base">Deploy</h2>
					<span class="font-mono text-2xl opacity-80">@Model.DeployNodeCount<span class="text-xs opacity-50"> nodes</span></span>
				</div>
				<p class="text-xs opacity-60">The fleet's nodes and desired-state deployments.</p>
			</div>
		</a>
	}

	<a href="@Routes.SysDefaults()" class="card bg-base-200 border border-base-300 hover:border-primary transition-colors" data-testid="sys-card-defaults">
		<div class="card-body p-4">
			<div class="flex items-baseline justify-between">
				<h2 class="card-title text-base">Defaults</h2>
				<span class="font-mono text-2xl opacity-80">@Model.SettingOverrideCount<span class="text-xs opacity-50"> system-set</span></span>
			</div>
			<p class="text-xs opacity-60">System-level setting defaults for every workspace and project.</p>
		</div>
	</a>

	<a href="@Routes.SysWorkspaces()" class="card bg-base-200 border border-base-300 hover:border-primary transition-colors" data-testid="sys-card-projects">
		<div class="card-body p-4">
			<div class="flex items-baseline justify-between">
				<h2 class="card-title text-base">Projects (all workspaces)</h2>
				<span class="font-mono text-2xl">@Model.ProjectCount</span>
			</div>
			<p class="text-xs opacity-60">Drill into a workspace to manage its projects.</p>
		</div>
	</a>
</div>
