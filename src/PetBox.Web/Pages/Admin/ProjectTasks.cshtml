@page "/ui/admin/ws/{workspaceKey}/projects/{projectKey}/tasks"
@model PetBox.Web.Pages.Admin.ProjectTasksModel
@{
	ViewData["Title"] = $"{Model.ProjectKey} — Tasks";
	Layout = "_AdminLayout";
}

<div class="mb-4 flex items-baseline gap-3 flex-wrap">
	<h1 class="text-2xl font-semibold">@Model.ProjectKey · task boards</h1>
	<span class="badge badge-ghost">@Model.Boards.Count board(s)</span>
</div>

@if (Model.ProjectNotFound)
{
	<p class="text-error font-semibold" data-testid="project-tasks-error">Project not found</p>
	return;
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
	<div class="alert alert-error mb-3" data-testid="project-tasks-error-msg">@Model.ErrorMessage</div>
}

<section class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-6" data-testid="boards-list">
	@if (Model.Boards.Count == 0)
	{
		<div class="text-xs opacity-60 italic" data-testid="boards-empty">No task boards yet. Create one below.</div>
	}
	else
	{
		@foreach (var b in Model.Boards)
		{
			<div class="card bg-base-200 border border-base-300" data-testid="board-card" data-board-name="@b.Name">
				<div class="card-body p-4">
					<a href="@Routes.ProjectTaskBoard(Model.WorkspaceKey, Model.ProjectKey, b.Name)"
						class="font-mono font-semibold link link-hover" data-testid="board-open">@b.Name</a>
					@if (!string.IsNullOrEmpty(b.Description))
					{
						<p class="text-sm opacity-80">@b.Description</p>
					}
					<div class="flex gap-1 mt-1">
						<span class="badge badge-ghost badge-xs" data-testid="board-kind">@b.Kind</span>
						@if (b.ClosedAt != null)
						{
							<span class="badge badge-warning badge-xs" data-testid="board-closed-badge">closed</span>
						}
					</div>
					<div class="card-actions justify-between mt-2">
						<span class="text-xs opacity-50 font-mono">@b.CreatedAt.ToString("yyyy-MM-dd")</span>
						<div class="flex gap-1">
							<form method="post" asp-page-handler="Close" asp-route-name="@b.Name" asp-route-closed="@(b.ClosedAt == null)" style="display:inline">
								@Html.AntiForgeryToken()
								<button type="submit" class="btn btn-xs btn-ghost" data-testid="board-close">@(b.ClosedAt == null ? "Close" : "Reopen")</button>
							</form>
							<form method="post" asp-page-handler="Delete" asp-route-name="@b.Name"
								onsubmit="return confirm('Delete board @b.Name? All plan nodes will be removed.')" style="display:inline">
								@Html.AntiForgeryToken()
								<button type="submit" class="btn btn-xs btn-ghost text-error" data-testid="board-delete">Delete</button>
							</form>
						</div>
					</div>
				</div>
			</div>
		}
	}
</section>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-3 max-w-4xl">

	@* Methodology: the intake→ideas→spec→work quartet as ONE unit (per-project singletons). *@
	<div class="card bg-base-200 border border-base-300" data-testid="methodology-card">
		<div class="card-body p-4">
			<h3 class="card-title text-base">Methodology</h3>
			@if (Model.MethodologyEnabled)
			{
				<p class="text-sm opacity-80">Enabled — this project runs the <span class="font-mono">intake → ideas → spec → work</span> quartet (one board of each, work auto-linked to spec). Add ad-hoc work as <em>free</em> boards on the right.</p>
				<div class="mt-1"><span class="badge badge-success badge-sm" data-testid="methodology-enabled">methodology enabled</span></div>
			}
			else
			{
				<p class="text-sm opacity-80">Provision the four linked boards — <span class="font-mono">intake</span>, <span class="font-mono">ideas</span>, <span class="font-mono">spec</span>, <span class="font-mono">work</span> — as a single unit and auto-wire work → spec. Idempotent (adds only what's missing). The four kinds are one-per-project; pick this <strong>or</strong> free boards.</p>
				<form method="post" asp-page-handler="EnableMethodology" class="card-actions mt-3" data-testid="methodology-enable-form">
					@Html.AntiForgeryToken()
					<button type="submit" class="btn btn-sm btn-primary" data-testid="methodology-enable">Enable methodology</button>
				</form>
			}
		</div>
	</div>

	@* Free boards: scratch / ad-hoc, unlimited. The only kind a human creates by hand. *@
	<form method="post" asp-page-handler="Create" class="card bg-base-200 border border-base-300" data-testid="board-create-form">
		@Html.AntiForgeryToken()
		<div class="card-body p-4">
			<h3 class="card-title text-base">Free board</h3>
			<p class="text-sm opacity-80">A scratch board with no workflow rules — for anything outside the methodology.</p>
			<label class="form-control mt-1">
				<span class="label-text">Name</span>
				<input type="text" name="name" required minlength="1"
					pattern="[a-z][a-z0-9_\-]*"
					class="input input-bordered input-sm font-mono"
					placeholder="roadmap"
					data-testid="board-create-name" />
				<span class="text-xs opacity-60 mt-1">Lowercase letters, digits, `_` or `-`. Starts with a letter.</span>
			</label>
			<label class="form-control mt-2">
				<span class="label-text">Description (optional)</span>
				<input type="text" name="description"
					class="input input-bordered input-sm"
					placeholder="the plan"
					data-testid="board-create-desc" />
			</label>
			<div class="card-actions mt-3">
				<button type="submit" class="btn btn-sm btn-primary" data-testid="board-create-submit">Create free board</button>
			</div>
		</div>
	</form>
</div>
