@page "/ui/admin/sys/agent-keys"
@model PetBox.Web.Pages.Admin.AgentKeysModel
@{
	ViewData["Title"] = "Agent Keys";
	Layout = "_AdminLayout";
}

<div class="mb-4">
	<h1 class="text-2xl font-semibold" data-testid="sys-agent-keys-title">Agent Keys</h1>
	<p class="text-sm opacity-60">Management view of the DB-minted API keys issued across all projects — review what exists and revoke what's stale. Minting lives elsewhere (see below).</p>
</div>

<div class="alert bg-base-200 border border-base-300 mb-4 text-sm" data-testid="sys-agent-keys-mint-hint">
	<div>
		<div class="font-semibold mb-1">Where to mint keys</div>
		<ul class="list-disc list-inside space-y-0.5 opacity-80">
			<li>Per-project keys — from the project's Connect page (sidebar → project → Connect).</li>
			<li>Cross-project or TTL-scoped keys — via the MCP <code class="font-mono">apikey_create</code> tool.</li>
		</ul>
	</div>
</div>

<div class="flex items-center gap-3 mb-3">
	<h2 class="text-lg font-semibold">Active &amp; expired keys</h2>
	<span class="badge badge-ghost">@Model.Keys.Count</span>
</div>

@if (Model.Keys.Count == 0)
{
	<div class="text-xs opacity-60 italic" data-testid="sys-agent-keys-empty">No agent keys.</div>
}
else
{
	<div class="overflow-x-auto">
		<table class="table table-sm" data-testid="sys-agent-keys-table">
			<thead>
				<tr>
					<th>Name</th>
					<th>Project</th>
					<th>Scopes</th>
					<th>Expires</th>
					<th class="w-24">Actions</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var k in Model.Keys)
				{
					<tr data-testid="agent-key-row">
						<td>@k.Name</td>
						<td class="font-mono text-xs">
							@if (k.ProjectKey == "*")
							{
								<span class="badge badge-warning badge-sm" data-testid="agent-key-all-projects-badge">all projects</span>
							}
							else
							{
								@k.ProjectKey
							}
						</td>
						<td class="font-mono text-xs">@k.Scopes</td>
						<td class="text-xs">
							@if (k.Expired)
							{
								<span class="badge badge-error badge-sm" data-testid="agent-key-expired">expired</span>
							}
							else if (k.ExpiresAt is null)
							{
								<span class="badge badge-ghost badge-sm" data-testid="agent-key-never-expires">never</span>
							}
							else
							{
								<span class="font-mono opacity-70">@k.ExpiresAt?.ToString("yyyy-MM-dd HH:mm")</span>
							}
						</td>
						<td>
							<form method="post" asp-page-handler="Revoke" onsubmit="return confirm('Revoke this key?');">
								<input type="hidden" name="key" value="@k.Key" />
								<button type="submit" class="btn btn-ghost btn-xs text-error" data-testid="agent-key-revoke">Revoke</button>
							</form>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
}
