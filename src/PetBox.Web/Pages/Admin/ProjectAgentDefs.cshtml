@page "/ui/admin/ws/{workspaceKey}/projects/{projectKey}/agent-defs"
@model PetBox.Web.Pages.Admin.ProjectAgentDefsModel
@{
	ViewData["Title"] = $"{Model.ProjectKey} — Agent definitions";
	Layout = "_AdminLayout";
}

<div class="mb-4 flex items-baseline gap-3 flex-wrap">
	<h1 class="text-2xl font-semibold">@Model.ProjectKey · agent definitions</h1>
	<span class="badge badge-ghost" data-testid="agent-defs-count">@Model.Items.Count definition(s)</span>
</div>

@if (Model.ProjectNotFound)
{
	<p class="text-error font-semibold" data-testid="agent-defs-not-found">Project not found</p>
	return;
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
	<div class="alert alert-error mb-4 whitespace-pre-wrap font-mono text-sm" data-testid="agent-defs-errors">@Model.ErrorMessage</div>
}

<section class="mb-6 max-w-4xl" data-testid="agent-defs-list">
	@if (Model.Items.Count == 0)
	{
		<div class="text-xs opacity-60 italic" data-testid="agent-defs-empty">No agent definitions yet. Create one below.</div>
	}
	else
	{
		<div class="overflow-x-auto">
			<table class="table table-sm">
				<thead>
					<tr><th>key</th><th>name</th><th class="w-24">version</th><th class="w-40">updated</th><th class="w-24"></th></tr>
				</thead>
				<tbody>
					@foreach (var item in Model.Items)
					{
						<tr data-testid="agent-defs-row" data-def-key="@item.Key">
							<td class="font-mono">
								<a href="?key=@Uri.EscapeDataString(item.Key)" class="link link-hover font-semibold" data-testid="agent-defs-open">@item.Key</a>
							</td>
							<td data-testid="agent-defs-row-name">@item.Name</td>
							<td class="font-mono" data-testid="agent-defs-row-version">@item.Version</td>
							<td class="font-mono text-xs opacity-70">@item.Updated.ToString("yyyy-MM-dd HH:mm")</td>
							<td>
								<form method="post" asp-page-handler="Delete"
									data-confirm="Delete agent definition '@item.Key'? The stored document is removed."
									data-testid="agent-defs-delete-form">
									@Html.AntiForgeryToken()
									<input type="hidden" name="key" value="@item.Key" />
									<input type="hidden" name="version" value="@item.Version" />
									<button type="submit" class="btn btn-xs btn-ghost text-error" data-testid="agent-defs-delete">Delete</button>
								</form>
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	}
</section>

@if (!string.IsNullOrEmpty(Model.Key))
{
	@* The document editor: the SAME wire shape agent_def_get / agent_def_upsert use. Saving
	   posts the raw JSON, so the `model`-not-allowed reject runs on exactly what was typed. *@
	<form method="post" asp-page-handler="Save" class="max-w-4xl mb-4" data-testid="agent-defs-editor">
		@Html.AntiForgeryToken()
		<input type="hidden" name="key" value="@Model.Key" data-testid="agent-defs-editor-key" />
		<input type="hidden" name="version" value="@Model.Version" data-testid="agent-defs-version" />
		<div class="flex items-baseline gap-2 flex-wrap mb-2">
			<span class="font-semibold">Editing</span>
			<span class="font-mono" data-testid="agent-defs-editor-slug">@Model.Key</span>
			<span class="badge badge-ghost badge-sm font-mono" data-testid="agent-defs-editor-version">version @Model.Version</span>
			@if (Model.Stored is not null)
			{
				<span class="text-xs opacity-60">Updated @Model.Stored.Updated.ToString("yyyy-MM-dd HH:mm") UTC</span>
			}
		</div>
		<label class="form-control">
			<span class="label-text">Definition document (JSON)</span>
			<textarea name="definitionJson" rows="24" spellcheck="false" wrap="off" data-json-highlight
				class="textarea textarea-bordered font-mono text-xs leading-snug w-full"
				placeholder='{ "name": "team", "roles": [ { "slug": "worker", "tier": "worker", "requiredCapabilities": [] } ] }'
				data-testid="agent-defs-json">@Model.DefinitionJson</textarea>
		</label>
		<p class="text-xs opacity-60 mt-1" data-testid="agent-defs-schema-note">
			The server stores your document as written: fields outside the schema below (for example
			<span class="font-mono">notes</span>) are preserved as-is and come back on reopen — the compilers simply ignore them.
			A <span class="font-mono">model</span> property is rejected outright, anywhere in the tree.
		</p>
		<div class="mt-3 flex gap-2 items-center">
			<button type="submit" class="btn btn-sm btn-primary" data-testid="agent-defs-save">Save definition</button>
			<a href="?" class="link link-hover text-sm opacity-70" data-testid="agent-defs-cancel">Cancel</a>
		</div>
	</form>
}

<form method="post" asp-page-handler="Create" class="card bg-base-200 border border-base-300 max-w-4xl" data-testid="agent-defs-create-form">
	@Html.AntiForgeryToken()
	<div class="card-body p-4">
		<h3 class="card-title text-base">Create definition</h3>
		<label class="form-control">
			<span class="label-text">Key</span>
			<input type="text" name="key" required minlength="1" maxlength="100"
				pattern="[a-z][a-z0-9_\-]*"
				class="input input-bordered input-sm font-mono"
				placeholder="core-team"
				data-testid="agent-defs-create-key" />
			<span class="text-xs opacity-60 mt-1">Lowercase letters, digits, `_` or `-`. Starts with a letter. The new key opens in the editor with a starter document.</span>
		</label>
		<div class="card-actions mt-3">
			<button type="submit" class="btn btn-sm btn-primary" data-testid="agent-defs-create-submit">Create</button>
		</div>
	</div>
</form>

@* Reference: the portable document shape, plus the one hard rule — no model binding, ever. *@
<details class="collapse collapse-arrow bg-base-200 border border-base-300 mt-6 max-w-4xl" data-testid="agent-defs-reference">
	<summary class="collapse-title font-semibold">Definition reference</summary>
	<div class="collapse-content overflow-x-auto">
		<p class="text-xs opacity-70 mb-2">
			A portable agent definition is a roster: a name and the roles a team may run. It is the same
			document <span class="font-mono">agent_def_get</span> / <span class="font-mono">agent_def_upsert</span> exchange,
			so it moves between this page, MCP and other projects unchanged.
		</p>

		<h3 class="font-mono font-semibold text-sm mt-3" data-testid="agent-defs-reference-entity">definition</h3>
		<table class="table table-xs mt-1">
			<thead>
				<tr><th class="w-56">field</th><th class="w-40">type</th><th>description</th></tr>
			</thead>
			<tbody>
				<tr><td class="font-mono">name</td><td class="font-mono opacity-70">string</td><td>Display name of the roster. Required.</td></tr>
				<tr><td class="font-mono">roles</td><td class="font-mono opacity-70">role[]</td><td>At least one role. Required.</td></tr>
			</tbody>
		</table>

		<h3 class="font-mono font-semibold text-sm mt-3" data-testid="agent-defs-reference-entity">role</h3>
		<table class="table table-xs mt-1">
			<thead>
				<tr><th class="w-56">field</th><th class="w-40">type</th><th>description</th></tr>
			</thead>
			<tbody>
				<tr><td class="font-mono">slug</td><td class="font-mono opacity-70">string</td><td>Role identifier inside the roster. Required.</td></tr>
				<tr><td class="font-mono">tier</td><td class="font-mono opacity-70">string</td><td>Role tier (e.g. <span class="font-mono">orchestrator</span>, <span class="font-mono">worker</span>). Required.</td></tr>
				<tr><td class="font-mono">requiredCapabilities</td><td class="font-mono opacity-70">string[]</td><td>Capabilities the role needs. Required, may be empty.</td></tr>
				<tr><td class="font-mono">spawn</td><td class="font-mono opacity-70">object</td><td><span class="font-mono">{ allowed: bool, allowedRoles?: string[] }</span> — may this role start others, and which.</td></tr>
				<tr><td class="font-mono">escalation</td><td class="font-mono opacity-70">object</td><td><span class="font-mono">{ available: bool, targets?: string[] }</span> — may this role escalate, and to whom.</td></tr>
			</tbody>
		</table>

		<h3 class="font-semibold text-sm mt-4">No model binding in a definition</h3>
		<p class="text-xs opacity-70 mt-1" data-testid="agent-defs-reference-model-rule">
			A <span class="font-mono">model</span> property is not allowed <em>anywhere</em> in the document — not at the root,
			not on a role, not nested. A save carrying one is rejected and names the offending JSON path. Definitions are
			portable, models are not: the role → model binding is machine-local and lives in
			<span class="font-mono">~/.petbox/roles.json</span> on the machine that runs the agents.
		</p>

		<h3 class="font-semibold text-sm mt-4">Unknown fields are preserved, not interpreted</h3>
		<p class="text-xs opacity-70 mt-1" data-testid="agent-defs-reference-unknown-rule">
			The server stores the document you wrote, so any property outside the schema above (for example a per-role
			<span class="font-mono">notes</span>) is kept verbatim and comes back when you reopen the editor. Nothing reads
			it: the compilers use the fields above only. The one exception is <span class="font-mono">model</span>, which is
			rejected rather than stored.
		</p>
	</div>
</details>
