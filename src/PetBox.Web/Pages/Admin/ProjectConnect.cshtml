@page "/ui/admin/ws/{workspaceKey}/projects/{projectKey}/connect"
@model PetBox.Web.Pages.Admin.ProjectConnectModel
@{
	ViewData["Title"] = $"{Model.ProjectKey} — Connect agent";
	Layout = "_AdminLayout";
	var mcp = Model.McpUrl;
	var key = Model.NewKey;
	var proj = Model.ProjectKey;
	var doc = Model.DocAgentUrl;
	var onboarding = Model.DocOnboardingUrl;
	var overview = Model.DocOverviewUrl;
	var methodology = Model.DocMethodologyUrl;
	var envvar = Model.EnvVarName;
}

<div class="mb-4 flex items-baseline gap-3 flex-wrap">
	<h1 class="text-2xl font-semibold">@Model.ProjectKey · connect agent</h1>
</div>

@if (Model.ProjectNotFound)
{
	<p class="text-error font-semibold" data-testid="project-connect-error">Project not found</p>
	return;
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
	<div class="alert alert-error mb-3" data-testid="project-connect-error-msg">@Model.ErrorMessage</div>
}

<div class="prose prose-sm max-w-3xl mb-6">
	<p>
		This wires a coding agent to PetBox over <strong>MCP</strong> (Model Context Protocol).
		Once connected, the agent can read and write this project's <strong>task boards</strong>,
		<strong>memory stores</strong> and <strong>session plans</strong> using the
		<code>tasks_*</code>, <code>memory_*</code> and <code>session_*</code> tools — a shared,
		durable plan/notes store that survives across sessions and agents.
	</p>
	<p class="text-sm opacity-70">
		MCP endpoint: <code data-testid="connect-mcp-url">@mcp</code> · auth header:
		<code>X-Api-Key</code> · project key: <code>@proj</code>
	</p>
</div>

@if (key is null)
{
	<form method="post" asp-page-handler="Mint" class="card bg-base-200 border border-base-300 max-w-3xl" data-testid="connect-mint-form">
		@Html.AntiForgeryToken()
		<div class="card-body p-4">
			<h3 class="card-title text-base">Mint an agent key</h3>
			<label class="form-control max-w-sm">
				<span class="label-text">Key name</span>
				<input type="text" name="name" required value="agent" class="input input-bordered input-sm font-mono" data-testid="connect-key-name" />
			</label>

			<div class="mt-3" data-testid="connect-scopes-group">
				<div class="text-sm font-semibold mb-1">Scopes</div>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-1">
					@foreach (var scope in Model.AllScopes)
					{
						var pre = PetBox.Web.Pages.Admin.ProjectConnectModel.AgentDefaultScopes.Contains(scope.Value);
						<label class="flex items-start gap-2 cursor-pointer" data-testid="connect-scope-@scope.Value">
							<input class="checkbox checkbox-sm" type="checkbox" name="scopes" value="@scope.Value" checked="@pre" />
							<span>
								<span class="font-mono text-xs">@scope.Value</span>
								<span class="block text-xs opacity-60">@scope.Title</span>
							</span>
						</label>
					}
				</div>
			</div>

			<div class="card-actions mt-3">
				<button type="submit" class="btn btn-sm btn-primary" data-testid="connect-mint-submit">Mint key &amp; show instructions</button>
			</div>
		</div>
	</form>
}
else
{
	<div class="alert alert-warning mb-4 max-w-3xl" data-testid="connect-key-shown">
		<div>
			<div class="font-semibold">Copy this key now — it is shown only once.</div>
			<code class="font-mono text-sm break-all" data-testid="connect-key-value">@key</code>
		</div>
	</div>

	<div class="card bg-base-200 border border-base-300 max-w-3xl mb-4" data-testid="connect-env-step">
		<div class="card-body p-4">
			<h3 class="card-title text-base">First: set an environment variable</h3>
			<p class="text-sm">
				The agent reads the key from an environment variable named <code>@envvar</code> — it is never
				stored in any config file. The name is <strong>per project</strong> (not a shared
				<code>PETBOX_API_KEY</code>) so several projects can coexist on one machine. Set it in the
				environment where the agent runs, then start the agent from that same shell/session:
			</p>
			<pre class="bg-base-300 rounded p-3 text-xs whitespace-pre-wrap"><code># macOS / Linux (current shell)
export @(envvar)="@key"

# Windows PowerShell (persisted for new shells)
setx @envvar "@key"</code></pre>
			<p class="text-xs opacity-70 mb-0">
				Don't commit it to a file. Pasting the prompt below also puts the key in the agent's chat
				history — if that matters, rotate the key when you're done.
			</p>
		</div>
	</div>

	<div class="max-w-3xl" data-testid="connect-instructions">
		<p class="text-sm mb-2">
			Paste the block below to your coding agent. It carries the connection secrets and points the
			agent at the public docs — the staged
			<a href="@onboarding" target="_blank" rel="noopener">onboarding runbook</a>, the
			<a href="@overview" target="_blank" rel="noopener">overview</a> and the
			<a href="@methodology" target="_blank" rel="noopener">methodology</a> — so nothing is duplicated.
		</p>
		<pre class="bg-base-200 border border-base-300 rounded p-3 text-xs whitespace-pre-wrap" data-testid="connect-agent-prompt"><code>Connect yourself to this project's PetBox server over MCP, then onboard end-to-end.

Connection details:
- MCP endpoint (HTTP/streamable): @mcp
- Auth: send header  X-Api-Key: @key
- Project key (pass as projectKey in every tool call): @proj
- MCP server name to register: petbox

Follow the staged onboarding runbook (public, no auth — fetch and follow it):
  @onboarding
It links the overview (@overview) and the methodology, and walks you through each
stage with a validation gate. Do the stages in order and do not skip a gate:

1. Set the env var @envvar in your process env from the key above (never commit it).
   Confirm it is non-empty.
2. Add a PROJECT-level MCP server named "petbox" (HTTP/streamable, the endpoint above,
   header  X-Api-Key: ${@envvar} ), then RESTART your MCP connection. Verify with
   tasks_board_list projectKey "@proj" — an empty list (not an auth error) means it works.
3. Read the overview + methodology, then report back, in your own words: the board kinds,
   how nodes are addressed (l1/l2/l3 + title), the spec-link invariant, and the approve
   gate (your ceiling is Review — never set Done). Wait for the maintainer to confirm.
4. Optionally install the petbox SKILL.md (see the connect guide: @doc).
5. Then plan your implementation ON this PetBox backend and track it IN PetBox: capture
   requirements on a spec board, technical tasks on a work board (linked via specRef),
   ideas on an ideas board. Drive work to Review; leave Done to the maintainer.</code></pre>
	</div>

	<div class="mt-4 flex flex-wrap items-center gap-2" data-testid="connect-doc-links">
		<span class="text-sm opacity-70">Docs for the agent:</span>
		<a href="@onboarding" target="_blank" rel="noopener" class="link link-primary text-sm">Onboarding</a>
		<span class="opacity-40">·</span>
		<a href="@overview" target="_blank" rel="noopener" class="link link-primary text-sm">Overview</a>
		<span class="opacity-40">·</span>
		<a href="@doc" target="_blank" rel="noopener" class="link link-primary text-sm">Connect guide</a>
		<span class="opacity-40">·</span>
		<a href="@methodology" target="_blank" rel="noopener" class="link link-primary text-sm">Methodology</a>
	</div>

	<div class="mt-4">
		<a href="@Routes.ProjectConnect(Model.WorkspaceKey, Model.ProjectKey)" class="btn btn-sm btn-ghost" data-testid="connect-mint-another">Mint another key</a>
	</div>
}
