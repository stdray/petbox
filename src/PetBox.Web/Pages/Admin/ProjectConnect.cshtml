@page "/ui/admin/ws/{workspaceKey}/projects/{projectKey}/connect"
@model PetBox.Web.Pages.Admin.ProjectConnectModel
@{
	// admin-routes-and-pages (item 9): this page only ISSUES an access key — the consumer may be an
	// agent or a plain REST client, so "Connect Agent" overclaimed what it does. Renamed to say what
	// actually happens; the route (/connect) is unchanged, only the title/copy moved.
	ViewData["Title"] = $"{Model.ProjectKey} — Issue access key";
	Layout = "_AdminLayout";
	var mcp = Model.McpUrl;
	var key = Model.NewKey;
	var proj = Model.ProjectKey;
	var doc = Model.DocAgentUrl;
	var onboarding = Model.DocOnboardingUrl;
	var overview = Model.DocOverviewUrl;
	var methodology = Model.DocMethodologyUrl;
	var envvar = Model.EnvVarName;
}

<div class="mb-4 flex items-baseline gap-3 flex-wrap">
	<h1 class="text-2xl font-semibold" data-testid="project-connect-title">@Model.ProjectKey · issue access key</h1>
</div>

@if (Model.ProjectNotFound)
{
	<p class="text-error font-semibold" data-testid="project-connect-error">Project not found</p>
	return;
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
	<div class="alert alert-error mb-3" data-testid="project-connect-error-msg">@Model.ErrorMessage</div>
}

<div class="prose prose-sm max-w-3xl mb-6">
	<p>
		This wires a coding agent to PetBox over <strong>MCP</strong> (Model Context Protocol).
		Once connected, the agent can read and write this project's <strong>task boards</strong>,
		<strong>memory stores</strong> and <strong>session plans</strong> using the
		<code>tasks_*</code>, <code>memory_*</code> and <code>session_*</code> tools — a shared,
		durable plan/notes store that survives across sessions and agents.
	</p>
	<p class="text-sm opacity-70">
		MCP endpoint: <code data-testid="connect-mcp-url">@mcp</code> · auth header:
		<code>X-Api-Key</code> · project key: <code>@proj</code>
	</p>
</div>

@if (key is null)
{
	<form method="post" asp-page-handler="Mint" class="card bg-base-200 border border-base-300 max-w-3xl" data-testid="connect-mint-form">
		@Html.AntiForgeryToken()
		<div class="card-body p-4">
			<h3 class="card-title text-base">Mint an access key</h3>
			<label class="form-control max-w-sm">
				<span class="label-text">Key name</span>
				<input type="text" name="name" required value="agent" class="input input-bordered input-sm font-mono" data-testid="connect-key-name" />
			</label>

			<div class="mt-3" data-testid="connect-scopes-group">
				<div class="text-sm font-semibold mb-1">Scopes</div>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-1">
					@foreach (var scope in Model.AllScopes)
					{
						var pre = PetBox.Web.Pages.Admin.ProjectConnectModel.AgentDefaultScopes.Contains(scope.Value);
						<label class="flex items-start gap-2 cursor-pointer" data-testid="connect-scope-@scope.Value">
							<input class="checkbox checkbox-sm" type="checkbox" name="scopes" value="@scope.Value" checked="@pre" />
							<span>
								<span class="font-mono text-xs">@scope.Value</span>
								<span class="block text-xs opacity-60">@scope.Title</span>
							</span>
						</label>
					}
				</div>
			</div>

			<div class="card-actions mt-3">
				<button type="submit" class="btn btn-sm btn-primary" data-testid="connect-mint-submit">Mint key &amp; show instructions</button>
			</div>
		</div>
	</form>
}
else
{
	<div class="alert alert-success mb-4 max-w-3xl" data-testid="connect-key-shown">
		<div>
			<div class="font-semibold">Copy this key now — it is shown only once.</div>
			<code class="font-mono text-sm break-all" data-testid="connect-key-value">@key</code>
		</div>
	</div>

	<div class="card bg-base-200 border border-base-300 max-w-3xl mb-4" data-testid="connect-wire-step">
		<div class="card-body p-4">
			<h3 class="card-title text-base">Wire the project (one command)</h3>
			<p class="text-sm mb-1">
				Run from the project folder you want to wire — <code>.</code> is that current directory.
				One command installs the hooks, plugins and MCP config and drops the key in place.
			</p>
			<div class="flex items-start gap-2">
				<pre class="bg-base-300 rounded p-3 text-xs whitespace-pre-wrap flex-1 mb-0"><code data-testid="connect-npx-command">@Model.WireCommand</code></pre>
				<button type="button" class="btn btn-xs" data-copy="@Model.WireCommand">Copy</button>
			</div>
			<p class="text-xs opacity-70 mb-2">single quotes keep <code>$</code>-keys literal in bash/PowerShell</p>

			<div class="text-sm font-semibold">What it installs</div>
			<ul class="text-xs opacity-80 list-disc list-inside space-y-0.5 mb-2">
				<li>global Stop / SessionStart hooks for Claude Code &amp; Factory Droid</li>
				<li>a global opencode plugin</li>
				<li>per-project MCP configs + the petbox skill</li>
				<li>a stable kit copy in <code>~/.petbox/wire/</code></li>
				<li>the key in <code>~/.petbox/keys.json</code> + the env var the MCP configs read</li>
			</ul>

			<div class="text-sm font-semibold">Verify</div>
			<ul class="text-xs opacity-80 list-disc list-inside space-y-0.5 mb-2">
				<li>watch for <code>[10/10] self-smoke: OK</code> in the output</li>
				<li>open a <strong>new</strong> terminal — the MCP configs read the env var, which is set for new shells</li>
				<li>run your agent in the folder — its first reply should open with <code>🧠 PetBox memory active</code></li>
			</ul>

			<p class="text-xs opacity-60 mb-0">
				Requires Node &gt;= 23.6. Non-standard setup? The MCP endpoint, auth header and project key
				are at the top of this page; the env-var name for this key is <code>@envvar</code>.
			</p>
		</div>
	</div>

	<div class="mt-4 flex flex-wrap items-center gap-2" data-testid="connect-doc-links">
		<span class="text-sm opacity-70">Docs for the agent:</span>
		<a href="@onboarding" target="_blank" rel="noopener" class="link link-primary text-sm">Onboarding</a>
		<span class="opacity-40">·</span>
		<a href="@overview" target="_blank" rel="noopener" class="link link-primary text-sm">Overview</a>
		<span class="opacity-40">·</span>
		<a href="@doc" target="_blank" rel="noopener" class="link link-primary text-sm">Connect guide</a>
		<span class="opacity-40">·</span>
		<a href="@methodology" target="_blank" rel="noopener" class="link link-primary text-sm">Methodology</a>
	</div>

	<div class="mt-4">
		<a href="@Routes.ProjectConnect(Model.WorkspaceKey, Model.ProjectKey)" class="btn btn-sm btn-ghost" data-testid="connect-mint-another">Mint another key</a>
	</div>
}
