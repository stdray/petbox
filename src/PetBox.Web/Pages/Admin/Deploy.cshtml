@page "/ui/admin/sys/deploy"
@using PetBox.Deploy.Data
@model PetBox.Web.Pages.Admin.DeployModel
@{
	ViewData["Title"] = "Deploy";
	Layout = "_AdminLayout";
}

<div class="mb-4">
	<h1 class="text-2xl font-semibold" data-testid="deploy-title">Deploy</h1>
	<p class="text-sm opacity-60">The fleet's nodes and the desired-state grid. Node-agents poll and reconcile to whatever you set here.</p>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
	<div class="alert alert-error mb-3 text-sm" data-testid="deploy-error">@Model.ErrorMessage</div>
}

<!-- ── Nodes ─────────────────────────────────────────────── -->
<div class="card bg-base-200 mb-4">
	<div class="card-body p-4">
		<h2 class="text-base font-semibold mb-2">Register node</h2>
		<form method="post" asp-page-handler="NewNode" class="flex flex-wrap items-end gap-2">
			<div>
				<label class="text-xs opacity-60 block" for="n-id">Id</label>
				<input id="n-id" name="id" class="input input-bordered input-sm font-mono" placeholder="vdsina-1" data-testid="node-id" />
			</div>
			<div>
				<label class="text-xs opacity-60 block" for="n-name">Display name</label>
				<input id="n-name" name="displayName" class="input input-bordered input-sm" placeholder="VDSina" />
			</div>
			<div>
				<label class="text-xs opacity-60 block" for="n-tags">Tags (csv)</label>
				<input id="n-tags" name="tags" class="input input-bordered input-sm font-mono" placeholder="net.x,disk=nvme" data-testid="node-tags" />
			</div>
			<label class="label cursor-pointer gap-2 p-0 pb-1">
				<input type="checkbox" name="ephemeral" value="true" class="checkbox checkbox-sm" />
				<span class="text-xs">Ephemeral</span>
			</label>
			<button type="submit" class="btn btn-primary btn-sm" data-testid="node-add">Register</button>
		</form>
	</div>
</div>

<div class="flex items-center gap-3 mb-2">
	<h2 class="text-lg font-semibold">Nodes</h2>
	<span class="badge badge-ghost">@Model.Nodes.Count</span>
</div>
@if (Model.Nodes.Count == 0)
{
	<div class="text-xs opacity-60 italic mb-4" data-testid="deploy-nodes-empty">No nodes.</div>
}
else
{
	<div class="overflow-x-auto mb-6">
		<table class="table table-sm" data-testid="deploy-nodes-table">
			<thead><tr><th>Id</th><th>Name</th><th>Tags</th><th>Status</th><th>Host</th><th>Last seen</th><th>Deploys</th><th></th></tr></thead>
			<tbody>
				@foreach (var n in Model.Nodes)
				{
					<tr data-testid="deploy-node-row">
						<td class="font-mono text-xs">@n.Id @(n.Ephemeral ? Html.Raw("<span class=\"badge badge-ghost badge-xs\">ephemeral</span>") : null)</td>
						<td>@n.DisplayName</td>
						<td class="font-mono text-xs">@n.Tags @(n.Capabilities.Length > 0 ? Html.Raw($"<span class=\"badge badge-ghost badge-xs\" title=\"agent-detected capabilities\">{n.Capabilities}</span>") : null)</td>
						<td>
							@if (n.Online)
							{
								<span class="badge badge-success badge-sm" data-testid="node-online">online</span>
							}
							else
							{
								<span class="badge badge-ghost badge-sm" data-testid="node-offline">offline</span>
							}
							@foreach (var w in n.Warnings ?? Array.Empty<string>())
							{
								<div class="text-error text-xs mt-1" data-testid="node-warning">⚠ @w</div>
							}
						</td>
						<td class="text-xs font-mono opacity-70" data-testid="node-host">
							@if (n.Host?.Memory is { TotalMb: not null, AvailableMb: not null } m) { <div>mem @m.AvailableMb/@m.TotalMb MB</div> }
							@if (n.Host?.Disk is { TotalGb: not null, FreeGb: not null } dsk) { <div>disk @dsk.FreeGb/@dsk.TotalGb GB</div> }
							@if (n.Host?.Os is { } os) { <div title="@os">@(os.Length > 22 ? os[..22] + "…" : os)</div> }
						</td>
						<td class="text-xs font-mono opacity-70">@(n.LastSeenAt?.ToString("MM-dd HH:mm:ss") ?? "—")</td>
						<td>@n.Deployments</td>
						<td>
							<form method="post" asp-page-handler="DeleteNode" onsubmit="return confirm('Delete node and its deployments?');">
								<input type="hidden" name="id" value="@n.Id" />
								<button type="submit" class="btn btn-ghost btn-xs text-error" data-testid="node-delete">Delete</button>
							</form>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
}

<!-- ── Deployments ───────────────────────────────────────── -->
<div class="card bg-base-200 mb-4">
	<div class="card-body p-4">
		<h2 class="text-base font-semibold mb-3">New deployment</h2>
		<form method="post" asp-page-handler="NewDeployment" class="space-y-4">

			@* ── Identity: what to run, where, and how it's scheduled ── *@
			<fieldset class="space-y-2" data-testid="dep-section-identity">
				<legend class="text-xs opacity-50 uppercase tracking-wide">Identity</legend>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
					<label class="form-control w-full" for="d-service">
						<span class="label-text text-xs opacity-60">Service</span>
						<input id="d-service" name="service" class="input input-bordered input-sm font-mono w-full" placeholder="bot" data-testid="dep-service" />
					</label>
					<label class="form-control w-full" for="d-project">
						<span class="label-text text-xs opacity-60">Project</span>
						<input id="d-project" name="project" class="input input-bordered input-sm font-mono w-full" placeholder="yobapub" data-testid="dep-project" />
					</label>
					<label class="form-control w-full" for="d-node">
						<span class="label-text text-xs opacity-60">Node</span>
						<select id="d-node" name="nodeId" class="select select-bordered select-sm font-mono w-full" data-testid="dep-node">
							@foreach (var n in Model.Nodes)
							{
								<option value="@n.Id">@n.Id</option>
							}
						</select>
					</label>
					<label class="form-control w-full sm:col-span-2 lg:col-span-1" for="d-image">
						<span class="label-text text-xs opacity-60">Image</span>
						<input id="d-image" name="imageDigest" class="input input-bordered input-sm font-mono w-full" placeholder="ghcr.io/...:tag" data-testid="dep-image" />
					</label>
					<label class="form-control w-full" for="d-req">
						<span class="label-text text-xs opacity-60">Required tags</span>
						<input id="d-req" name="requiredTags" class="input input-bordered input-sm font-mono w-full" placeholder="net.x" />
					</label>
					<label class="form-control w-full" for="d-cfg">
						<span class="label-text text-xs opacity-60">Config tags</span>
						<input id="d-cfg" name="configTags" class="input input-bordered input-sm font-mono w-full" placeholder="env:prod" />
					</label>
				</div>
				<label class="label cursor-pointer justify-start gap-2 pl-0" title="May be auto-relocated to another matching node when this node goes stale.">
					<input type="checkbox" name="relocatable" value="true" class="checkbox checkbox-sm" />
					<span class="label-text text-xs">Relocatable</span>
				</label>
			</fieldset>

			@* ── Networking: published ports, docker network, optional site domain ── *@
			<fieldset class="space-y-2" data-testid="dep-section-networking">
				<legend class="text-xs opacity-50 uppercase tracking-wide">Networking</legend>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
					<label class="form-control w-full" for="d-ports">
						<span class="label-text text-xs opacity-60">Ports (csv)</span>
						<input id="d-ports" name="ports" class="input input-bordered input-sm font-mono w-full" placeholder="127.0.0.1:8080:8080" data-testid="dep-ports" />
					</label>
					<label class="form-control w-full" for="d-network">
						<span class="label-text text-xs opacity-60">Network</span>
						<input id="d-network" name="network" class="input input-bordered input-sm font-mono w-full" placeholder="bridge" />
					</label>
					<label class="form-control w-full" for="d-domain" title="Makes this deployment a SITE: the node agent routes the domain to the loopback port (first ports entry) via the host reverse-proxy.">
						<span class="label-text text-xs opacity-60">Site domain</span>
						<input id="d-domain" name="domain" class="input input-bordered input-sm font-mono w-full" placeholder="app.example.com" data-testid="dep-domain" />
					</label>
				</div>
			</fieldset>

			@* ── Resources: container limits ── *@
			<fieldset class="space-y-2" data-testid="dep-section-resources">
				<legend class="text-xs opacity-50 uppercase tracking-wide">Resources</legend>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
					<label class="form-control w-full" for="d-memory">
						<span class="label-text text-xs opacity-60">Memory</span>
						<input id="d-memory" name="memory" class="input input-bordered input-sm font-mono w-full" placeholder="256m" data-testid="dep-memory" />
					</label>
					<label class="form-control w-full" for="d-cpus">
						<span class="label-text text-xs opacity-60">Cpus</span>
						<input id="d-cpus" name="cpus" class="input input-bordered input-sm font-mono w-full" placeholder="0.5" />
					</label>
				</div>
			</fieldset>

			@* ── Runtime: mounts and restart policy ── *@
			<fieldset class="space-y-2" data-testid="dep-section-runtime">
				<legend class="text-xs opacity-50 uppercase tracking-wide">Runtime</legend>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
					<label class="form-control w-full sm:col-span-2" for="d-volumes">
						<span class="label-text text-xs opacity-60">Volumes (csv)</span>
						<input id="d-volumes" name="volumes" class="input input-bordered input-sm font-mono w-full" placeholder="/opt/app/logs:/app/logs" data-testid="dep-volumes" />
					</label>
					<label class="form-control w-full" for="d-restart">
						<span class="label-text text-xs opacity-60">Restart</span>
						<select id="d-restart" name="restart" class="select select-bordered select-sm font-mono w-full" data-testid="dep-restart">
							<option value="">(default)</option>
							<option value="unless-stopped">unless-stopped</option>
							<option value="always">always</option>
							<option value="on-failure">on-failure</option>
							<option value="no">no</option>
						</select>
					</label>
				</div>
			</fieldset>

			<div class="flex items-center gap-2 pt-1">
				<button type="submit" class="btn btn-primary btn-sm" data-testid="dep-add">Create</button>
				<p class="text-xs opacity-50">Healthcheck, command override and labels are settable via MCP <code>deploy_upsert</code>.</p>
			</div>
		</form>
	</div>
</div>

<div class="flex items-center gap-3 mb-2">
	<h2 class="text-lg font-semibold">Deployments</h2>
	<span class="badge badge-ghost">@Model.Deployments.Count</span>
</div>
@if (Model.Deployments.Count == 0)
{
	<div class="text-xs opacity-60 italic" data-testid="deploy-deployments-empty">No deployments.</div>
}
else
{
	<div class="overflow-x-auto">
		<table class="table table-sm" data-testid="deploy-deployments-table">
			<thead><tr><th>Service</th><th>Project</th><th>Node</th><th>Image</th><th>Run spec</th><th>Desired</th><th>Actual</th><th>Reloc</th><th class="w-72">Actions</th></tr></thead>
			<tbody>
				@foreach (var d in Model.Deployments)
				{
					<tr data-testid="deploy-deployment-row">
						<td class="font-mono text-xs font-semibold">@d.Service</td>
						<td class="font-mono text-xs">@d.Project</td>
						<td class="font-mono text-xs">@d.NodeId</td>
						<td class="font-mono text-xs break-all">@d.ImageDigest</td>
						<td class="text-xs font-mono" data-testid="dep-runspec">
							@if (d.RunSpec.Site is not null) { <div class="font-semibold" data-testid="dep-site">site&nbsp;@d.RunSpec.Site.Domain&nbsp;→&nbsp;:@d.RunSpec.Site.Port</div> }
							@foreach (var p in d.RunSpec.Ports ?? Array.Empty<string>()) { <div>p&nbsp;@p</div> }
							@foreach (var v in d.RunSpec.Volumes ?? Array.Empty<string>()) { <div>v&nbsp;@v</div> }
							@if (d.RunSpec.Restart is not null) { <div>restart&nbsp;@d.RunSpec.Restart</div> }
							@if (d.RunSpec.Healthcheck is not null) { <div title="@d.RunSpec.Healthcheck.Cmd">health&nbsp;✓</div> }
							@if (d.RunSpec.Resources?.Memory is not null) { <div>mem&nbsp;@d.RunSpec.Resources.Memory</div> }
							@if (d.RunSpec.Resources?.Cpus is not null) { <div>cpus&nbsp;@d.RunSpec.Resources.Cpus</div> }
							@if (d.RunSpec.Network is not null) { <div>net&nbsp;@d.RunSpec.Network</div> }
							@if (d.RunSpec.Command is not null) { <div title="@string.Join(" ", d.RunSpec.Command)">cmd&nbsp;✓</div> }
							@if (d.RunSpec.Labels is not null) { <div>labels&nbsp;@d.RunSpec.Labels.Count</div> }
						</td>
						<td>
							@if (d.DesiredState == DesiredState.Running)
							{
								<span class="badge badge-success badge-sm">running</span>
							}
							else
							{
								<span class="badge badge-ghost badge-sm">stopped</span>
							}
						</td>
						<td class="text-xs">
							@if (d.ActualState is null)
							{
								<span class="opacity-50">—</span>
							}
							else
							{
								<span class="badge badge-sm @(d.ActualState == ActualState.Running && d.Healthy == true ? "badge-success" : "badge-warning")" data-testid="dep-actual">@d.ActualState</span>
							}
							@if (!string.IsNullOrEmpty(d.Error))
							{
								<div class="text-error text-xs mt-1" data-testid="dep-error">@d.Error</div>
							}
						</td>
						<td>@(d.Relocatable ? "yes" : "")</td>
						<td>
							<div class="flex flex-wrap items-center gap-1">
								@if (d.DesiredState == DesiredState.Running)
								{
									<form method="post" asp-page-handler="SetState">
										<input type="hidden" name="id" value="@d.Id" />
										<input type="hidden" name="desired" value="@((int)DesiredState.Stopped)" />
										<button type="submit" class="btn btn-ghost btn-xs" data-testid="dep-stop">Stop</button>
									</form>
								}
								else
								{
									<form method="post" asp-page-handler="SetState">
										<input type="hidden" name="id" value="@d.Id" />
										<input type="hidden" name="desired" value="@((int)DesiredState.Running)" />
										<button type="submit" class="btn btn-ghost btn-xs text-success" data-testid="dep-start">Start</button>
									</form>
								}
								<form method="post" asp-page-handler="Move" class="flex items-center gap-1">
									<input type="hidden" name="id" value="@d.Id" />
									<select name="toNodeId" class="select select-bordered select-xs font-mono">
										@foreach (var n in Model.Nodes.Where(n => n.Id != d.NodeId))
										{
											<option value="@n.Id">@n.Id</option>
										}
									</select>
									<button type="submit" class="btn btn-ghost btn-xs" data-testid="dep-move">Move</button>
								</form>
								<form method="post" asp-page-handler="DeleteDeployment" onsubmit="return confirm('Delete deployment?');">
									<input type="hidden" name="id" value="@d.Id" />
									<button type="submit" class="btn btn-ghost btn-xs text-error" data-testid="dep-delete">Delete</button>
								</form>
							</div>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
}
