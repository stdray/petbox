@page "/ui/admin/sys/users"
@model PetBox.Web.Pages.Admin.UsersModel
@{
	ViewData["Title"] = "Users";
	Layout = "_AdminLayout";
}

<div class="mb-4">
	<h1 class="text-2xl font-semibold" data-testid="sys-users-title">Users</h1>
	<p class="text-sm opacity-60">All accounts that can sign in. Membership is granted per workspace from <code class="font-mono">/ui/admin/ws/{ws}/members</code>.</p>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
	<div class="alert alert-error mb-3 text-sm" data-testid="sys-users-error">@Model.ErrorMessage</div>
}

<div class="card bg-base-200 mb-4">
	<div class="card-body p-4">
		<h2 class="text-base font-semibold mb-2">Create user</h2>
		<form method="post" asp-page-handler="Create" class="flex flex-wrap items-end gap-2" autocomplete="off">
			<div>
				<label class="text-xs opacity-60 block" for="new-username">Username</label>
				<input id="new-username" name="username" class="input input-bordered input-sm font-mono" data-testid="sys-user-create-username" autocomplete="off" required />
			</div>
			<div>
				<label class="text-xs opacity-60 block" for="new-password">Password</label>
				<input id="new-password" name="password" type="password" class="input input-bordered input-sm" data-testid="sys-user-create-password" autocomplete="new-password" required />
			</div>
			@* No default value on purpose: the allowance is a decision, so the field is empty and
			   required. An empty submit is rejected — it never becomes a silent 0. Native `required`
			   validation blocks the POST with no visible feedback in some environments (no toast, no
			   inline error, counter unchanged), so the "Required" hint below is a permanent, always-on
			   signal rather than relying solely on the browser's own validation UI. *@
			<div>
				<label class="text-xs opacity-60 block" for="new-quota">Workspace allowance <span class="text-error">*</span></label>
				<input id="new-quota" name="workspaceQuota" type="number" min="0" step="1" placeholder="e.g. 0 or 1"
					class="input input-bordered input-sm w-40" data-testid="sys-user-create-quota" required
					aria-describedby="new-quota-hint" />
				<span id="new-quota-hint" class="text-xs text-error block mt-1" data-testid="sys-user-create-quota-hint">Required — pick a number (0 = no workspaces).</span>
			</div>
			<button type="submit" class="btn btn-primary btn-sm" data-testid="sys-user-create-submit">Create</button>
		</form>
		<p class="text-xs opacity-50 mt-2">
			Workspace allowance = how many workspaces this account may create for itself (0 = none). The creator becomes
			the administrator of each workspace they create. Workspace membership is granted separately from
			<code class="font-mono">/ui/admin/ws/{ws}/members</code>.
		</p>
	</div>
</div>

<div class="flex items-center gap-3 mb-3">
	<h2 class="text-lg font-semibold">All users</h2>
	<span class="badge badge-ghost">@Model.Users.Count</span>
</div>

@if (Model.Users.Count == 0)
{
	<div class="text-xs opacity-60 italic" data-testid="sys-users-empty">No users.</div>
}
else
{
	<div class="overflow-x-auto">
		<table class="table table-sm" data-testid="sys-users-table">
			<thead>
				<tr>
					<th>Username</th>
					<th>Memberships</th>
					<th class="w-48">Workspace allowance</th>
					<th class="w-32">Created</th>
					<th class="w-64">Actions</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var u in Model.Users)
				{
					<tr data-testid="sys-user-row" data-user-id="@u.Id">
						<td class="font-mono text-sm">@u.Username</td>
						<td>
							@if (u.Memberships.Count == 0)
							{
								<span class="text-xs opacity-50">— none —</span>
							}
							else
							{
								<div class="flex flex-wrap gap-1">
									@foreach (var m in u.Memberships)
									{
										<a href="@Routes.SysWorkspace(m.WorkspaceKey)"
											class="badge badge-outline badge-sm font-mono"
											title="@m.Role in @m.WorkspaceKey">@m.WorkspaceKey<span class="opacity-50 ml-1">@m.Role</span></a>
									}
								</div>
							}
						</td>
						@* Lowering the allowance never revokes a workspace already created (that would leave it
						   without an administrator) — it only governs the next create. *@
						<td>
							<form method="post" asp-page-handler="SetQuota" class="flex items-center gap-1">
								<input type="hidden" name="userId" value="@u.Id" />
								<input name="workspaceQuota" type="number" min="0" step="1" value="@u.WorkspaceQuota"
									class="input input-bordered input-xs w-16" data-testid="sys-user-quota-input" />
								<button type="submit" class="btn btn-ghost btn-xs" data-testid="sys-user-quota-submit">Set</button>
								<span class="text-xs opacity-50" data-testid="sys-user-quota-used" title="workspaces this account already owns">@u.WorkspacesOwned used</span>
							</form>
						</td>
						<td class="text-xs opacity-70 font-mono">@u.CreatedAt.ToString("yyyy-MM-dd")</td>
						<td>
							<div class="flex items-center gap-2">
								<form method="post" asp-page-handler="ResetPassword" class="flex items-center gap-1" autocomplete="off">
									<input type="hidden" name="userId" value="@u.Id" />
									<input name="newPassword" type="password" placeholder="new password" class="input input-bordered input-xs" data-testid="sys-user-reset-password" autocomplete="new-password" required />
									<button type="submit" class="btn btn-ghost btn-xs" data-testid="sys-user-reset-submit">Reset</button>
								</form>
								@if (!u.IsBootstrapAdmin)
								{
									<form method="post" asp-page-handler="Delete" onsubmit="return confirm('Delete user @u.Username? This removes the account and all its workspace memberships. This cannot be undone.');">
										<input type="hidden" name="userId" value="@u.Id" />
										<button type="submit" class="btn btn-ghost btn-xs text-error" data-testid="sys-user-delete">Delete</button>
									</form>
								}
								else
								{
									<span class="badge badge-ghost badge-xs" title="bootstrap admin">bootstrap</span>
								}
							</div>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
}
