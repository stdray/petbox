@page "/ui/admin/ws/{workspaceKey}/projects/{projectKey}/info"
@model PetBox.Web.Pages.Admin.ProjectDetailModel
@{
	ViewData["Title"] = $"Project: {Model.Project?.Name ?? Model.Key}";
	Layout = "_AdminLayout";
}

@if (Model.Project is null)
{
	<div class="alert alert-error" data-testid="project-detail-error">Project not found.</div>
	return;
}

<div class="mb-4 flex items-baseline gap-3 flex-wrap">
	<h1 class="text-2xl font-semibold" data-testid="project-detail-title">@Model.Project.Name</h1>
	<span class="font-mono text-sm opacity-60">@Model.Project.Key</span>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
	<div class="alert alert-error mb-3" data-testid="project-detail-error-msg">@Model.ErrorMessage</div>
}

@* API-key management and Log retention moved off this (overloaded) Info page — admin-routes-and-pages
   item 3. Keys have their own page; retention lives on the generic project Settings page
   (SettingsScopePolicy already renders LogSettings there). This card is the only trace left here. *@
<div class="mb-6">
	<a href="@Routes.ProjectKeys(Model.WorkspaceKey, Model.ProjectKey)" class="card bg-base-200 border border-base-300 hover:border-primary transition-colors max-w-sm" data-testid="project-detail-manage-keys">
		<div class="card-body p-3">
			<div class="text-xs opacity-60 uppercase tracking-wide">API keys</div>
			<div class="text-sm">@Model.KeyCount issued · Manage &rarr;</div>
		</div>
	</a>
</div>

<section class="mb-6" data-testid="project-health-section">
	<div class="flex items-center gap-3 mb-3">
		<h2 class="text-lg font-semibold">Health endpoints</h2>
		<span class="badge badge-ghost">@Model.HealthEndpoints.Count</span>
	</div>
	<p class="text-xs opacity-60 mb-3">
		Pull sources: petbox periodically GETs each URL and expects a status structure
		(<code>{ svc, tags, version, status }</code>). Services can also <strong>push</strong> to
		<code>POST /api/health</code> with a <code>health:write</code> key — no row needed here.
	</p>

	<div class="overflow-x-auto mb-3">
		<table class="table table-sm" data-testid="project-health-table">
			<thead>
				<tr>
					<th>URL</th>
					<th class="w-24">Interval</th>
					<th class="w-24"></th>
				</tr>
			</thead>
			<tbody>
				@if (Model.HealthEndpoints.Count == 0)
				{
					<tr data-testid="project-health-empty"><td colspan="3" class="text-xs opacity-60 italic text-center">No pull endpoints. Add one below or push to /api/health.</td></tr>
				}
				else
				{
					@foreach (var e in Model.HealthEndpoints)
					{
						<tr data-testid="health-endpoint-row" data-endpoint-id="@e.Id">
							<td class="font-mono text-xs max-w-md truncate">@e.Url</td>
							<td class="text-xs opacity-70">@e.IntervalSeconds s</td>
							<td>
								<form method="post" asp-page-handler="DeleteHealthEndpoint" asp-route-id="@e.Id"
									onsubmit="return confirm('Delete health endpoint?')" style="display:inline">
									@Html.AntiForgeryToken()
									<button type="submit" class="btn btn-xs btn-ghost text-error" data-testid="project-health-delete">Delete</button>
								</form>
							</td>
						</tr>
					}
				}
			</tbody>
		</table>
	</div>

	<form method="post" asp-page-handler="CreateHealthEndpoint" class="card bg-base-200 border border-base-300 max-w-3xl" data-testid="project-health-create-form">
		@Html.AntiForgeryToken()
		<div class="card-body p-4">
			<h3 class="card-title text-sm">New pull endpoint</h3>
			<div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
				<label class="form-control sm:col-span-2">
					<span class="label-text">URL</span>
					<input type="url" name="url" required
						class="input input-bordered input-sm font-mono"
						placeholder="https://my-service/health"
						data-testid="project-health-create-url" />
				</label>
				<label class="form-control">
					<span class="label-text">Interval (s)</span>
					<input type="number" name="intervalSeconds" min="5" value="60"
						class="input input-bordered input-sm"
						data-testid="project-health-create-interval" />
				</label>
			</div>
			<div class="card-actions mt-3">
				<button type="submit" class="btn btn-sm btn-primary" data-testid="project-health-create-submit">Add endpoint</button>
			</div>
		</div>
	</form>
</section>

<div class="divider"></div>

<section class="mb-6 max-w-3xl" data-testid="project-commit-links-section">
	<div class="flex items-center gap-3 mb-3">
		<h2 class="text-lg font-semibold">Commit links</h2>
		@if (!string.IsNullOrEmpty(Model.CommitUrlTemplate))
		{
			<span class="badge badge-info badge-sm" data-testid="project-commit-template-set-badge">set</span>
		}
		else
		{
			<span class="badge badge-ghost badge-sm" data-testid="project-commit-template-unset-badge">not set</span>
		}
	</div>
	<p class="text-xs opacity-60 mb-3">
		Commit-view URL template with a literal <code>{sha}</code> placeholder, e.g.
		<code>https://github.com/user/repo/commit/{sha}</code>. When set, commit refs on task
		cards and commit hashes in node/comment bodies become links. Leave empty to keep plain text.
	</p>

	<form method="post" asp-page-handler="SetCommitTemplate" class="card bg-base-200 border border-base-300" data-testid="project-commit-template-form">
		@Html.AntiForgeryToken()
		<div class="card-body p-4">
			<label class="form-control">
				<span class="label-text">Commit URL template</span>
				<input type="text" name="commitUrlTemplate" maxlength="500"
					value="@Model.CommitUrlTemplate"
					class="input input-bordered input-sm font-mono"
					placeholder="https://github.com/user/repo/commit/{sha}"
					data-testid="project-commit-template-input" />
			</label>
			<div class="card-actions mt-3 flex-wrap">
				<button type="submit" class="btn btn-sm btn-primary" data-testid="project-commit-template-save">Save</button>
				@if (!string.IsNullOrEmpty(Model.CommitUrlTemplate))
				{
					<button type="submit" formaction="?handler=ClearCommitTemplate" class="btn btn-sm btn-ghost" data-testid="project-commit-template-clear">Clear</button>
				}
			</div>
		</div>
	</form>
</section>

@if (Model.SearchReindexEnabled)
{
	<div class="divider"></div>

	<section class="mb-6 max-w-3xl" data-testid="project-search-index-section">
		<h2 class="text-lg font-semibold mb-3">Search index</h2>
		<p class="text-xs opacity-60 mb-3">
			Rebuilds both halves of the search index from the live data: the semantic (vector) index
			re-embeds on the stock background drain, and the lexical (full-text) index rebuilds on the
			very next search of each store/board. Use it after a search-projection change, or when
			search looks stale or wrong and you don't want to wait for it to self-heal.
		</p>
		<div class="card bg-base-200 border border-base-300">
			<div class="card-body p-4">
				<form method="post" asp-page-handler="Reindex"
					onsubmit="return confirm('Rebuild the search index for @Model.Project.Key? This re-embeds and re-indexes the whole project.')">
					@Html.AntiForgeryToken()
					<button type="submit" class="btn btn-sm btn-warning" data-testid="project-search-reindex">Rebuild search index</button>
				</form>
			</div>
		</div>
	</section>
}

@if (!PetBox.Core.Data.ProjectDeletion.IsReserved(Model.Project.Key))
{
	<div class="divider"></div>

	<section class="mb-6 max-w-3xl" data-testid="project-danger-section">
		<h2 class="text-lg font-semibold text-error mb-3">Danger zone</h2>
		<div class="card bg-base-200 border border-error/40" data-testid="project-delete-card">
			<div class="card-body p-4">
				<h3 class="card-title text-sm">Delete this project</h3>
				<p class="text-xs opacity-70">
					Permanently deletes <code class="font-mono">@Model.Project.Key</code> and everything it owns:
					API keys, health endpoints, databases, saved queries, share links, logs, task boards,
					memory stores, relations and settings. This cannot be undone.
				</p>
				<div class="card-actions mt-3">
					<form method="post" asp-page-handler="Delete"
						onsubmit="return confirm('Delete project @Model.Project.Key and ALL its API keys, databases, logs, task boards, memory stores and settings? This cannot be undone.')">
						@Html.AntiForgeryToken()
						<button type="submit" class="btn btn-sm btn-error" data-testid="project-delete">Delete project</button>
					</form>
				</div>
			</div>
		</div>
	</section>
}
