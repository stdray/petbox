@page
@model ErrorModel
@{
	ViewData["Title"] = Model.IsNotFound ? "Not found — PetBox" : "Error — PetBox";
	ViewData["BodyClass"] = "min-h-full flex items-center justify-center bg-base-300 p-6";
	Layout = "_PublicLayout";
}

<div class="card w-96 max-w-full bg-base-200 p-6 shadow-xl text-center" data-testid="error-card">
	@if (Model.IsNotFound)
	{
		<p class="text-5xl font-bold text-primary mb-2" data-testid="error-status">404</p>
		<h1 class="text-xl font-semibold mb-2" data-testid="error-title">Page not found</h1>
		<p class="opacity-70 mb-4" data-testid="error-message">
			We couldn't find that page. It may have been moved, or the address is not valid.
		</p>
	}
	else
	{
		@if (Model.ErrorCode is int code)
		{
			<p class="text-5xl font-bold text-error mb-2" data-testid="error-status">@code</p>
		}
		<h1 class="text-xl font-semibold text-error mb-2" data-testid="error-title">Something went wrong</h1>
		<p class="opacity-70 mb-4" data-testid="error-message">
			An error occurred while processing your request.
		</p>
	}

	<a href="@Routes.Home()" class="btn btn-primary" data-testid="error-home">Back to home</a>

	@if (Model.ShowRequestId)
	{
		<p class="mt-4 text-xs opacity-60">
			Request ID: <code data-testid="error-request-id">@Model.RequestId</code>
		</p>
	}
</div>
