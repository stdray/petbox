@model PetBox.Web.Pages.ProjectHome.TaskBoardModel
@* Outline view mode (board-view-mode-framework): a heading-hierarchy table of contents over the
   SAME DFS-ordered nodes the tree pane uses (part_of depth, via n.Depth) — just headings, not
   full cards. ONE partial serves every board kind.
   board-view-fields: Model.Fields.Body is what actually decides whether a row gets the lazy-expand
   affordance — Model.OutlineRevealMode only seeds Fields' DEFAULT (BoardFieldConfig.Default), so a
   board whose kind defaults outline bodies off (everything but spec today) can still opt them in
   via the dialog, same as every other field. The fetch itself (OnGetNodeBodyAsync) doesn't care
   which kind asked — expanding always works once Body is on:
     - <details>'s native `toggle` event fires an htmx GET at OnGetNodeBodyAsync, which fetches and
       renders JUST that node's body on demand — no body ships in this page's initial HTML
       (board-body-truncate: inline body only on explicit reveal).
     - Body off: no expand affordance — the heading link goes straight to the node page.
   board-node-filter / board-sort: the shared _BoardFilterSort bar plus the same ts/board.ts
   data-* contract _PlanNodeCard carries — the outline row list is DFS-flat exactly like the tree
   pane (indentation via margin-left, no actual DOM nesting), so it's ONE reorder scope. *@
@if (Model.Nodes.Count == 0)
{
	<div class="alert" data-testid="board-empty">This board has no active plan nodes.</div>
}
else
{
	var filterSortModel = new PetBox.Web.Pages.Shared.BoardFilterSortModel(Fields: Model.Fields, ViewMode: BoardViewModeNames.Outline, SortHint: "sort branches:");
	<partial name="_BoardFilterSort" model="filterSortModel" />
	<ul class="flex flex-col gap-1" data-testid="board-outline" data-reveal-mode="@Model.OutlineRevealMode" data-sort-scope>
		@foreach (var n in Model.Nodes)
		{
			var nodeUrl = Routes.TaskBoardNodeBySlug(Model.WorkspaceKey, Model.ProjectKey, Model.Board, n.Key);
			var hasBody = !string.IsNullOrEmpty(n.Body);
			var closed = Model.Runtime.IsTerminalStatus(Model.KindSlug, n.Status);
			// board-terminal-negative-visible: independent of Model.Fields.Status — the title
			// strikethrough is an invariant over the data, not a dialog checkbox.
			var terminalCancel = Model.Runtime.StatusKindOf(Model.KindSlug, n.Status) == StatusKind.TerminalCancel;
			var keepVisible = !closed || Model.ClosedWithActiveDescendant.Contains(n.NodeId);
			// board-body-truncate: unlike the tree card, outline never ships the body inline (it's
			// fetched lazily on expand, or never at all with Body off) — data-search must NOT leak
			// it into the initial HTML, so this omits n.Body where _PlanNodeCard includes it.
			var search = $"{n.Title} {n.Key} {string.Join(' ', n.Tags)}".ToLowerInvariant();
			// Tree edges (outline-tree-edges, live UI review finding): a left border per
			// indented row is the same nesting-guide convention _CommentThread already uses for
			// reply depth — without it, depth reads only from indentation, which is easy to
			// misjudge once a few sibling groups stack up.
			var edgeClass = n.Depth > 0 ? "border-l-2 border-base-300/60 pl-2" : "";
			var titleClass = "font-semibold link link-hover" + (terminalCancel ? " line-through opacity-60" : "");
			<li data-testid="outline-row" data-node-key="@n.Key" data-node-id="@n.NodeId" data-parent-id="@(n.ParentNodeId ?? "")" data-depth="@n.Depth" data-status="@n.Status" data-type="@n.Type" data-priority="@n.Priority" data-title="@n.Title" data-search="@search" data-created="@(n.CreatedAt?.ToString("o") ?? "")" data-updated="@(n.UpdatedAt?.ToString("o") ?? "")" data-closed="@closed.ToString().ToLowerInvariant()" data-keep-visible="@keepVisible.ToString().ToLowerInvariant()" data-terminal-cancel="@terminalCancel.ToString().ToLowerInvariant()" class="@edgeClass" style="margin-left:@(n.Depth * 1.5)rem">
				@if (Model.Fields.Body && hasBody)
				{
					var bodyUrl = $"?handler=NodeBody&nodeId={Uri.EscapeDataString(n.NodeId)}";
					<details data-testid="outline-node-lazy" hx-get="@bodyUrl" hx-trigger="toggle once" hx-target="find [data-outline-body]" hx-swap="innerHTML">
						<summary class="cursor-pointer flex items-baseline gap-2 flex-wrap">
							<a href="@nodeUrl" class="@titleClass" data-testid="node-name">@n.Title</a>
							<span class="font-mono text-xs opacity-50">@n.Key</span>
							<partial name="_OutlineFieldChips" model="new PetBox.Web.Pages.ProjectHome.OutlineFieldChipsModel(Model.Runtime, Model.KindSlug, Model.Fields, n, Model.WorkspaceKey, Model.ProjectKey)" />
						</summary>
						<div class="mt-1 ml-2" data-outline-body data-testid="outline-body">
							<span class="opacity-50 text-xs italic" data-testid="outline-body-loading">loading…</span>
						</div>
					</details>
				}
				else
				{
					<div class="flex items-baseline gap-2 flex-wrap">
						<a href="@nodeUrl" class="@titleClass" data-testid="node-name">@n.Title</a>
						<span class="font-mono text-xs opacity-50">@n.Key</span>
						<partial name="_OutlineFieldChips" model="new PetBox.Web.Pages.ProjectHome.OutlineFieldChipsModel(Model.Runtime, Model.KindSlug, Model.Fields, n, Model.WorkspaceKey, Model.ProjectKey)" />
					</div>
				}
			</li>
		}
	</ul>
}
