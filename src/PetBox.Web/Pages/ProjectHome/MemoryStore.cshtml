@page "/ui/{workspaceKey}/{projectKey}/memory/{store}"
@model PetBox.Web.Pages.ProjectHome.MemoryStoreModel
@{
	ViewData["Title"] = $"{Model.Store} — Memory";

	string PageHref(int pageNum)
	{
		var href = $"{Routes.ProjectMemoryStore(Model.WorkspaceKey, Model.ProjectKey, Model.Store)}?pageNum={pageNum}";
		if (!string.IsNullOrWhiteSpace(Model.Query)) href += $"&q={Uri.EscapeDataString(Model.Query)}";
		return href;
	}
}

<div class="mb-4 flex items-baseline gap-3 flex-wrap">
	<a href="@Routes.ProjectMemory(Model.WorkspaceKey, Model.ProjectKey)" class="link link-hover opacity-70" data-testid="store-breadcrumb">memory</a>
	<span class="opacity-40">/</span>
	<h1 class="text-2xl font-semibold font-mono" data-testid="store-title">@Model.Store</h1>
	<span class="badge badge-ghost" data-testid="store-total">@Model.Total entr@(Model.Total == 1 ? "y" : "ies")</span>
</div>

@if (Model.Aggregate is { TotalEntries: > 0 } agg)
{
	<div class="stats stats-horizontal shadow bg-base-200 border border-base-300 mb-4 overflow-x-auto" data-testid="usage-aggregate">
		<div class="stat py-2 px-4">
			<div class="stat-title text-xs">Surfaced</div>
			<div class="stat-value text-lg" data-testid="agg-surfaced">@agg.SurfacedAtLeastOnce / @agg.TotalEntries</div>
			<div class="stat-desc">@($"{agg.SurfacedFraction:P0}") ever returned in search</div>
		</div>
		<div class="stat py-2 px-4">
			<div class="stat-title text-xs">Opened</div>
			<div class="stat-value text-lg" data-testid="agg-opened">@agg.OpenedAtLeastOnce / @agg.TotalEntries</div>
			<div class="stat-desc">@($"{agg.OpenedFraction:P0}") opened directly — a read count, not a value verdict; see Cost/Fit</div>
		</div>
		<div class="stat py-2 px-4">
			<div class="stat-title text-xs">Median recency</div>
			<div class="stat-value text-lg" data-testid="agg-recency">
				@(agg.MedianLastHitAt is { } m ? $"{(int)Math.Max(0, (DateTime.UtcNow - m).TotalDays)}d" : "—")
			</div>
			<div class="stat-desc">of the surfaced set</div>
		</div>
		<div class="stat py-2 px-4">
			<div class="stat-title text-xs">Dead tail</div>
			<div class="stat-value text-lg" data-testid="agg-dead">@agg.DeadTail.Count</div>
			<div class="stat-desc" title="@string.Join(", ", agg.DeadTail.TopKeys)">never surfaced</div>
		</div>
		<div class="stat py-2 px-4">
			<div class="stat-title text-xs">Cost (@(agg.Cost.WindowDays)d)</div>
			<div class="stat-value text-lg" data-testid="agg-cost">
				@(agg.Cost.Deliveries > 0 ? agg.Cost.DeliveredChars.ToString("N0") : "—")
			</div>
			<div class="stat-desc"
				title="body chars this store delivered into callers' context over the window — read together with Fit: high chars + low fit = noise-boar, low chars + high fit = precise index">
				@(agg.Cost.Deliveries > 0 ? $"{agg.Cost.EntriesDelivered} entries · {agg.Cost.Deliveries} deliveries" : "no deliveries in window")
			</div>
		</div>
		<div class="stat py-2 px-4">
			<div class="stat-title text-xs">Fit</div>
			<div class="stat-value text-lg" data-testid="agg-fit">
				@(agg.Cost.AvgKRel is { } fit ? $"{fit:P0}" : "—")
			</div>
			<div class="stat-desc"
				title="mean within-request relevance of delivered rows — read together with Cost: high chars + low fit = noise-boar, low chars + high fit = precise index">
				@(agg.Cost.AvgKRel.HasValue ? "avg relevance of delivered rows" : "no fit measured in window")
			</div>
		</div>
	</div>
}

<form method="get" class="mb-4 flex items-center gap-2" data-testid="store-search-form">
	<input type="search" name="q" value="@Model.Query" placeholder="Search key, description, body or tags…"
		class="input input-bordered input-sm flex-1 max-w-md" data-testid="store-search-input" />
	<button type="submit" class="btn btn-sm btn-primary" data-testid="store-search-submit">Search</button>
	@if (!string.IsNullOrWhiteSpace(Model.Query))
	{
		<a href="@Routes.ProjectMemoryStore(Model.WorkspaceKey, Model.ProjectKey, Model.Store)" class="btn btn-sm btn-ghost" data-testid="store-search-clear">Clear</a>
	}
</form>

@if (Model.Entries.Count == 0)
{
	<div class="alert" data-testid="store-empty">
		@(string.IsNullOrWhiteSpace(Model.Query) ? "This store has no active entries." : "No entries match this search.")
	</div>
}
else
{
	<ul class="flex flex-col gap-2" data-testid="store-entries">
		@foreach (var e in Model.Entries)
		{
			@* id = the entry key: the anchor half of the stable entry URL
			   (…/memory/{store}#{key}, MemoryLinks) — `.memory-entry:target` in app.css
			   highlights the card the fragment points at. An unknown key simply matches no
			   card; the store page still renders. *@
			<li id="@e.Key" class="memory-entry card bg-base-200 border border-base-300" data-testid="memory-entry" data-entry-key="@e.Key">
				<div class="card-body p-3">
					<div class="flex items-baseline justify-between gap-2">
						<span class="font-mono font-semibold">@e.Key</span>
						@if (Model.Usage.TryGetValue(e.Key, out var u))
						{
							<span class="badge badge-ghost badge-sm opacity-70" data-testid="entry-usage"
								title="surfaced @u.Surfaced x / opened @u.Opened x / last @(u.LastHitAt?.ToString("yyyy-MM-dd HH:mm") ?? "none") -- an impression count, not a value verdict">
								👁 @u.Surfaced · 📖 @u.Opened
							</span>
							<span class="badge badge-ghost badge-sm opacity-70" data-testid="entry-cost"
								title="body chars delivered across this entry's deliveries -- a fact, not a verdict on its own; read together with Fit">
								💰 @(u.Deliveries > 0 ? u.DeliveredChars.ToString("N0") : "—")
							</span>
							<span class="badge badge-ghost badge-sm opacity-70" data-testid="entry-fit"
								title="mean within-request fit (kRel) of delivered rows -- pairs with Cost: high cost + low fit = noise, low cost + high fit = precise">
								🎯 @(u.AvgKRel is { } k ? $"{k:P0}" : "—")
							</span>
						}
						@if (!string.IsNullOrEmpty(e.Tags))
						{
							<span class="flex gap-1 flex-wrap">
								@foreach (var tag in e.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
								{
									<span class="badge badge-ghost badge-sm" data-testid="entry-tag">@tag</span>
								}
							</span>
						}
					</div>
					@if (!string.IsNullOrEmpty(e.Description))
					{
						<p class="text-sm opacity-70">@e.Description</p>
					}
					@if (!string.IsNullOrEmpty(e.Body))
					{
						<p class="text-sm opacity-90 whitespace-pre-wrap">@e.Body</p>
					}
				</div>
			</li>
		}
	</ul>

	<div class="flex items-center justify-between mt-4 text-sm">
		<span class="opacity-60" data-testid="store-page-info">page @(Model.PageNum + 1) · @Model.Entries.Count of @Model.Total</span>
		<div class="join">
			@if (Model.PageNum > 0)
			{
				<a href="@PageHref(Model.PageNum - 1)" class="btn btn-sm join-item" data-testid="store-prev">‹ Prev</a>
			}
			else
			{
				<button class="btn btn-sm join-item btn-disabled" disabled>‹ Prev</button>
			}
			@if (Model.HasNext)
			{
				<a href="@PageHref(Model.PageNum + 1)" class="btn btn-sm join-item" data-testid="store-next">Next ›</a>
			}
			else
			{
				<button class="btn btn-sm join-item btn-disabled" disabled>Next ›</button>
			}
		</div>
	</div>
}
