@page "/ui/{workspaceKey}/{projectKey}/databases"
@model PetBox.Web.Pages.ProjectHome.DatabasesModel
@{
	ViewData["Title"] = $"Databases — {Model.Project?.Name ?? Model.ProjectKey}";
}

<div class="mb-4 flex items-baseline gap-3 flex-wrap">
	<h1 class="text-2xl font-semibold" data-testid="databases-title">@(Model.Project?.Name ?? Model.ProjectKey) · databases</h1>
	<span class="badge badge-ghost">@Model.Dbs.Count</span>
</div>

@if (Model.Project is null)
{
	<div class="alert alert-error" data-testid="databases-notfound">Project not found.</div>
	return;
}

@if (!Model.DataEnabled)
{
	<div class="alert" data-testid="databases-disabled">The Data module is disabled.</div>
	return;
}

@if (Model.Dbs.Count == 0)
{
	<div class="alert" data-testid="databases-empty">
		<span>No databases yet.</span>
		@if (Model.CanAdminWorkspace)
		{
			<a href="@Routes.ProjectData(Model.WorkspaceKey, Model.ProjectKey)" class="link" data-testid="databases-create-link">Create one in the Data admin page.</a>
		}
		else
		{
			<span class="opacity-70">Ask a workspace admin to create one on the Data admin page.</span>
		}
	</div>
}
else
{
	<section class="grid grid-cols-1 sm:grid-cols-2 gap-3" data-testid="databases-list">
		@foreach (var d in Model.Dbs)
		{
			<a href="@Routes.ProjectDatabase(Model.WorkspaceKey, Model.ProjectKey, d.Name)"
				class="card bg-base-200 border border-base-300 hover:border-primary transition-colors"
				data-testid="database-card" data-db-name="@d.Name">
				<div class="card-body p-4">
					<div class="flex items-baseline justify-between">
						<span class="font-mono font-semibold">@d.Name</span>
						<span class="text-xs opacity-60">@(d.MaxPageCount * 4 / 1024) MB quota</span>
					</div>
					@if (!string.IsNullOrEmpty(d.Description))
					{
						<p class="text-sm opacity-80">@d.Description</p>
					}
					<div class="text-xs opacity-50 font-mono mt-2">created @d.CreatedAt.ToString("yyyy-MM-dd")</div>
				</div>
			</a>
		}
	</section>
}
