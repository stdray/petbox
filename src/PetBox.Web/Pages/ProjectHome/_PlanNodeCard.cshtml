@model PetBox.Web.Pages.ProjectHome.TaskBoardModel.PlanNodeCard
@{
	var n = Model.Node;
	var leaf = n.Key;
	var parent = n.ParentSlug;
	var nodeUrl = Routes.TaskBoardNodeBySlug(Model.WorkspaceKey, Model.ProjectKey, Model.Board, n.Key);
	var search = $"{n.Title} {n.Key} {n.Body} {string.Join(' ', n.Tags)}".ToLowerInvariant();
}

@* One plan-node card. Reused by both the part_of tree and the tag-groups projection; the
   data-* attributes power ts/board.ts (tree pane only — the tag pane uses a different list).
   data-priority/title/created/updated (board-sort-impl) feed the client sort toggle — CreatedAt/
   UpdatedAt come straight off the active PlanNode revision, so they're only meaningful here in
   the tree pane. *@
<li class="card bg-base-200 border border-base-300" data-testid="plan-node" data-node-key="@n.Key" data-depth="@Model.Depth" data-node-id="@n.NodeId" data-parent-id="@(n.ParentNodeId ?? "")" data-closed="@Model.Closed.ToString().ToLowerInvariant()" data-keep-visible="@Model.KeepVisible.ToString().ToLowerInvariant()" data-status="@n.Status" data-type="@n.Type" data-search="@search" data-priority="@n.Priority" data-title="@n.Title" data-created="@(n.CreatedAt?.ToString("o") ?? "")" data-updated="@(n.UpdatedAt?.ToString("o") ?? "")" style="margin-left:@(Model.Depth * 1.5)rem">
	<div class="card-body p-3">
		<div class="flex items-baseline justify-between gap-2">
			<div class="min-w-0 flex items-baseline gap-2 flex-wrap">
				@if (Model.HasChildren)
				{
					<button type="button" data-collapse-toggle class="btn btn-ghost btn-xs px-1 leading-none font-mono shrink-0" title="collapse / expand subtree" aria-label="collapse or expand">▾</button>
				}
				@if (!string.IsNullOrEmpty(n.Title))
				{
					<a href="@nodeUrl" class="font-semibold link link-hover" data-testid="node-name">@n.Title</a>
				}
				<span class="font-mono text-xs opacity-50">
					@if (parent is not null)
					{
						<span>@parent / </span>
					}
					<a href="@nodeUrl" class="link link-hover" data-testid="node-leaf">@leaf</a>
				</span>
			</div>
			<div class="flex items-center gap-1 shrink-0">
				@* Status + delivery badges via the shared partials — the ONE spec-board suppression
				   rule (StatusBadgeModel.Show) and colour mappings, so the board card and the node
				   detail page can never drift (ui-spec-status-board-node-mismatch). *@
				<partial name="_StatusBadge" model="new PetBox.Web.Pages.Shared.StatusBadgeModel(Model.Runtime, Model.KindSlug, n.Status)" />
				@if (n.Delivery is not null)
				{
					<partial name="_DeliveryBadge" model="new PetBox.Web.Pages.Shared.DeliveryBadgeModel(n.Delivery)" />
				}
			</div>
		</div>
		@if (!string.IsNullOrEmpty(n.Body))
		{
			@* Body is markdown, hydrated client-side (ts/markdown.ts) and clipped on the
			   board — the full text lives on the node detail page (board-body-truncate). *@
			<div class="mt-1">
				<partial name="_MdBody" model="@(new PetBox.Web.Pages.Shared.MdBodyModel { Body = n.Body, TestId = "node-body", ExtraClasses = "max-h-24 overflow-hidden", CommitUrlTemplate = Model.CommitUrlTemplate, NodeRefs = Model.NodeRefs })" />
				<a href="@nodeUrl" class="text-xs link link-hover opacity-60" data-testid="node-body-more">full ↗</a>
			</div>
		}
		@if (n.Commits is { Count: > 0 })
		{
			<div class="text-xs opacity-50 font-mono mt-1 flex flex-wrap gap-x-2 gap-y-1" data-testid="node-commits">
				@foreach (var sha in n.Commits)
				{
					var commitUrl = PetBox.Web.Rendering.CommitUrl.For(Model.CommitUrlTemplate, sha);
					if (commitUrl is not null)
					{
						<a href="@commitUrl" target="_blank" rel="noopener" class="link link-hover" data-testid="node-commit-link">@sha</a>
					}
					else
					{
						<span data-testid="node-commit">@sha</span>
					}
				}
			</div>
		}
		@if (n.LinkedTasks is { Count: > 0 })
		{
			<div class="text-xs opacity-70 mt-1 flex flex-wrap gap-x-3 gap-y-1" data-testid="node-linked-tasks">
				@foreach (var t in n.LinkedTasks)
				{
					<a href="@Routes.TaskBoardNodeBySlug(Model.WorkspaceKey, Model.ProjectKey, t.Board!, t.Slug!)" class="font-mono link link-hover" data-testid="linked-task">@t.Slug<span class="opacity-50"> · @t.Status</span></a>
				}
			</div>
		}
		@* List-view card (tree/tags/kanban/table): show existing comments, but suppress the
		   root add-comment form (board-comment-form-list-noise) — commenting is a node-detail
		   operation, not a per-card affordance under every node on the board. *@
		<partial name="_CommentThread" model="@(new PetBox.Web.Pages.Shared.CommentThreadModel(Model.Thread ?? [], n.NodeId, Model.CommitUrlTemplate, Model.NodeRefs, ShowAddForm: false))" />
	</div>
</li>
