@model PetBox.Web.Pages.ProjectHome.TaskBoardModel.PlanNodeCard
@{
	var n = Model.Node;
	var leaf = n.Key;
	var parent = n.ParentSlug;
	var nodeUrl = Routes.TaskBoardNodeBySlug(Model.WorkspaceKey, Model.ProjectKey, Model.Board, n.Key);
	// board-search-stem-lookup: BODY dropped from data-search — it used to ship the body TWICE
	// (rendered HTML + this attribute, 294KB->124KB gzip on the real `work` board). Title+key+tags
	// stays as an instant substring fallback for the brief window before ts/board.ts's fetched
	// stem index (?handler=SearchIndex) loads, mirroring the pattern _BoardViewKanban.cshtml /
	// _BoardViewOutline.cshtml already use for the same reason.
	var search = $"{n.Title} {n.Key} {string.Join(' ', n.Tags)}".ToLowerInvariant();
	// board-terminal-negative-visible: the strikethrough is an INVARIANT over the data
	// (StatusKind.TerminalCancel), not a dialog checkbox — a terminally-cancelled node reads as
	// dead REGARDLESS of whether Model.Fields.Status is on, so this never consults Fields.
	// SCOPED TO THE SPEC BOARD ONLY (review finding, 2026-07): on every other board the status is
	// already a displayable property (toggle via the fields dialog), so the strikethrough was
	// redundant noise there — the maintainer ruled it out everywhere except spec.
	var terminalCancel = Model.Runtime.StatusKindOf(Model.KindSlug, n.Status) == StatusKind.TerminalCancel;
	// IsSpecKind, NOT PresetKind(...) == BoardKind.Spec (production regression, 2026-07):
	// PresetKind nulls out for any DEFINED kind, and a real project's spec board is virtually
	// always definition-resolved — see MethodologyRuntime.IsSpecKind's own comment.
	var isSpecBoard = Model.Runtime.IsSpecKind(Model.KindSlug);
	var strikethrough = terminalCancel && isSpecBoard;
}

@* One plan-node card. Reused by both the part_of tree and the tag-groups projection; the
   data-* attributes power ts/board.ts (tree pane only — the tag pane uses a different list).
   data-priority/title/created/updated (board-sort-impl) feed the client sort toggle — CreatedAt/
   UpdatedAt come straight off the active PlanNode revision, so they're only meaningful here in
   the tree pane. *@
<li class="card bg-base-200 border border-base-300" data-testid="plan-node" data-node-key="@n.Key" data-depth="@Model.Depth" data-node-id="@n.NodeId" data-parent-id="@(n.ParentNodeId ?? "")" data-closed="@Model.Closed.ToString().ToLowerInvariant()" data-keep-visible="@Model.KeepVisible.ToString().ToLowerInvariant()" data-status="@n.Status" data-type="@n.Type" data-search="@search" data-priority="@n.Priority" data-title="@n.Title" data-created="@(n.CreatedAt?.ToString("o") ?? "")" data-updated="@(n.UpdatedAt?.ToString("o") ?? "")" data-terminal-cancel="@terminalCancel.ToString().ToLowerInvariant()" style="margin-left:@(Model.Depth * 1.5)rem;display:@(Model.Hidden ? "none" : "")">
	<div class="card-body p-3">
		<div class="flex items-baseline justify-between gap-2">
			<div class="min-w-0 flex items-baseline gap-2 flex-wrap">
				@* board-filters-server-state: the caret glyph and data-collapsed both come off the
				   server-resolved collapse cookie now — ts/board.ts no longer sets the glyph after
				   paint, it only flips it (and Model.Hidden's descendants) on a click. *@
				@if (Model.HasChildren)
				{
					<button type="button" data-collapse-toggle data-collapsed="@Model.CollapsedSelf.ToString().ToLowerInvariant()" class="btn btn-ghost btn-xs px-1 leading-none font-mono shrink-0" title="collapse / expand subtree" aria-label="collapse or expand">@(Model.CollapsedSelf ? "▸" : "▾")</button>
				}
				@if (!string.IsNullOrEmpty(n.Title))
				{
					<a href="@nodeUrl" class="font-semibold link link-hover @(strikethrough ? "line-through opacity-60" : "")" data-testid="node-name">@n.Title</a>
				}
				@if (Model.Fields.Slug)
				{
					<span class="font-mono text-xs opacity-50">
						@if (parent is not null)
						{
							<span>@parent / </span>
						}
						<a href="@nodeUrl" class="link link-hover" data-testid="node-leaf">@leaf</a>
					</span>
				}
			</div>
			<div class="flex items-center gap-1 shrink-0 flex-wrap justify-end">
				@* board-view-fields: type/priority badges are plain, so they render inline here
				   rather than through a shared partial (only the ENABLE decision — Model.Fields —
				   is shared, per BoardFieldConfig's own header comment). *@
				@if (Model.Fields.Type && !string.IsNullOrEmpty(n.Type))
				{
					<span class="badge badge-ghost badge-xs" data-testid="node-type">@n.Type</span>
				}
				@if (Model.Fields.Priority)
				{
					<span class="font-mono text-xs opacity-70" data-testid="node-priority" title="priority">P@(n.Priority)</span>
				}
				@* Status + delivery badges via the shared partials — the ONE spec-board suppression
				   rule (StatusBadgeModel.Show) and colour mappings, so the board card and the node
				   detail page can never drift (ui-spec-status-board-node-mismatch). Gated on
				   Model.Fields.Status/Delivery — unlike the terminal-cancel strikethrough above,
				   these ARE dialog-togglable (board-view-fields). *@
				@if (Model.Fields.Status)
				{
					<partial name="_StatusBadge" model="new PetBox.Web.Pages.Shared.StatusBadgeModel(Model.Runtime, Model.KindSlug, n.Status)" />
				}
				@if (Model.Fields.Delivery && n.Delivery is not null)
				{
					<partial name="_DeliveryBadge" model="new PetBox.Web.Pages.Shared.DeliveryBadgeModel(n.Delivery)" />
				}
				@if (Model.Fields.UpdatedAt && n.UpdatedAt is not null)
				{
					<time class="local-time text-xs opacity-60" datetime="@n.UpdatedAt.Value.ToString("o")" data-testid="node-updated">@n.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm")</time>
				}
			</div>
		</div>
		@if (Model.Fields.Tags && n.Tags.Count > 0)
		{
			<div class="flex flex-wrap gap-1 mt-1" data-testid="node-tags">
				@foreach (var t in n.Tags)
				{
					<span class="badge badge-outline badge-xs">@t</span>
				}
			</div>
		}
		@if (Model.Fields.BlockedBy)
		{
			<div class="mt-1">
				<partial name="_BlockedByChips" model="new PetBox.Web.Pages.Shared.BlockedByChipsModel(Model.WorkspaceKey, Model.ProjectKey, n.BlockedBy)" />
			</div>
		}
		@if (Model.Fields.Body && !string.IsNullOrEmpty(n.Body))
		{
			@* Body is markdown, hydrated client-side (ts/markdown.ts) and clipped on the
			   board — the full text lives on the node detail page (board-body-truncate). *@
			<div class="mt-1">
				<partial name="_MdBody" model="@(new PetBox.Web.Pages.Shared.MdBodyModel { Body = n.Body, TestId = "node-body", ExtraClasses = "max-h-24 overflow-hidden", CommitUrlTemplate = Model.CommitUrlTemplate, NodeRefs = Model.NodeRefs, MemoryRefs = Model.MemoryRefs })" />
				<a href="@nodeUrl" class="text-xs link link-hover opacity-60" data-testid="node-body-more">full ↗</a>
			</div>
		}
		@if (n.Commits is { Count: > 0 })
		{
			<div class="text-xs opacity-50 font-mono mt-1 flex flex-wrap gap-x-2 gap-y-1" data-testid="node-commits">
				@foreach (var sha in n.Commits)
				{
					var commitUrl = PetBox.Web.Rendering.CommitUrl.For(Model.CommitUrlTemplate, sha);
					if (commitUrl is not null)
					{
						<a href="@commitUrl" target="_blank" rel="noopener" class="link link-hover" data-testid="node-commit-link">@sha</a>
					}
					else
					{
						<span data-testid="node-commit">@sha</span>
					}
				}
			</div>
		}
		@if (n.LinkedTasks is { Count: > 0 })
		{
			<div class="text-xs opacity-70 mt-1 flex flex-wrap gap-x-3 gap-y-1" data-testid="node-linked-tasks">
				@foreach (var t in n.LinkedTasks)
				{
					<a href="@Routes.TaskBoardNodeBySlug(Model.WorkspaceKey, Model.ProjectKey, t.Board!, t.Slug!)" class="font-mono link link-hover" data-testid="linked-task">@t.Slug<span class="opacity-50"> · @t.Status</span></a>
				}
			</div>
		}
		@* board-page-cost: a board card never renders the discussion thread (body/markdown per
		   comment) — that stayed a node-detail-page affordance. A count-only chip (sourced from
		   ONE aggregate query, Model.CommentCount) links to it instead. *@
		@if (Model.CommentCount > 0)
		{
			<div class="mt-1">
				<a href="@nodeUrl" class="text-xs link link-hover opacity-60" data-testid="node-comment-count">💬 @Model.CommentCount</a>
			</div>
		}
	</div>
</li>
