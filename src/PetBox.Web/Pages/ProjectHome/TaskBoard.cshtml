@page "/ui/{workspaceKey}/{projectKey}/tasks/{board}"
@model PetBox.Web.Pages.ProjectHome.TaskBoardModel
@{
	ViewData["Title"] = $"{Model.Board} — Tasks";
}

@functions {
	// Status is a workflow slug; the catalog tells us its StatusKind (domain), the
	// view maps that to a daisyUI class (presentation stays here, not in the domain).
	static string StatusBadge(string slug) => PetBox.Tasks.Workflow.WorkflowCatalog.KindOfSlug(slug) switch
	{
		PetBox.Tasks.Workflow.StatusKind.TerminalOk => "badge-success",
		PetBox.Tasks.Workflow.StatusKind.TerminalCancel => "badge-ghost",
		PetBox.Tasks.Workflow.StatusKind.Open => "badge-info",
		_ => "badge-neutral",
	};

	// Computed spec delivery roll-up (spec boards only) -> daisyUI class.
	static string DeliveryBadge(string d) => d switch
	{
		"done" => "badge-success",
		"in_progress" => "badge-warning",
		"done_with_defects" => "badge-error",
		_ => "badge-ghost", // not_started
	};
}

<div class="mb-4 flex items-baseline gap-3 flex-wrap">
	<a href="@Routes.ProjectTasks(Model.WorkspaceKey, Model.ProjectKey)" class="link link-hover opacity-70" data-testid="board-breadcrumb">tasks</a>
	<span class="opacity-40">/</span>
	<h1 class="text-2xl font-semibold font-mono" data-testid="board-title">@Model.Board</h1>
	<span class="badge badge-ghost">@Model.Nodes.Count node(s)</span>
</div>

<form method="post" asp-page-handler="Create" class="mb-4 flex flex-col gap-2" data-testid="task-create">
	<input type="text" name="name" required maxlength="200" class="input input-bordered input-sm w-full" placeholder="New task title → incoming…" data-testid="task-create-name" aria-label="Title" />
	<textarea name="body" maxlength="4000" rows="2" class="textarea textarea-bordered textarea-sm w-full" placeholder="Details (optional)" data-testid="task-create-body" aria-label="Body"></textarea>
	<div class="flex items-center gap-2">
		<select name="priority" class="select select-bordered select-sm" data-testid="task-create-priority" aria-label="Priority">
			<option value="10">High</option>
			<option value="50" selected>Normal</option>
			<option value="90">Low</option>
		</select>
		<button type="submit" class="btn btn-sm btn-primary" data-testid="task-create-submit">Add</button>
	</div>
</form>

@if (Model.Nodes.Count == 0)
{
	<div class="alert" data-testid="board-empty">This board has no active plan nodes.</div>
}
else
{
	// A node has children when some other node's part_of parent is its NodeId — only those
	// get a collapse caret. (Visibility/collapse/filter is applied client-side by ts/board.ts;
	// active-only + collapse state persist in localStorage.)
	var parentIds = Model.Nodes.Where(x => x.ParentNodeId is not null).Select(x => x.ParentNodeId!).ToHashSet(StringComparer.Ordinal);

	<div class="mb-3 flex flex-wrap items-center gap-2" data-testid="board-filter">
		<input type="search" class="input input-bordered input-xs w-48" placeholder="filter…" data-testid="board-filter-text" aria-label="Filter text" />
		<select class="select select-bordered select-xs" data-testid="board-filter-status" aria-label="Filter by status"><option value="">status: any</option></select>
		<select class="select select-bordered select-xs" data-testid="board-filter-type" aria-label="Filter by type"><option value="">type: any</option></select>
		<label class="label cursor-pointer justify-start gap-2 text-xs">
			<input type="checkbox" class="toggle toggle-xs" data-testid="active-only-toggle" />
			<span>active only</span>
		</label>
	</div>
	<ul class="flex flex-col gap-2" data-testid="board-nodes">
		@foreach (var n in Model.Nodes)
		{
			var depth = n.Depth;
			var leaf = n.Key;
			var parent = n.ParentSlug;
			var closed = PetBox.Tasks.Workflow.WorkflowCatalog.IsTerminalSlug(n.Status);
			// A closed node hides under "active only" — unless it still has open
			// descendants, in which case it stays so its children aren't orphaned.
			var keepVisible = !closed || Model.ClosedWithActiveDescendant.Contains(n.NodeId);
			var hasChildren = parentIds.Contains(n.NodeId);
			var search = $"{n.Title} {n.Key} {n.Body} {string.Join(' ', n.Tags)}".ToLowerInvariant();
			var nodeUrl = Routes.TaskBoardNode(Model.WorkspaceKey, Model.ProjectKey, n.NodeId);
			<li class="card bg-base-200 border border-base-300" data-testid="plan-node" data-node-key="@n.Key" data-depth="@depth" data-node-id="@n.NodeId" data-parent-id="@(n.ParentNodeId ?? "")" data-closed="@closed.ToString().ToLowerInvariant()" data-keep-visible="@keepVisible.ToString().ToLowerInvariant()" data-status="@n.Status" data-type="@n.Type" data-search="@search" style="margin-left:@(depth * 1.5)rem">
				<div class="card-body p-3">
					<div class="flex items-baseline justify-between gap-2">
						<div class="min-w-0 flex items-baseline gap-2 flex-wrap">
							@if (hasChildren)
							{
								<button type="button" data-collapse-toggle class="btn btn-ghost btn-xs px-1 leading-none font-mono shrink-0" title="collapse / expand subtree" aria-label="collapse or expand">▾</button>
							}
							@if (!string.IsNullOrEmpty(n.Title))
							{
								<a href="@nodeUrl" class="font-semibold link link-hover" data-testid="node-name">@n.Title</a>
							}
							<span class="font-mono text-xs opacity-50">
								@if (parent is not null)
								{
									<span>@parent / </span>
								}
								<a href="@nodeUrl" class="link link-hover" data-testid="node-leaf">@leaf</a>
							</span>
						</div>
						<div class="flex items-center gap-1 shrink-0">
							<span class="badge @StatusBadge(n.Status) badge-sm" data-testid="node-status">@n.Status</span>
							@if (n.Delivery is not null)
							{
								<span class="badge @DeliveryBadge(n.Delivery) badge-sm" data-testid="node-delivery" title="delivery — computed from linked tasks">@n.Delivery</span>
							}
						</div>
					</div>
					@if (!string.IsNullOrEmpty(n.Body))
					{
						// Body is markdown, hydrated client-side (ts/markdown.ts) and clipped on the
						// board — the full text lives on the node detail page (board-body-truncate).
						<div class="mt-1">
							<div data-md class="md-body text-base opacity-90 max-h-24 overflow-hidden" data-testid="node-body">@n.Body</div>
							<a href="@nodeUrl" class="text-xs link link-hover opacity-60" data-testid="node-body-more">full ↗</a>
						</div>
					}
					@if (!string.IsNullOrEmpty(n.CommitRef))
					{
						<div class="text-xs opacity-50 font-mono mt-1">@n.CommitRef</div>
					}
					@if (n.LinkedTasks is { Count: > 0 })
					{
						<div class="text-xs opacity-70 mt-1 flex flex-wrap gap-x-3 gap-y-1" data-testid="node-linked-tasks">
							@foreach (var t in n.LinkedTasks)
							{
								<span class="font-mono" data-testid="linked-task">@t.Slug<span class="opacity-50"> · @t.Status</span></span>
							}
						</div>
					}
					@if (Model.CommentThreads.TryGetValue(n.NodeId, out var thread))
					{
						<partial name="_CommentThread" model="thread" />
					}
				</div>
			</li>
		}
	</ul>
}
