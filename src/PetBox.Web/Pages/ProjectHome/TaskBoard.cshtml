@page "/ui/{workspaceKey}/{projectKey}/tasks/{board}"
@model PetBox.Web.Pages.ProjectHome.TaskBoardModel
@{
	ViewData["Title"] = $"{Model.Board} — Tasks";

	// Tag-grouping presets: each is an ordered list of tag namespaces (board-tag-grouping).
	// Order sets nesting; the projection is a pure view (tag-grouping-is-projection).
	var presets = new (string By, string Label)[]
	{
		("area", "area"),
		("concern", "concern"),
		("area,concern", "area → concern"),
		("concern,area", "concern → area"),
	};
	var curBy = string.Join(",", Model.GroupDims);

	// Effective kind via MethodologyRuntime (definition first, preset fallback) — a
	// definition-declared custom kind shows its own slug, not the Simple fallback.
	var kindName = Model.KindName;
	var isSimple = Model.Runtime.PresetKind(Model.KindSlug) == PetBox.Tasks.Workflow.BoardKind.Simple;
	// Surface the board kind explicitly so its statuses read as "this is a simple/methodology
	// board", not "the statuses are broken". Simple = a lightweight preset (fixed vocab, free
	// transitions); methodology kinds add gates.
	var kindBadgeClass = isSimple ? "badge-info badge-outline" : "badge-neutral";
	var kindTitle = isSimple
		? "simple board — lightweight preset: statuses Todo|InProgress|Blocked|Done|Cancelled, free transitions, types task|bug|feature|chore|issue"
		: $"{kindName} board — statuses follow the {kindName} workflow";
}

<div class="mb-4 flex items-baseline gap-3 flex-wrap">
	<a href="@Routes.ProjectTasks(Model.WorkspaceKey, Model.ProjectKey)" class="link link-hover opacity-70" data-testid="board-breadcrumb">tasks</a>
	<span class="opacity-40">/</span>
	<h1 class="text-2xl font-semibold font-mono" data-testid="board-title">@Model.Board</h1>
	<span class="badge @kindBadgeClass" data-testid="board-kind" data-kind="@kindName" title="@kindTitle">@kindName</span>
	<span class="badge badge-ghost">@Model.Nodes.Count node(s)</span>
	@* Per-type "View workflow" triggers — one per FSM block (a preset kind has exactly one).
	   Opens the daisyUI modal with the block's status graph (ts/workflow-viz.ts). *@
	@if (Model.WorkflowBlocks.Count > 0)
	{
		<span class="text-xs opacity-50 ml-1">workflow:</span>
		@foreach (var wb in Model.WorkflowBlocks)
		{
			<button type="button" class="btn btn-ghost btn-xs gap-1" data-testid="workflow-open" data-workflow-type="@wb.Types[0]" title="View this type's workflow graph">⤳ @string.Join(" · ", wb.Types)</button>
		}
	}
</div>

@if (Model.ShowQuickAdd)
{
	<form method="post" asp-page-handler="Create" class="mb-4 flex flex-col gap-2" data-testid="task-create">
		<input type="text" name="name" required maxlength="200" class="input input-bordered input-sm w-full" placeholder="New task title → incoming…" data-testid="task-create-name" aria-label="Title" />
		<textarea name="body" maxlength="4000" rows="2" class="textarea textarea-bordered textarea-sm w-full" placeholder="Details (optional)" data-testid="task-create-body" aria-label="Body"></textarea>
		<div class="flex items-center gap-2">
			<select name="priority" class="select select-bordered select-sm" data-testid="task-create-priority" aria-label="Priority">
				<option value="10">High</option>
				<option value="50" selected>Normal</option>
				<option value="90">Low</option>
			</select>
			<button type="submit" class="btn btn-sm btn-primary" data-testid="task-create-submit">Add</button>
		</div>
	</form>
}

@* View switch: the stored part_of tree, or a tag-groups projection by an ordered namespace
   list. Explicit query-string links (no implicit persistence) — switching is reversible and
   never mutates part_of (tag-grouping-is-projection). *@
<div class="mb-3 flex flex-wrap items-center gap-1" data-testid="board-view-controls">
	<span class="text-xs opacity-60 mr-1">view:</span>
	<a href="?view=tree" class="btn btn-xs @(Model.IsTagView ? "btn-ghost" : "btn-active")" data-testid="view-tree">part_of</a>
	<span class="text-xs opacity-40 mx-1">tags:</span>
	@foreach (var p in presets)
	{
		var active = Model.IsTagView && curBy == p.By;
		<a href="?view=tags&by=@Uri.EscapeDataString(p.By)" class="btn btn-xs @(active ? "btn-active" : "btn-ghost")" data-testid="view-tags" data-by="@p.By">@p.Label</a>
	}
</div>

@if (Model.IsTagView)
{
	@if (Model.GroupRows.Count == 0)
	{
		<div class="alert" data-testid="board-empty">This board has no active plan nodes.</div>
	}
	else
	{
		<ul class="flex flex-col gap-2" data-testid="board-tag-groups">
			@foreach (var row in Model.GroupRows)
			{
				@if (row.Node is null)
				{
					<li class="mt-2" style="margin-left:@(row.Depth * 1.5)rem" data-testid="tag-group" data-group-key="@row.GroupKey">
						<div class="flex items-baseline gap-2 border-b border-base-300 pb-1">
							<span class="font-mono font-semibold text-sm">@row.GroupKey</span>
							@if (row.Delivery is not null)
							{
								<partial name="_DeliveryBadge" model="@(new PetBox.Web.Pages.Shared.DeliveryBadgeModel(row.Delivery) { Size = "badge-xs", Title = "delivery — rolled up over this group", TestId = null })" />
							}
						</div>
					</li>
				}
				else
				{
					var closed = Model.Runtime.IsTerminalStatus(Model.KindSlug, row.Node.Status);
					Model.CommentThreads.TryGetValue(row.Node.NodeId, out var thread);
					<partial name="_PlanNodeCard" model="new PetBox.Web.Pages.ProjectHome.TaskBoardModel.PlanNodeCard(Model.WorkspaceKey, Model.ProjectKey, Model.Board, Model.Runtime, Model.KindSlug, row.Node, row.Depth, closed, true, false, thread, Model.CommitUrlTemplate, Model.NodeRefs)" />
				}
			}
		</ul>
	}
}
else if (Model.Nodes.Count == 0)
{
	<div class="alert" data-testid="board-empty">This board has no active plan nodes.</div>
}
else
{
	// A node has children when some other node's part_of parent is its NodeId — only those
	// get a collapse caret. (Visibility/collapse/filter is applied client-side by ts/board.ts;
	// active-only + collapse state persist in localStorage.)
	var parentIds = Model.Nodes.Where(x => x.ParentNodeId is not null).Select(x => x.ParentNodeId!).ToHashSet(StringComparer.Ordinal);

	<div class="mb-3 flex flex-wrap items-center gap-2" data-testid="board-filter">
		<input type="search" class="input input-bordered input-xs w-48" placeholder="filter…" data-testid="board-filter-text" aria-label="Filter text" />
		<select class="select select-bordered select-xs" data-testid="board-filter-status" aria-label="Filter by status"><option value="">status: any</option></select>
		<select class="select select-bordered select-xs" data-testid="board-filter-type" aria-label="Filter by type"><option value="">type: any</option></select>
		<label class="label cursor-pointer justify-start gap-2 text-xs">
			<input type="checkbox" class="toggle toggle-xs" data-testid="active-only-toggle" />
			<span>active only</span>
		</label>
	</div>
	<ul class="flex flex-col gap-2" data-testid="board-nodes">
		@foreach (var n in Model.Nodes)
		{
			var closed = Model.Runtime.IsTerminalStatus(Model.KindSlug, n.Status);
			// A closed node hides under "active only" — unless it still has open
			// descendants, in which case it stays so its children aren't orphaned.
			var keepVisible = !closed || Model.ClosedWithActiveDescendant.Contains(n.NodeId);
			var hasChildren = parentIds.Contains(n.NodeId);
			Model.CommentThreads.TryGetValue(n.NodeId, out var thread);
			<partial name="_PlanNodeCard" model="new PetBox.Web.Pages.ProjectHome.TaskBoardModel.PlanNodeCard(Model.WorkspaceKey, Model.ProjectKey, Model.Board, Model.Runtime, Model.KindSlug, n, n.Depth, closed, keepVisible, hasChildren, thread, Model.CommitUrlTemplate, Model.NodeRefs)" />
		}
	</ul>
}

@if (Model.WorkflowJson is not null)
{
	<partial name="_WorkflowModal" model="Model.WorkflowJson" />
}
