@page "/ui/{workspaceKey}/{projectKey}/tasks/{board}"
@model PetBox.Web.Pages.ProjectHome.TaskBoardModel
@{
	ViewData["Title"] = $"{Model.Board} — Tasks";

	// Tag-grouping `by` (board-tag-grouping): the ordered tag-namespace list a direct
	// `?view=tags&by=...` request applied — the projection is a pure view (tag-grouping-is-
	// projection). Still computed (board-view-meta below needs it for the client reconcile) even
	// though the switcher no longer offers preset buttons to pick it (board-tag-grouping-hidden:
	// Tags is a Hidden entry in BoardViewModeRegistry — direct URL access keeps working).
	var curBy = string.Join(",", Model.GroupDims);

	// Effective kind via MethodologyRuntime (definition first, preset fallback) — a
	// definition-declared custom kind shows its own slug, not the Simple fallback.
	var kindName = Model.KindName;
	var isSimple = Model.Runtime.PresetKind(Model.KindSlug) == PetBox.Tasks.Workflow.BoardKind.Simple;
	// Surface the board kind explicitly so its statuses read as "this is a simple/methodology
	// board", not "the statuses are broken". Simple = a lightweight preset (fixed vocab, free
	// transitions); methodology kinds add gates.
	var kindBadgeClass = isSimple ? "badge-info badge-outline" : "badge-neutral";
	var kindTitle = isSimple
		? "simple board — lightweight preset: statuses Todo|InProgress|Blocked|Done|Cancelled, free transitions, types task|bug|feature|chore|issue"
		: $"{kindName} board — statuses follow the {kindName} workflow";
}

@if (Model.Error is not null)
{
	<div class="alert alert-error text-sm py-2 mb-3" data-testid="board-comment-error" role="alert">@Model.Error</div>
}

<div class="mb-4 flex items-baseline gap-3 flex-wrap">
	<a href="@Routes.ProjectTasks(Model.WorkspaceKey, Model.ProjectKey)" class="link link-hover opacity-70" data-testid="board-breadcrumb">tasks</a>
	<span class="opacity-40">/</span>
	<h1 class="text-2xl font-semibold font-mono" data-testid="board-title">@Model.Board</h1>
	<span class="badge @kindBadgeClass" data-testid="board-kind" data-kind="@kindName" title="@kindTitle">@kindName</span>
	@if (Model.ClosedAt is not null)
	{
		<span class="badge badge-warning badge-xs" data-testid="board-closed-badge" title="closed — read-only, writes are rejected">closed</span>
	}
	<span class="badge badge-ghost">@Model.Nodes.Count node(s)</span>
	@* Per-type "View workflow" triggers — one per FSM block (a preset kind has exactly one).
	   Opens the daisyUI modal with the block's status graph (ts/workflow-viz.ts). *@
	@if (Model.WorkflowBlocks.Count > 0)
	{
		<span class="text-xs opacity-50 ml-1">workflow:</span>
		@foreach (var wb in Model.WorkflowBlocks)
		{
			<button type="button" class="btn btn-ghost btn-xs gap-1" data-testid="workflow-open" data-workflow-type="@wb.Types[0]" title="View this type's workflow graph">⤳ @string.Join(" · ", wb.Types)</button>
		}
	}
</div>

@if (Model.ShowQuickAdd)
{
	<form method="post" asp-page-handler="Create" class="mb-4 flex flex-col gap-2" data-testid="task-create">
		<input type="text" name="name" required maxlength="200" class="input input-bordered input-sm w-full" placeholder="New task title → incoming…" data-testid="task-create-name" aria-label="Title" />
		<textarea name="body" maxlength="4000" rows="2" class="textarea textarea-bordered textarea-sm w-full" placeholder="Details (optional)" data-testid="task-create-body" aria-label="Body"></textarea>
		<div class="flex items-center gap-2">
			<select name="priority" class="select select-bordered select-sm" data-testid="task-create-priority" aria-label="Priority">
				<option value="10">High</option>
				<option value="50" selected>Normal</option>
				<option value="90">Low</option>
			</select>
			<button type="submit" class="btn btn-sm btn-primary" data-testid="task-create-submit">Add</button>
		</div>
	</form>
}

@* View switch (board-view-modes): one button per NON-HIDDEN BoardViewModeRegistry entry — a
   new mode (kanban/outline/table, once its partial ships) needs no edit here, it just appears.
   Filtering on `!entry.Hidden` (board-tag-grouping-hidden) is how a mode stops offering itself
   in the switcher without this markup ever naming it — Tags is Hidden today (its presets
   worked poorly enough to pull from discovery pending a redesign), but `?view=tags&by=...`
   still resolves/renders exactly as before (BoardViewModeRegistry.Resolve/Find scan the FULL
   Entries list, hidden or not — only this loop filters). Explicit query-string links (no
   implicit persistence server-side — ts/board.ts saves the click to localStorage keyed by
   board, see board-view-meta below) — switching is reversible and never mutates part_of
   (tag-grouping-is-projection). *@
<div class="mb-3 flex flex-wrap items-center gap-1" data-testid="board-view-controls">
	<span class="text-xs opacity-60 mr-1">view:</span>
	@foreach (var entry in PetBox.Web.Rendering.BoardViewModeRegistry.Entries.Where(e => !e.Hidden))
	{
		// Highlight tracks what's ACTUALLY rendered (Model.ContentPartialName), not the
		// requested/resolved mode name: a resolved mode whose content pane degrades (e.g. tags
		// with no/invalid `by` — still reachable by direct URL even though hidden from the
		// switcher) renders a DIFFERENT partial than its own entry, so comparing against
		// ResolvedViewMode would leave every visible button dark in that case. ContentPartialName
		// always equals exactly one entry's PartialName (a degrade included — e.g. it becomes
		// "_BoardViewTree", matching the tree entry here).
		var active = entry.PartialName == Model.ContentPartialName;
		<a href="?view=@entry.Key" class="btn btn-xs @(active ? "btn-active" : "btn-ghost")" data-testid="view-@entry.Key" data-view-link data-view-mode="@entry.Key">@entry.Label</a>
	}
</div>

@* board-view-persistence: the key ts/board.ts saves the chosen mode under (scoped per board,
   since defaultView differs by kind) and what the server actually resolved/rendered this
   load, so the client can reconcile a saved-but-different choice on the NEXT navigation
   without the server needing to read localStorage. Hidden — data only, no visible content. *@
<div class="hidden" data-testid="board-view-meta" data-board-key="@Model.ProjectKey/@Model.Board" data-resolved-view="@Model.ResolvedViewMode" data-resolved-by="@curBy"></div>

<partial name="@Model.ContentPartialName" model="Model" />

@if (Model.WorkflowJson is not null)
{
	<partial name="_WorkflowModal" model="Model.WorkflowJson" />
}
