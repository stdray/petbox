@page "/ui/{workspaceKey}/{projectKey}/tasks/{board}"
@model PetBox.Web.Pages.ProjectHome.TaskBoardModel
@{
	ViewData["Title"] = $"{Model.Board} — Tasks";
}

@functions {
	static string StatusBadge(PetBox.Tasks.Data.PlanStatus s) => s switch
	{
		PetBox.Tasks.Data.PlanStatus.Done => "badge-success",
		PetBox.Tasks.Data.PlanStatus.InProgress => "badge-info",
		PetBox.Tasks.Data.PlanStatus.Blocked => "badge-error",
		PetBox.Tasks.Data.PlanStatus.Deferred or PetBox.Tasks.Data.PlanStatus.Cancelled => "badge-ghost",
		_ => "badge-neutral",
	};
}

<div class="mb-4 flex items-baseline gap-3 flex-wrap">
	<a href="@Routes.ProjectTasks(Model.WorkspaceKey, Model.ProjectKey)" class="link link-hover opacity-70" data-testid="board-breadcrumb">tasks</a>
	<span class="opacity-40">/</span>
	<h1 class="text-2xl font-semibold font-mono" data-testid="board-title">@Model.Board</h1>
	<span class="badge badge-ghost">@Model.Nodes.Count node(s)</span>
</div>

<form method="post" asp-page-handler="Create" class="mb-4 flex flex-col gap-2" data-testid="task-create">
	<textarea name="name" required maxlength="2000" rows="2" class="textarea textarea-bordered textarea-sm w-full" placeholder="New task → incoming…" data-testid="task-create-name"></textarea>
	<div class="flex items-center gap-2">
		<select name="priority" class="select select-bordered select-sm" data-testid="task-create-priority" aria-label="Priority">
			<option value="10">High</option>
			<option value="50" selected>Normal</option>
			<option value="90">Low</option>
		</select>
		<button type="submit" class="btn btn-sm btn-primary" data-testid="task-create-submit">Add</button>
	</div>
</form>

@if (Model.Nodes.Count == 0)
{
	<div class="alert" data-testid="board-empty">This board has no active plan nodes.</div>
}
else
{
	<div x-data="{ activeOnly: JSON.parse(localStorage.getItem('tasksActiveOnly') ?? 'true') }" x-init="$watch('activeOnly', v => localStorage.setItem('tasksActiveOnly', v))">
	<label class="label cursor-pointer justify-start gap-2 text-xs mb-2 w-fit">
		<input type="checkbox" class="toggle toggle-sm" x-model="activeOnly" data-testid="active-only-toggle" />
		<span>active only</span>
	</label>
	<ul class="flex flex-col gap-2" data-testid="board-nodes">
		@foreach (var n in Model.Nodes)
		{
			var id = PetBox.Tasks.Data.TaskNodeId.TryParse(n.Key, out var p) ? p : null;
			var depth = id?.Depth ?? 1;
			var leaf = id is null ? n.Key : (id.TaskKey ?? id.WaveKey ?? id.PhaseKey);
			var parent = id?.ParentKey;
			var closed = n.Status is PetBox.Tasks.Data.PlanStatus.Done or PetBox.Tasks.Data.PlanStatus.Cancelled;
			// A closed node hides under "active only" — unless it still has open
			// descendants, in which case it stays so its children aren't orphaned.
			var keepVisible = !closed || Model.ClosedWithActiveDescendant.Contains(n.Key);
			var showExpr = keepVisible ? "true" : "!activeOnly";
			<li class="card bg-base-200 border border-base-300" data-testid="plan-node" data-node-key="@n.Key" data-depth="@depth" data-closed="@closed.ToString().ToLowerInvariant()" style="margin-left:@((depth - 1) * 1.5)rem" x-show="@showExpr">
				<div class="card-body p-3">
					<div class="flex items-baseline justify-between gap-2">
						<div class="min-w-0 flex items-baseline gap-2 flex-wrap">
							@if (!string.IsNullOrEmpty(n.Name))
							{
								<span class="font-semibold" data-testid="node-name">@n.Name</span>
							}
							<span class="font-mono text-xs opacity-50">
								@if (parent is not null)
								{
									<span>@parent / </span>
								}
								<span data-testid="node-leaf">@leaf</span>
							</span>
						</div>
						<span class="badge @StatusBadge(n.Status) badge-sm" data-testid="node-status">@n.Status</span>
					</div>
					@if (!string.IsNullOrEmpty(n.Body))
					{
						<p class="text-sm opacity-80 whitespace-pre-wrap mt-1">@n.Body</p>
					}
					@if (!string.IsNullOrEmpty(n.CommitRef))
					{
						<div class="text-xs opacity-50 font-mono mt-1">@n.CommitRef</div>
					}
				</div>
			</li>
		}
	</ul>
	</div>
}
