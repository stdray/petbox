@model PetBox.Web.Pages.ProjectHome.TaskBoardModel
@* Table view mode (board-view-mode-framework): a flat row-per-node table. Columns follow
   Model.Fields (board-view-fields) — this partial's only job is projecting Model.Nodes into
   TaskTableRow — the actual table markup + column gating + sort/filter wiring live in the
   REUSABLE _TaskTable.cshtml (Pages/Shared), the same partial the cross-scope search results
   page renders (with its extra workspace/project/board columns switched on) — one table
   component, not two. *@
@{
	// board-filters-server-state: table is ONE FLAT sort scope (unlike tree/outline's DFS sibling
	// order) — Model.Nodes is already DFS-ordered for the hierarchical panes, so table re-sorts it
	// flat here, matching what the client's own reorderDom always did for this view (roots-only,
	// no part_of nesting to respect).
	var sortComparer = PetBox.Web.Pages.ProjectHome.TaskBoardModel.SortComparer(Model.SortBy, Model.SortDesc);
	var rows = Model.Nodes.OrderBy(n => n, sortComparer).ThenBy(n => n.Key, StringComparer.Ordinal).Select(n =>
	{
		var badge = new StatusBadgeModel(Model.Runtime, Model.KindSlug, n.Status);
		var closed = Model.Runtime.IsTerminalStatus(Model.KindSlug, n.Status);
		// board-terminal-negative-visible review finding: strikethrough scoped to the spec board.
		// IsSpecKind, NOT PresetKind(...) == BoardKind.Spec (production regression, 2026-07):
		// PresetKind nulls out for any DEFINED kind, and a real project's spec board is
		// virtually always definition-resolved — see MethodologyRuntime.IsSpecKind's own comment.
		var isSpecBoard = Model.Runtime.IsSpecKind(Model.KindSlug);
		return new TaskTableRow(
			NodeId: n.NodeId, Key: n.Key, Title: n.Title,
			Url: Routes.TaskBoardNodeBySlug(Model.WorkspaceKey, Model.ProjectKey, Model.Board, n.Key),
			Type: n.Type,
			StatusSlug: n.Status, StatusDisplay: badge.Display, StatusCssClass: badge.CssClass, StatusShow: badge.Show,
			Closed: closed,
			Priority: n.Priority, Tags: n.Tags, CreatedAt: n.CreatedAt, UpdatedAt: n.UpdatedAt,
			Delivery: n.Delivery,
			TerminalCancel: Model.Runtime.StatusKindOf(Model.KindSlug, n.Status) == StatusKind.TerminalCancel,
			IsSpecBoard: isSpecBoard,
			BlockedBy: n.BlockedBy, Body: n.Body,
			// board-filters-server-state: table has no hierarchy to orphan a child out of, so
			// (unlike PlanNodeCard) there's no keepVisible exception — a closed row hides under
			// active-only, period. No collapse either (table never showed one).
			Hidden: Model.ActiveOnly && closed);
	}).ToList();
}
<partial name="_TaskTable" model="new TaskTableModel(rows, ShowScopeColumns: false, Fields: Model.Fields, WorkspaceKey: Model.WorkspaceKey, ProjectKey: Model.ProjectKey, ActiveOnly: Model.ActiveOnly, SortBy: Model.SortBy, SortDesc: Model.SortDesc)" />
