@model PetBox.Web.Pages.ProjectHome.TaskBoardModel
@* Tree view mode (board-view-modes): the stored part_of tree, DFS-ordered — the historical
   default. One entry in BoardViewModeRegistry ("tree" -> this partial); TaskBoard.cshtml
   dispatches to it without knowing anything mode-specific. Client interactivity (collapse /
   filter / active-only / sort) is ts/board.ts, keyed off the data-* attrs _PlanNodeCard
   renders on each <li data-node-id>. *@
@if (Model.Nodes.Count == 0)
{
	<div class="alert" data-testid="board-empty">This board has no active plan nodes.</div>
}
else
{
	// A node has children when some other node's part_of parent is its NodeId — only those
	// get a collapse caret. (Visibility/collapse/filter is applied client-side by ts/board.ts;
	// active-only + collapsed state persist in localStorage.)
	var parentIds = Model.Nodes.Where(x => x.ParentNodeId is not null).Select(x => x.ParentNodeId!).ToHashSet(StringComparer.Ordinal);
	var filterSortModel = new PetBox.Web.Pages.Shared.BoardFilterSortModel(Fields: Model.Fields, ViewMode: BoardViewModeNames.Tree, SortHint: "sort branches:");

	<partial name="_BoardFilterSort" model="filterSortModel" />
	@* data-sort-scope (board-sort): the DFS-flat <li> list IS the single reorder scope for this
	   pane — ts/board.ts walks it depth-first via each row's data-parent-id, so "sort" reorders
	   sibling branches in place without touching the part_of nesting (finding D11). *@
	<ul class="flex flex-col gap-2" data-testid="board-nodes" data-sort-scope>
		@foreach (var n in Model.Nodes)
		{
			var closed = Model.Runtime.IsTerminalStatus(Model.KindSlug, n.Status);
			// A closed node hides under "active only" — unless it still has open
			// descendants, in which case it stays so its children aren't orphaned.
			var keepVisible = !closed || Model.ClosedWithActiveDescendant.Contains(n.NodeId);
			var hasChildren = parentIds.Contains(n.NodeId);
			Model.CommentThreads.TryGetValue(n.NodeId, out var thread);
			<partial name="_PlanNodeCard" model="new PetBox.Web.Pages.ProjectHome.TaskBoardModel.PlanNodeCard(Model.WorkspaceKey, Model.ProjectKey, Model.Board, Model.Runtime, Model.KindSlug, n, n.Depth, closed, keepVisible, hasChildren, thread, Model.Fields, Model.CommitUrlTemplate, Model.NodeRefs, Model.MemoryRefs)" />
		}
	</ul>
}
