@page "/ui/{workspaceKey}/{projectKey}/sessions/{sessionId}"
@model PetBox.Web.Pages.ProjectHome.SessionModel
@{
	ViewData["Title"] = $"{Model.SessionId} — Session";
}

<div class="mb-4 flex items-baseline gap-3 flex-wrap">
	<a href="@Routes.ProjectSessions(Model.WorkspaceKey, Model.ProjectKey)" class="link link-hover opacity-70" data-testid="session-breadcrumb">sessions</a>
	<span class="opacity-40">/</span>
	<h1 class="text-2xl font-semibold font-mono truncate" data-testid="session-title">@Model.SessionId</h1>
	@if (Model.Session is not null)
	{
		<span class="badge badge-ghost" data-testid="session-agent">@Model.Session.Agent</span>
	}
</div>

@if (Model.Session is not null)
{
	@* Session content is GFM markdown (agents write `### user` / `### assistant` role headers,
	   code blocks, lists). Render it via the ONE shared markdown renderer (_MdBody / IMarkdownRenderer)
	   — the same server-side, sanitized pipeline node bodies and comments use — so role headers become
	   real headings and code blocks/long lines render sanely, instead of a raw `<pre>` blob. *@
	<article class="card bg-base-200 border border-base-300" data-testid="session-content">
		<div class="card-body p-4">
			<partial name="_MdBody" model="@(new PetBox.Web.Pages.Shared.MdBodyModel { Body = Model.Session.Content, TestId = "session-body" })" />
		</div>
	</article>
}
