@model PetBox.Web.Pages.ProjectHome.TaskBoardModel
@* Kanban view mode (board-view-mode-framework): cards grouped into one column per FSM status.
   Columns come from Model.KanbanColumns (TaskBoardModel.LoadAsync, sourced from WorkflowBlocks)
   — NEVER hardcoded, so this ONE partial renders correctly for any methodology's own statuses,
   not just work's Pending/InProgress/Review/Done. View only: no drag-and-drop (a status change
   is a write through the FSM guards — a separate story).
   board-node-filter / board-sort: the SAME filter+sort bar every mode gets (_BoardFilterSort),
   plus the full ts/board.ts data-* contract on every card (_PlanNodeCard's shape, restated here
   since a kanban card isn't a _PlanNodeCard) so filtering/active-only/sort work identically to
   tree/table. Sort is PER COLUMN: each column's own <ul data-sort-scope> is an independent
   reorder scope (board.ts groups scopes by DOM containment) — cards have no data-parent-id, so
   within a scope they're all "roots" and sort flat, matching "order of cards within column". *@
@if (Model.Nodes.Count == 0)
{
	<div class="alert" data-testid="board-empty">This board has no active plan nodes.</div>
}
else
{
	var byStatus = Model.Nodes
		.GroupBy(n => n.Status, StringComparer.OrdinalIgnoreCase)
		.ToDictionary(g => g.Key, g => (IReadOnlyList<PlanNodeView>)g
			.OrderBy(n => n.Priority).ThenBy(n => n.Key, StringComparer.Ordinal).ToList(),
			StringComparer.OrdinalIgnoreCase);
	var knownSlugs = Model.KanbanColumns.Select(c => c.Slug).ToHashSet(StringComparer.OrdinalIgnoreCase);
	// A node whose status isn't in ANY workflow block (a stale/legacy slug the FSM no longer
	// declares) still needs a home on the board — an extra "other" column rather than a silently
	// dropped card.
	var strayCount = Model.Nodes.Count(n => !knownSlugs.Contains(n.Status));
	var filterSortModel = new PetBox.Web.Pages.Shared.BoardFilterSortModel(Fields: Model.Fields, ViewMode: BoardViewModeNames.Kanban, SortHint: "sort within column:");

	<partial name="_BoardFilterSort" model="filterSortModel" />
	<div class="flex gap-3 overflow-x-auto pb-2" data-testid="board-kanban">
		@foreach (var col in Model.KanbanColumns)
		{
			var nodesInCol = byStatus.TryGetValue(col.Slug, out var list) ? list : [];
			<div class="flex-none w-72" data-testid="kanban-column" data-status="@col.Slug">
				@* pl-4: the card below is `rounded-box` (1rem radius) — its rounded top-left
				   corner curves away from the column's true left edge, so a header flush at
				   x=0 reads as shifted left of the card content under it. 1rem matches
				   card-compact's own body padding, so the column name lines up with where the
				   card's rounding ends and its text actually starts (kanban-header-align,
				   live UI review finding). *@
				<div class="font-semibold text-sm mb-2 pl-4 flex items-center gap-2">
					<span>@col.Name</span>
					<span class="badge badge-ghost badge-xs" data-testid="kanban-column-count">@nodesInCol.Count</span>
				</div>
				<ul class="flex flex-col gap-2 min-h-8" data-sort-scope>
					@foreach (var n in nodesInCol)
					{
						var nodeUrl = Routes.TaskBoardNodeBySlug(Model.WorkspaceKey, Model.ProjectKey, Model.Board, n.Key);
						var closed = Model.Runtime.IsTerminalStatus(Model.KindSlug, n.Status);
						// board-terminal-negative-visible: same invariant as the tree card — a
						// terminal-cancel node's title is struck through regardless of Model.Fields.Status.
						var terminalCancel = Model.Runtime.StatusKindOf(Model.KindSlug, n.Status) == StatusKind.TerminalCancel;
						// board-body-truncate: a kanban card never renders the body (unlike the tree
						// card) — data-search omits n.Body so filtering can't leak it into the HTML.
						var search = $"{n.Title} {n.Key} {string.Join(' ', n.Tags)}".ToLowerInvariant();
						<li class="card card-compact bg-base-200 border border-base-300" data-testid="kanban-card" data-node-key="@n.Key" data-node-id="@n.NodeId" data-status="@n.Status" data-type="@n.Type" data-priority="@n.Priority" data-title="@n.Title" data-search="@search" data-created="@(n.CreatedAt?.ToString("o") ?? "")" data-updated="@(n.UpdatedAt?.ToString("o") ?? "")" data-closed="@closed.ToString().ToLowerInvariant()" data-keep-visible="false" data-terminal-cancel="@terminalCancel.ToString().ToLowerInvariant()">
							<div class="card-body p-2 gap-1">
								<a href="@nodeUrl" class="font-semibold link link-hover text-sm @(terminalCancel ? "line-through opacity-60" : "")" data-testid="node-name">@n.Title</a>
								<div class="flex items-center gap-1 flex-wrap text-xs opacity-70">
									@if (Model.Fields.Type)
									{
										<span class="badge badge-ghost badge-xs" data-testid="node-type">@n.Type</span>
									}
									@if (Model.Fields.Priority)
									{
										<span class="font-mono" data-testid="node-priority" title="priority">P@(n.Priority)</span>
									}
									@if (Model.Fields.Status)
									{
										<partial name="_StatusBadge" model="new StatusBadgeModel(Model.Runtime, Model.KindSlug, n.Status)" />
									}
									@if (Model.Fields.Delivery && n.Delivery is not null)
									{
										<partial name="_DeliveryBadge" model="@(new DeliveryBadgeModel(n.Delivery) { Size = "badge-xs" })" />
									}
									@if (Model.Fields.UpdatedAt && n.UpdatedAt is not null)
									{
										<time class="local-time" datetime="@n.UpdatedAt.Value.ToString("o")" data-testid="node-updated">@n.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm")</time>
									}
								</div>
								@if (Model.Fields.Tags && n.Tags.Count > 0)
								{
									<div class="flex flex-wrap gap-1" data-testid="node-tags">
										@foreach (var t in n.Tags)
										{
											<span class="badge badge-outline badge-xs">@t</span>
										}
									</div>
								}
								@if (Model.Fields.BlockedBy)
								{
									<partial name="_BlockedByChips" model="new BlockedByChipsModel(Model.WorkspaceKey, Model.ProjectKey, n.BlockedBy)" />
								}
								@if (Model.Fields.Body && !string.IsNullOrEmpty(n.Body))
								{
									<partial name="_MdBody" model="@(new MdBodyModel { Body = n.Body, TestId = "node-body", ExtraClasses = "max-h-16 overflow-hidden text-xs", CommitUrlTemplate = Model.CommitUrlTemplate, NodeRefs = Model.NodeRefs, MemoryRefs = Model.MemoryRefs })" />
								}
							</div>
						</li>
					}
				</ul>
			</div>
		}
		@if (strayCount > 0)
		{
			<div class="flex-none w-72" data-testid="kanban-column" data-status="">
				<div class="font-semibold text-sm mb-2 pl-4 opacity-60">other</div>
				<ul class="flex flex-col gap-2 min-h-8" data-sort-scope>
					@foreach (var n in Model.Nodes.Where(n => !knownSlugs.Contains(n.Status)).OrderBy(n => n.Priority).ThenBy(n => n.Key, StringComparer.Ordinal))
					{
						var nodeUrl = Routes.TaskBoardNodeBySlug(Model.WorkspaceKey, Model.ProjectKey, Model.Board, n.Key);
						var closed = Model.Runtime.IsTerminalStatus(Model.KindSlug, n.Status);
						var terminalCancel = Model.Runtime.StatusKindOf(Model.KindSlug, n.Status) == StatusKind.TerminalCancel;
						// board-body-truncate: a kanban card never renders the body (unlike the tree
						// card) — data-search omits n.Body so filtering can't leak it into the HTML.
						var search = $"{n.Title} {n.Key} {string.Join(' ', n.Tags)}".ToLowerInvariant();
						<li class="card card-compact bg-base-200 border border-base-300" data-testid="kanban-card" data-node-key="@n.Key" data-node-id="@n.NodeId" data-status="@n.Status" data-type="@n.Type" data-priority="@n.Priority" data-title="@n.Title" data-search="@search" data-created="@(n.CreatedAt?.ToString("o") ?? "")" data-updated="@(n.UpdatedAt?.ToString("o") ?? "")" data-closed="@closed.ToString().ToLowerInvariant()" data-keep-visible="false" data-terminal-cancel="@terminalCancel.ToString().ToLowerInvariant()">
							<div class="card-body p-2 gap-1">
								<a href="@nodeUrl" class="font-semibold link link-hover text-sm @(terminalCancel ? "line-through opacity-60" : "")" data-testid="node-name">@n.Title</a>
								<span class="font-mono text-xs opacity-70" title="unrecognized status">@n.Status</span>
							</div>
						</li>
					}
				</ul>
			</div>
		}
	</div>
}
