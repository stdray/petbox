@model PetBox.Web.Pages.ProjectHome.TaskBoardModel
@* Kanban view mode (board-view-mode-framework): cards grouped into one column per FSM status.
   Columns come from Model.KanbanColumns (TaskBoardModel.LoadAsync, sourced from WorkflowBlocks)
   — NEVER hardcoded, so this ONE partial renders correctly for any methodology's own statuses,
   not just work's Pending/InProgress/Review/Done. View only: no drag-and-drop (a status change
   is a write through the FSM guards — a separate story).
   board-node-filter / board-sort: the SAME filter+sort bar every mode gets (_BoardFilterSort),
   plus the full ts/board.ts data-* contract on every card (_PlanNodeCard's shape, restated here
   since a kanban card isn't a _PlanNodeCard) so filtering/active-only/sort work identically to
   tree/table. Sort is PER COLUMN: each column's own <ul data-sort-scope> is an independent
   reorder scope (board.ts groups scopes by DOM containment) — cards have no data-parent-id, so
   within a scope they're all "roots" and sort flat, matching "order of cards within column". *@
@if (Model.Nodes.Count == 0)
{
	<div class="alert" data-testid="board-empty">This board has no active plan nodes.</div>
}
else
{
	// board-filters-server-state: sort WITHIN each column uses the server-resolved comparator
	// (default reproduces the old hardcoded Priority-then-Key order exactly).
	var sortComparer = PetBox.Web.Pages.ProjectHome.TaskBoardModel.SortComparer(Model.SortBy, Model.SortDesc);
	var byStatus = Model.Nodes
		.GroupBy(n => n.Status, StringComparer.OrdinalIgnoreCase)
		.ToDictionary(g => g.Key, g => (IReadOnlyList<PlanNodeView>)g
			.OrderBy(n => n, sortComparer).ThenBy(n => n.Key, StringComparer.Ordinal).ToList(),
			StringComparer.OrdinalIgnoreCase);
	var knownSlugs = Model.KanbanColumns.Select(c => c.Slug).ToHashSet(StringComparer.OrdinalIgnoreCase);
	// A node whose status isn't in ANY workflow block (a stale/legacy slug the FSM no longer
	// declares) still needs a home on the board — an extra "other" column rather than a silently
	// dropped card.
	var strayCount = Model.Nodes.Count(n => !knownSlugs.Contains(n.Status));
	var filterSortModel = new PetBox.Web.Pages.Shared.BoardFilterSortModel(Fields: Model.Fields, ViewMode: BoardViewModeNames.Kanban, SortHint: "sort within column:", ActiveOnly: Model.ActiveOnly, SortBy: Model.SortBy, SortDesc: Model.SortDesc);
	// board-terminal-negative-visible review finding: strikethrough scoped to the spec board only
	// — everywhere else the status is already a displayable property (fields dialog toggle).
	// IsSpecKind, NOT PresetKind(...) == BoardKind.Spec (production regression, 2026-07):
	// PresetKind nulls out for any DEFINED kind, and a real project's spec board is virtually
	// always definition-resolved — see MethodologyRuntime.IsSpecKind's own comment.
	var isSpecBoard = Model.Runtime.IsSpecKind(Model.KindSlug);

	<partial name="_BoardFilterSort" model="filterSortModel" />
	<div class="flex gap-3 overflow-x-auto pb-2" data-testid="board-kanban">
		@foreach (var col in Model.KanbanColumns)
		{
			var nodesInCol = byStatus.TryGetValue(col.Slug, out var list) ? list : [];
			<div class="flex-none w-72" data-testid="kanban-column" data-status="@col.Slug">
				@* pl-4: the card below is `rounded-box` (1rem radius) — its rounded top-left
				   corner curves away from the column's true left edge, so a header flush at
				   x=0 reads as shifted left of the card content under it. 1rem matches
				   card-compact's own body padding, so the column name lines up with where the
				   card's rounding ends and its text actually starts (kanban-header-align,
				   live UI review finding). *@
				<div class="font-semibold text-sm mb-2 pl-4 flex items-center gap-2">
					<span>@col.Name</span>
					<span class="badge badge-ghost badge-xs" data-testid="kanban-column-count">@nodesInCol.Count</span>
				</div>
				<ul class="flex flex-col gap-2 min-h-8" data-sort-scope>
					@foreach (var n in nodesInCol)
					{
						var nodeUrl = Routes.TaskBoardNodeBySlug(Model.WorkspaceKey, Model.ProjectKey, Model.Board, n.Key);
						var closed = Model.Runtime.IsTerminalStatus(Model.KindSlug, n.Status);
						// board-terminal-negative-visible: same invariant as the tree card — a
						// terminal-cancel node's title is struck through regardless of Model.Fields.Status.
						var terminalCancel = Model.Runtime.StatusKindOf(Model.KindSlug, n.Status) == StatusKind.TerminalCancel;
						// kanban-blocked-signal: blocked-ness is read off the DATA (a non-empty
						// BlockedBy edge list), never off the status name/slug — a work-preset node is
						// only ever Blocked WITH a non-empty BlockedBy (RequireBlockersAsync enforces
						// it), but a node can also carry blockers while sitting in another status/column
						// under a different methodology, and the signal must still fire there. Same
						// invariant class as terminalCancel above: it survives Model.Fields.BlockedBy
						// being off (board-view-fields is about the DETAIL — the chip links to who's
						// blocking — not about whether the card admits it's blocked at all).
						var blocked = n.BlockedBy is { Count: > 0 };
						// kanban-blocked-signal review finding: the symmetric counterpart — a node
						// that blocks others gets its own chip, same data source (n.Blocks, the
						// outgoing "blocks" edges), same quiet chip-level weight, no frame.
						var blockingCount = n.Blocks?.Count ?? 0;
						var blocking = blockingCount > 0;
						// board-body-truncate: a kanban card never renders the body (unlike the tree
						// card) — data-search omits n.Body so filtering can't leak it into the HTML.
						var search = $"{n.Title} {n.Key} {string.Join(' ', n.Tags)}".ToLowerInvariant();
						// board-filters-server-state: active-only only — kanban never showed a
						// hierarchy (no data-parent-id on a card), so collapse doesn't apply here,
						// matching what the client-side mechanism this replaces actually did.
						var hidden = Model.ActiveOnly && closed;
						@* kanban-blocked-signal review finding: no border/frame highlight and no
						   loud/saturated background behind the blocked chip anymore — both blocked
						   and blocking are chip-level signals (badge-outline, same weight as tags/
						   date), not a card-frame treatment. *@
						<li class="card card-compact bg-base-200 border border-base-300" data-testid="kanban-card" data-node-key="@n.Key" data-node-id="@n.NodeId" data-status="@n.Status" data-type="@n.Type" data-priority="@n.Priority" data-title="@n.Title" data-search="@search" data-created="@(n.CreatedAt?.ToString("o") ?? "")" data-updated="@(n.UpdatedAt?.ToString("o") ?? "")" data-closed="@closed.ToString().ToLowerInvariant()" data-keep-visible="false" data-terminal-cancel="@terminalCancel.ToString().ToLowerInvariant()" data-blocked="@blocked.ToString().ToLowerInvariant()" data-blocking="@blocking.ToString().ToLowerInvariant()" style="display:@(hidden ? "none" : "")">
							<div class="card-body p-2 gap-1">
								<div class="flex items-start gap-1">
									<a href="@nodeUrl" class="font-semibold link link-hover text-sm @(terminalCancel && isSpecBoard ? "line-through opacity-60" : "")" data-testid="node-name">@n.Title</a>
									@if (blocked)
									{
										<span class="badge badge-outline badge-xs shrink-0" data-testid="node-blocked-badge" title="blocked">⛔ blocked</span>
									}
									@if (blockingCount > 0)
									{
										<span class="badge badge-outline badge-xs shrink-0" data-testid="node-blocking-badge" title="blocking @blockingCount">🔒 blocking @blockingCount</span>
									}
								</div>
								@* board-fields-slug-missing: the node key never rendered on a kanban card at all
								   before this field existed — every other view mode already showed it. Click-to-
								   copy reuses the SAME global [data-copy] handler as the node detail page
								   (ts/config.ts, document-level; wired unconditionally via initConfigPage in
								   ts/site.ts, so it's live here without extra wiring). *@
								@if (Model.Fields.Slug)
								{
									<div class="flex items-center gap-1">
										<a href="@nodeUrl" class="font-mono text-xs opacity-50 link link-hover" data-testid="node-leaf">@n.Key</a>
										<button type="button" class="btn btn-ghost btn-xs px-1 leading-none opacity-50 hover:opacity-100" data-copy="@n.Key" data-testid="node-slug-copy" title="Copy slug" aria-label="Copy slug">⧉</button>
									</div>
								}
								<div class="flex items-center gap-1 flex-wrap text-xs opacity-70">
									@if (Model.Fields.Type)
									{
										<span class="badge badge-ghost badge-xs" data-testid="node-type">@n.Type</span>
									}
									@if (Model.Fields.Priority)
									{
										<span class="font-mono" data-testid="node-priority" title="priority">P@(n.Priority)</span>
									}
									@if (Model.Fields.Status)
									{
										<partial name="_StatusBadge" model="new StatusBadgeModel(Model.Runtime, Model.KindSlug, n.Status)" />
									}
									@if (Model.Fields.Delivery && n.Delivery is not null)
									{
										<partial name="_DeliveryBadge" model="@(new DeliveryBadgeModel(n.Delivery) { Size = "badge-xs" })" />
									}
									@if (Model.Fields.UpdatedAt && n.UpdatedAt is not null)
									{
										<time class="local-time" datetime="@n.UpdatedAt.Value.ToString("o")" data-testid="node-updated">@n.UpdatedAt.Value.ToString("yyyy-MM-dd HH:mm")</time>
									}
								</div>
								@if (Model.Fields.Tags && n.Tags.Count > 0)
								{
									<div class="flex flex-wrap gap-1" data-testid="node-tags">
										@foreach (var t in n.Tags)
										{
											<span class="badge badge-outline badge-xs">@t</span>
										}
									</div>
								}
								@if (Model.Fields.BlockedBy)
								{
									<partial name="_BlockedByChips" model="new BlockedByChipsModel(Model.WorkspaceKey, Model.ProjectKey, n.BlockedBy)" />
								}
								@if (Model.Fields.Body && !string.IsNullOrEmpty(n.Body))
								{
									<partial name="_MdBody" model="@(new MdBodyModel { Body = n.Body, TestId = "node-body", ExtraClasses = "max-h-16 overflow-hidden text-xs", CommitUrlTemplate = Model.CommitUrlTemplate, NodeRefs = Model.NodeRefs, MemoryRefs = Model.MemoryRefs })" />
								}
							</div>
						</li>
					}
				</ul>
			</div>
		}
		@if (strayCount > 0)
		{
			<div class="flex-none w-72" data-testid="kanban-column" data-status="">
				<div class="font-semibold text-sm mb-2 pl-4 opacity-60">other</div>
				<ul class="flex flex-col gap-2 min-h-8" data-sort-scope>
					@foreach (var n in Model.Nodes.Where(n => !knownSlugs.Contains(n.Status)).OrderBy(n => n, sortComparer).ThenBy(n => n.Key, StringComparer.Ordinal))
					{
						var nodeUrl = Routes.TaskBoardNodeBySlug(Model.WorkspaceKey, Model.ProjectKey, Model.Board, n.Key);
						var closed = Model.Runtime.IsTerminalStatus(Model.KindSlug, n.Status);
						var terminalCancel = Model.Runtime.StatusKindOf(Model.KindSlug, n.Status) == StatusKind.TerminalCancel;
						// kanban-blocked-signal: same data-driven invariant as the main columns above —
						// a stray-status node can still carry blockers.
						var blocked = n.BlockedBy is { Count: > 0 };
						// kanban-blocked-signal review finding: symmetric "blocking" chip, same as
						// the main columns above.
						var blockingCount = n.Blocks?.Count ?? 0;
						var blocking = blockingCount > 0;
						// board-body-truncate: a kanban card never renders the body (unlike the tree
						// card) — data-search omits n.Body so filtering can't leak it into the HTML.
						var search = $"{n.Title} {n.Key} {string.Join(' ', n.Tags)}".ToLowerInvariant();
						var hidden = Model.ActiveOnly && closed;
						@* kanban-blocked-signal review finding: no border/frame highlight, no loud
						   background — chip-level signals only, same as the main columns above. *@
						<li class="card card-compact bg-base-200 border border-base-300" data-testid="kanban-card" data-node-key="@n.Key" data-node-id="@n.NodeId" data-status="@n.Status" data-type="@n.Type" data-priority="@n.Priority" data-title="@n.Title" data-search="@search" data-created="@(n.CreatedAt?.ToString("o") ?? "")" data-updated="@(n.UpdatedAt?.ToString("o") ?? "")" data-closed="@closed.ToString().ToLowerInvariant()" data-keep-visible="false" data-terminal-cancel="@terminalCancel.ToString().ToLowerInvariant()" data-blocked="@blocked.ToString().ToLowerInvariant()" data-blocking="@blocking.ToString().ToLowerInvariant()" style="display:@(hidden ? "none" : "")">
							<div class="card-body p-2 gap-1">
								<div class="flex items-start gap-1">
									<a href="@nodeUrl" class="font-semibold link link-hover text-sm @(terminalCancel && isSpecBoard ? "line-through opacity-60" : "")" data-testid="node-name">@n.Title</a>
									@if (blocked)
									{
										<span class="badge badge-outline badge-xs shrink-0" data-testid="node-blocked-badge" title="blocked">⛔ blocked</span>
									}
									@if (blockingCount > 0)
									{
										<span class="badge badge-outline badge-xs shrink-0" data-testid="node-blocking-badge" title="blocking @blockingCount">🔒 blocking @blockingCount</span>
									}
								</div>
								@if (Model.Fields.Slug)
								{
									<div class="flex items-center gap-1">
										<a href="@nodeUrl" class="font-mono text-xs opacity-50 link link-hover" data-testid="node-leaf">@n.Key</a>
										<button type="button" class="btn btn-ghost btn-xs px-1 leading-none opacity-50 hover:opacity-100" data-copy="@n.Key" data-testid="node-slug-copy" title="Copy slug" aria-label="Copy slug">⧉</button>
									</div>
								}
								<span class="font-mono text-xs opacity-70" title="unrecognized status">@n.Status</span>
								@if (blocked && Model.Fields.BlockedBy)
								{
									<partial name="_BlockedByChips" model="new BlockedByChipsModel(Model.WorkspaceKey, Model.ProjectKey, n.BlockedBy)" />
								}
							</div>
						</li>
					}
				</ul>
			</div>
		}
	</div>
}
