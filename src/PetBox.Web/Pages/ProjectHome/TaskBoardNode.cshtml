@page "/ui/{workspaceKey}/{projectKey}/tasks/node/{nodeId}"
@model PetBox.Web.Pages.ProjectHome.TaskBoardNodeModel
@{
	var node = Model.Detail.Node;
	ViewData["Title"] = string.IsNullOrEmpty(node.Title) ? node.Key : node.Title;

	var nodeKindName = Model.Detail.Kind; // the board's resolved KindName (custom kind verbatim)
	var nodeIsSimple = Model.Runtime.PresetKind(Model.Detail.Kind) == PetBox.Tasks.Workflow.BoardKind.Simple;
	// Make the board kind explicit so its statuses read as a deliberate kind, not "broken".
	var nodeKindBadgeClass = nodeIsSimple ? "badge-info badge-outline" : "badge-neutral";
	var nodeKindTitle = nodeIsSimple
		? "simple board — lightweight preset: statuses Todo|InProgress|Blocked|Done|Cancelled, free transitions, types task|bug|feature|chore|issue"
		: $"{nodeKindName} board — statuses follow the {nodeKindName} workflow";
}

@functions {
	// StatusKind -> daisyUI badge (presentation; domain owns the StatusKind). Mirrors TaskBoard.
	// The kind is resolved through the runtime per the board's kind (custom statuses colour right).
	static string StatusBadge(PetBox.Tasks.Workflow.StatusKind? kind) => kind switch
	{
		PetBox.Tasks.Workflow.StatusKind.TerminalOk => "badge-success",
		PetBox.Tasks.Workflow.StatusKind.TerminalCancel => "badge-ghost",
		PetBox.Tasks.Workflow.StatusKind.Open => "badge-info",
		_ => "badge-neutral",
	};

	// Muted (outline) palette — delivery is context, not an alert (spec-board-status-noise #11).
	static string DeliveryBadge(string d) => d switch
	{
		"done" => "badge-success badge-outline",
		"in_progress" => "badge-warning badge-outline",
		"done_with_defects" => "badge-error badge-outline",
		_ => "badge-ghost",
	};
}

@* Breadcrumb: tasks / {board} / {ancestors…} / {this node}. The node is addressed by its
   stable id, so the trail is reconstructed from the part_of chain the service returns. *@
<div class="mb-4 flex items-center gap-2 flex-wrap text-sm" data-testid="node-breadcrumb">
	<a href="@Routes.ProjectTasks(Model.WorkspaceKey, Model.ProjectKey)" class="link link-hover opacity-70">tasks</a>
	<span class="opacity-40">/</span>
	<a href="@Routes.ProjectTaskBoard(Model.WorkspaceKey, Model.ProjectKey, Model.Detail.Board)" class="link link-hover opacity-70 font-mono">@Model.Detail.Board</a>
	<span class="badge @nodeKindBadgeClass badge-xs" data-testid="node-board-kind" data-kind="@nodeKindName" title="@nodeKindTitle">@nodeKindName</span>
	@foreach (var a in Model.Detail.Ancestors)
	{
		<span class="opacity-40">/</span>
		<a href="@Routes.TaskBoardNodeBySlug(Model.WorkspaceKey, Model.ProjectKey, Model.Detail.Board, a.Slug)" class="link link-hover opacity-70 font-mono">@(string.IsNullOrEmpty(a.Title) ? a.Slug : a.Title)</a>
	}
	<span class="opacity-40">/</span>
	<span class="font-mono opacity-90" data-testid="node-leaf">@node.Key</span>
</div>

@* Edit lives here on the node page (edit-respects-guards: the POST handlers route through
   ITasksService.UpsertAsync, the same door the MCP path uses). Status change is a plain POST form
   (works without JS); the read/edit toggle + markdown write/preview is wired imperatively by
   ts/nodeEdit.ts (no inline JS), mirroring ts/board.ts. The edit form starts hidden (inline style)
   so it doesn't flash before the script runs. *@
<div class="card bg-base-200 border border-base-300" data-testid="node-detail" data-node-id="@node.NodeId" data-board="@Model.Detail.Board">
	<div class="card-body p-4">

		@if (Model.Error is not null)
		{
			<div class="alert alert-error text-sm py-2" data-testid="node-edit-error" role="alert">@Model.Error</div>
		}

		<div class="flex items-baseline justify-between gap-2 flex-wrap">
			<h1 class="text-2xl font-semibold" data-testid="node-name">@(string.IsNullOrEmpty(node.Title) ? node.Key : node.Title)</h1>
			<div class="flex items-center gap-1 shrink-0 flex-wrap justify-end">
				@if (!string.IsNullOrEmpty(node.Type))
				{
					<span class="badge badge-ghost badge-sm" data-testid="node-type">@node.Type</span>
				}
				@* Opens the "View workflow" modal with this type's FSM graph (ts/workflow-viz.ts). *@
				<button type="button" class="btn btn-ghost btn-xs gap-1" data-testid="workflow-open" data-workflow-type="@node.Type" title="View this type's workflow graph">⤳ workflow</button>
				<span class="badge @StatusBadge(Model.Runtime.StatusKindOf(Model.Detail.Kind, node.Status)) badge-sm" data-testid="node-status">@node.Status</span>
				@if (Model.NextStatuses.Count > 0)
				{
					<form method="post" asp-page-handler="Status" class="inline-flex items-center gap-1" data-testid="node-status-form">
						<input type="hidden" name="version" value="@node.Version" />
						<select name="status" class="select select-bordered select-xs" data-testid="node-status-select" aria-label="Change status">
							@foreach (var s in Model.NextStatuses)
							{
								<option value="@s">@s</option>
							}
						</select>
						<button type="submit" class="btn btn-xs" data-testid="node-status-submit" title="change status">→</button>
					</form>
				}
				@if (node.Delivery is not null)
				{
					<span class="badge @DeliveryBadge(node.Delivery) badge-sm" data-testid="node-delivery" title="delivery — computed from linked tasks">@node.Delivery</span>
				}
				<button type="button" class="btn btn-ghost btn-xs" data-testid="node-edit-toggle">edit</button>
			</div>
		</div>

		@if (node.Tags.Count > 0)
		{
			<div class="flex flex-wrap gap-1 mt-1" data-testid="node-tags">
				@foreach (var tag in node.Tags)
				{
					<span class="badge badge-xs badge-outline font-mono">@tag</span>
				}
			</div>
		}

		@* Edit form (title + body, markdown write/preview). Hidden until ts/nodeEdit.ts shows it.
		   The textarea is the source for both the POST body and the client-side preview render. *@
		<form method="post" asp-page-handler="Edit" class="flex flex-col gap-2 mt-3" data-testid="node-edit-form" style="display:none">
			<input type="hidden" name="version" value="@node.Version" />
			<input type="text" name="title" value="@node.Title" maxlength="200" class="input input-bordered input-sm w-full" placeholder="Title" data-testid="node-edit-title" aria-label="Title" />
			<div role="tablist" class="tabs tabs-bordered text-xs self-start">
				<a role="tab" class="tab tab-active" data-testid="node-edit-write-tab">write</a>
				<a role="tab" class="tab" data-testid="node-edit-preview-tab">preview</a>
			</div>
			<textarea name="body" rows="12" class="textarea textarea-bordered textarea-sm w-full font-mono" placeholder="Body (markdown)" data-testid="node-edit-body" aria-label="Body">@node.Body</textarea>
			<partial name="_MdBody" model="@(new PetBox.Web.Pages.Shared.MdBodyModel { TestId = "node-edit-preview", ExtraClasses = "border border-base-300 rounded p-3 min-h-24", Style = "display:none", ServerRender = false })" />
			<div class="flex items-center gap-2">
				<button type="submit" class="btn btn-sm btn-primary" data-testid="node-edit-save">Save</button>
				<button type="button" class="btn btn-sm btn-ghost" data-testid="node-edit-cancel">Cancel</button>
			</div>
		</form>

		@* Read body, no truncation (node-page-full-body). Markdown is rendered to sanitized HTML on
		   the SERVER (_MdBody / IMarkdownRenderer) inside a semantic <article> so browser reader-view
		   can detect it; storage/format unchanged. Hidden while editing. *@
		<div data-testid="node-read-body">
			@if (!string.IsNullOrEmpty(node.Body))
			{
				<article class="mt-3">
					<partial name="_MdBody" model="@(new PetBox.Web.Pages.Shared.MdBodyModel { Body = node.Body, TestId = "node-body", CommitUrlTemplate = Model.CommitUrlTemplate, NodeRefs = Model.NodeRefs })" />
				</article>
			}
			else
			{
				<p class="text-base opacity-40 italic mt-3" data-testid="node-body-empty">(no body)</p>
			}
		</div>

		@if (node.Commits is { Count: > 0 })
		{
			<div class="text-xs opacity-50 font-mono mt-2 flex flex-wrap gap-x-2 gap-y-1" data-testid="node-commits">
				@foreach (var sha in node.Commits)
				{
					var commitUrl = PetBox.Web.Rendering.CommitUrl.For(Model.CommitUrlTemplate, sha);
					if (commitUrl is not null)
					{
						<a href="@commitUrl" target="_blank" rel="noopener" class="link link-hover" data-testid="node-commit-link">@sha</a>
					}
					else
					{
						<span data-testid="node-commit">@sha</span>
					}
				}
			</div>
		}

		@* Exhaustive relation panel (node-relations-panel): every relation kind in both directions
		   — children (part_of down), blocks/blocked by, implements/linked, idea/spec, issue/tasks,
		   supersedes/superseded by — computed by the service into Detail.Relations. Only non-empty
		   groups render, in a fixed reading order; each row shows the target's live status. *@
		@foreach (var group in Model.Detail.Relations)
		{
			@if (group.Links.Count > 0)
			{
				<div class="text-sm opacity-80 mt-2 flex flex-wrap items-baseline gap-x-2 gap-y-1" data-testid="node-links" data-relation="@group.Label">
					<span class="opacity-60">@group.Label:</span>
					@foreach (var l in group.Links)
					{
						@if (l.NodeId.Length > 0 && l.Status != "missing")
						{
							@* Canonical slug-URL when the target's board+slug are known (cross-board
							   links carry both); fall back to the opaque nodeId alias otherwise. *@
							var href = l is { Board: { Length: > 0 } b, Slug: { Length: > 0 } s }
								? Routes.TaskBoardNodeBySlug(Model.WorkspaceKey, Model.ProjectKey, b, s)
								: Routes.TaskBoardNode(Model.WorkspaceKey, Model.ProjectKey, l.NodeId);
							<a href="@href" class="link link-hover font-mono" data-testid="node-link">@(l.Slug ?? l.NodeId)<span class="opacity-50"> · @l.Status</span></a>
						}
						else
						{
							<span class="font-mono opacity-50" data-testid="node-link">@(l.Slug ?? l.NodeId) · @l.Status</span>
						}
					}
				</div>
			}
		}

		<partial name="_CommentThread" model="@(new PetBox.Web.Pages.Shared.CommentThreadModel(Model.Thread, Model.CommitUrlTemplate, Model.NodeRefs))" />
	</div>
</div>

@if (Model.WorkflowJson is not null)
{
	<partial name="_WorkflowModal" model="Model.WorkflowJson" />
}
