{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},
	"AllowedHosts": "*",
	"Host": {
		"BackgroundServices": true
	},
	"Features": {
		"Config": true,
		"Logging": true,
		"Data": true,
		"Dashboard": true,
		"Tasks": true,
		"Memory": true,
		"LlmRouter": true,
		"Deploy": true
	},
	"ConnectionStrings": {
		"PetBox": "Data Source=./data/petbox.db;Cache=Shared"
	},
	"Admin": {
		"Username": "",
		"PasswordHash": ""
	},
	"Auth": {
		"Mode": "local",
		"RemoteUrl": null,
		"RemoteApiKey": null
	},
	"Seq": {
		"SelfLog": {
			"Enabled": false,
			"ServerUrl": "http://localhost:5000",
			"ApiKey": "yb_key_system_internal",
			"ServiceKey": "petbox-web"
		}
	},
	"OpenTelemetry": {
		"Enabled": false,
		"ServiceName": "petbox",
		"OtlpEndpoint": null
	},
	"Search": {
		"Recency": {
			"Enabled": true,
			"HalfLifeDays": 30
		},
		"Diversity": {
			"Enabled": true,
			"Lambda": 0.7
		},
		"Sessions": {
			"SemanticFloor": 0.013
		}
	}
