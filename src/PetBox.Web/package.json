{
	"name": "petbox-web",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently -n ts,css -c blue,magenta \"bun run dev:ts\" \"bun run dev:css\"",
		"dev:ts": "bun build ./ts/site.ts --outdir=./wwwroot/js --splitting --watch",
		"dev:css": "tailwindcss -i ./ts/app.css -o ./wwwroot/css/app.css --watch",
		"build": "bun run typecheck && bun run build:ts && bun run build:css",
		"build:ts": "bun build ./ts/site.ts --outdir=./wwwroot/js --splitting --minify",
		"build:css": "tailwindcss -i ./ts/app.css -o ./wwwroot/css/app.css --minify",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@types/snowball-stemmers": "^0.6.2",
		"concurrently": "^9.2.1",
		"daisyui": "^4.12",
		"tailwindcss": "3.4.17",
		"typescript": "5.7.3"
	},
	"dependencies": {
		"alpinejs": "3.14.1",
		"dompurify": "^3.4.8",
		"htmx-ext-sse": "^2.2.4",
		"htmx.org": "2.0.4",
		"marked": "^18.0.4",
		"snowball-stemmers": "^0.6.0"
	}
}
