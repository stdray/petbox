@page "/config/edit"
@model YobaBox.Web.Pages.Config.EditorModel
@{
	Layout = null;
}

<tr data-testid="config-edit-row">
	<td data-testid="config-edit-tags">
		<textarea name="Tags" rows="2"
			placeholder="project=kpvotes&#10;service=kpvotes-bot"
			class="textarea textarea-bordered textarea-xs w-full font-mono text-xs">@Model.Tags</textarea>
	</td>
	<td data-testid="config-edit-path">
		<input type="text" name="Path" value="@Model.Path"
			class="input input-bordered input-sm w-full font-mono text-xs" />
	</td>
	<td data-testid="config-edit-value">
		<input type="text" name="Value" value="@Model.Value"
			class="input input-bordered input-sm w-full font-mono text-xs" />
	</td>
	<td></td>
	<td class="flex gap-1">
		<button class="btn btn-xs btn-primary"
			hx-post="/config/save?id=@(Model.Id ?? 0)"
			hx-include="closest tr"
			hx-target="closest tr"
			hx-swap="outerHTML"
			data-testid="config-save-btn">
			Save
		</button>
		<button class="btn btn-xs btn-ghost"
			hx-get="@(Model.Id is null ? "" : $"/config/row?id={Model.Id}")"
			@(Model.Id is null ? "onclick=\"this.closest('tr').remove()\"" : $"hx-target=\"closest tr\" hx-swap=\"outerHTML\"")
			data-testid="config-cancel-btn">
			Cancel
		</button>
	</td>
</tr>
