@page "/ui/config/{workspaceKey?}/edit/{bindingId:long?}"
@model YobaBox.Web.Pages.Config.EditorModel
@{
	ViewData["Title"] = Model.IsNew ? "New Binding" : "Edit Binding";
}

<div class="mb-4 text-sm">
	<a asp-page="/Config/Index" asp-route-workspaceKey="@Model.EffectiveWorkspaceKey"
		class="link opacity-70 hover:opacity-100" data-testid="back-to-config">← All bindings</a>
	<span class="badge badge-outline font-mono ml-2">@Model.EffectiveWorkspaceKey</span>
</div>

<h1 class="text-xl font-semibold mb-4" data-testid="edit-title">@(Model.IsNew ? "New binding" : "Edit binding")</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
	<div class="alert alert-error mb-3" data-testid="edit-error">@Model.ErrorMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ConflictMessage))
{
	<div class="alert alert-warning mb-3" data-testid="edit-conflict">@Model.ConflictMessage</div>
}

<form method="post" asp-page-handler="Save" autocomplete="off" class="grid grid-cols-1 gap-3 max-w-2xl" data-testid="config-edit-form">
	@Html.AntiForgeryToken()

	<label class="form-control">
		<span class="label-text">Tags (one <code class="font-mono text-xs">key=value</code> per line)</span>
		<textarea name="TagsText" rows="3"
			class="textarea textarea-bordered font-mono text-xs"
			placeholder="ws=@Model.EffectiveWorkspaceKey&#10;project=kpvotes&#10;env=prod"
			data-testid="config-edit-tags">@Model.TagsText</textarea>
		<span class="text-xs opacity-60 mt-1">Tag <code>ws=@Model.EffectiveWorkspaceKey</code> is mandatory.</span>
	</label>

	<label class="form-control">
		<span class="label-text">Key (Path)</span>
		<input type="text" name="Path" value="@Model.Path" required
			placeholder="app.timeout"
			class="input input-bordered input-sm font-mono text-xs"
			data-testid="config-edit-path" />
	</label>

	<div class="form-control">
		<span class="label-text mb-1">Kind</span>
		<div class="flex gap-4">
			<label class="flex items-center gap-2">
				<input type="radio" name="Kind" value="Plain" checked="@(Model.Kind == YobaBox.Core.Models.BindingKind.Plain)"
					class="radio radio-sm" data-testid="config-edit-kind-plain" />
				<span>Plain</span>
			</label>
			<label class="flex items-center gap-2">
				<input type="radio" name="Kind" value="Secret" checked="@(Model.Kind == YobaBox.Core.Models.BindingKind.Secret)"
					class="radio radio-sm" data-testid="config-edit-kind-secret"
					@(Model.SecretsAvailable ? "" : "disabled") />
				<span>Secret @(Model.SecretsAvailable ? "" : "(unavailable — YOBABOX_MASTER_KEY not set)")</span>
			</label>
		</div>
	</div>

	<label class="form-control">
		<span class="label-text">Value</span>
		<textarea name="Value" rows="3"
			class="textarea textarea-bordered font-mono text-xs"
			placeholder="30"
			data-testid="config-edit-value">@Model.Value</textarea>
		<span class="text-xs opacity-60 mt-1">For Secret bindings, the field starts empty on edit — paste a fresh plaintext to rotate.</span>
	</label>

	<div class="flex gap-2">
		<button type="submit" class="btn btn-sm btn-primary" data-testid="config-save-btn">Save</button>
		<a asp-page="/Config/Index" asp-route-workspaceKey="@Model.EffectiveWorkspaceKey" class="btn btn-sm btn-ghost" data-testid="config-cancel-btn">Cancel</a>
	</div>
</form>
