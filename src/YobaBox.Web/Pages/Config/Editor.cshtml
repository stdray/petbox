@page "/config/edit"
@model YobaBox.Web.Pages.Config.EditorModel
@{
	ViewData["Title"] = Model.IsNew ? "New Binding" : "Edit Binding";
}

<div class="max-w-2xl mx-auto">
	<h1 class="text-xl font-semibold mb-4">@ViewData["Title"]</h1>

	<form method="post" asp-page-handler="Save" asp-route-bindingId="@Model.Id" data-testid="config-edit-form">
		@Html.AntiForgeryToken()

		<div class="form-control mb-3">
			<label class="label"><span class="label-text">Key (Path)</span></label>
			<input type="text" name="Path" value="@Model.Path"
				class="input input-bordered w-full font-mono text-sm"
				placeholder="app.timeout"
				data-testid="config-edit-path" />
		</div>

		<div class="form-control mb-3">
			<label class="label"><span class="label-text">Value</span></label>
			<input type="text" name="Value" value="@Model.Value"
				class="input input-bordered w-full font-mono text-sm"
				placeholder="30"
				data-testid="config-edit-value" />
		</div>

		<div class="form-control mb-4">
			<label class="label"><span class="label-text">Tags</span></label>
			<textarea name="Tags" rows="3"
				class="textarea textarea-bordered w-full font-mono text-xs"
				placeholder="project=kpvotes&#10;service=kpvotes-bot"
				data-testid="config-edit-tags">@Model.Tags</textarea>
		</div>

		<div class="flex gap-2">
			<button type="submit" class="btn btn-primary" data-testid="config-save-btn">Save</button>
			<a asp-page="/Config/Index" class="btn btn-ghost" data-testid="config-cancel-btn">Cancel</a>
		</div>
	</form>
</div>
