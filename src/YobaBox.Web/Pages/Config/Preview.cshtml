@page "/ui/{workspaceKey}/config/preview"
@model YobaBox.Web.Pages.Config.PreviewModel
@{
	ViewData["Title"] = $"Config Preview — {Model.EffectiveWorkspaceKey}";
}

<div class="mb-4 text-sm">
	<a asp-page="/Config/Index" asp-route-workspaceKey="@Model.EffectiveWorkspaceKey"
		class="link opacity-70 hover:opacity-100" data-testid="back-to-config">← All bindings</a>
	<span class="badge badge-outline font-mono ml-2">@Model.EffectiveWorkspaceKey</span>
</div>

<h1 class="text-xl font-semibold mb-4" data-testid="config-preview-title">Resolve Preview</h1>
<p class="text-sm opacity-70 mb-4">Try a tag set against one or more paths to see which binding would resolve.</p>

<form method="post" class="grid grid-cols-1 gap-3 max-w-2xl mb-6" data-testid="config-preview-form">
	@Html.AntiForgeryToken()

	<label class="form-control">
		<span class="label-text">Tags (space, comma, or newline separated)</span>
		<textarea name="TagsInput" rows="2"
			class="textarea textarea-bordered font-mono text-xs"
			data-testid="config-preview-tags">@Model.TagsInput</textarea>
		<span class="text-xs opacity-60 mt-1">e.g. <code>ws:default project:kpvotes env:prod</code></span>
	</label>

	<label class="form-control">
		<span class="label-text">Paths (one per line)</span>
		<textarea name="PathsInput" rows="3"
			class="textarea textarea-bordered font-mono text-xs"
			data-testid="config-preview-paths">@Model.PathsInput</textarea>
	</label>

	<div class="flex gap-2">
		<button type="submit" class="btn btn-sm btn-primary" data-testid="config-preview-submit">Resolve</button>
	</div>
</form>

@if (Model.Results.Count > 0)
{
	<div class="overflow-x-auto">
		<table class="table table-sm" data-testid="config-preview-results">
			<thead>
				<tr>
					<th>Path</th>
					<th>Value</th>
					<th class="w-32">Specificity</th>
					<th class="w-32">Binding</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var row in Model.Results)
				{
					<tr data-testid="config-preview-row">
						<td class="font-mono text-xs text-primary">@row.Path</td>
						<td class="font-mono text-xs">
							@if (row.AmbiguityNote is not null)
							{
								<span class="text-error" data-testid="config-preview-ambiguous">@row.AmbiguityNote</span>
							}
							else if (row.Value is null)
							{
								<span class="opacity-50">(no match)</span>
							}
							else
							{
								<span>@row.Value</span>
							}
						</td>
						<td class="text-xs">@row.Specificity</td>
						<td class="text-xs">
							@if (row.BindingId is { } id)
							{
								<a asp-page="/Config/Editor" asp-route-workspaceKey="@Model.EffectiveWorkspaceKey" asp-route-bindingId="@id" class="link">#@id</a>
							}
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
}
