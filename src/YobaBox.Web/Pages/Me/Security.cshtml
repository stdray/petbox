@page "/ui/me/security"
@model YobaBox.Web.Pages.Me.SecurityModel
@{
	ViewData["Title"] = "Security";
	Layout = "_AccountLayout";
}

<div class="mb-4">
	<h1 class="text-2xl font-semibold" data-testid="me-security-title">Security</h1>
	<p class="text-sm opacity-60">Change your password. Stored as PBKDF2 hash.</p>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
	<div class="alert alert-success mb-3 max-w-3xl" data-testid="me-security-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
	<div class="alert alert-error mb-3 max-w-3xl" data-testid="me-security-error">@Model.ErrorMessage</div>
}

<form method="post" asp-page-handler="ChangePassword" class="card bg-base-200 border border-base-300 max-w-3xl" data-testid="me-security-form">
	@Html.AntiForgeryToken()
	<div class="card-body p-4 grid gap-3">
		<label class="form-control">
			<span class="label-text">Current password</span>
			<input type="password" name="currentPassword" required
				class="input input-bordered input-sm"
				autocomplete="current-password"
				data-testid="me-security-current" />
		</label>
		<label class="form-control">
			<span class="label-text">New password</span>
			<input type="password" name="newPassword" required minlength="8"
				class="input input-bordered input-sm"
				autocomplete="new-password"
				data-testid="me-security-new" />
			<span class="text-xs opacity-60 mt-1">Minimum 8 characters.</span>
		</label>
		<label class="form-control">
			<span class="label-text">Confirm new password</span>
			<input type="password" name="confirmPassword" required minlength="8"
				class="input input-bordered input-sm"
				autocomplete="new-password"
				data-testid="me-security-confirm" />
		</label>
		<div class="card-actions mt-2">
			<button type="submit" class="btn btn-sm btn-primary" data-testid="me-security-submit">Change password</button>
		</div>
	</div>
</form>
