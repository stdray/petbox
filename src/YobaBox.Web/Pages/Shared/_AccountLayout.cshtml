@inject YobaBox.Web.Navigation.INavigationContext Nav
@inject YobaBox.Core.Settings.ISettingsResolver Settings
@{
	var currentWs = Nav.CurrentWorkspaceKey;
	var backUrl = Routes.Workspace(currentWs);
	var backLabel = $"Back to {currentWs}";

	var theme = "dark";
	var userIdRaw = Nav.IsAuthenticated
		? Context.User.FindFirst(YobaBox.Core.Auth.YobaBoxClaims.UserId)?.Value
		: null;
	if (!string.IsNullOrEmpty(userIdRaw))
	{
		var ui = await Settings.GetAsync<YobaBox.Core.Settings.UiSettings>(YobaBox.Core.Settings.Scope.User, userIdRaw);
		theme = ui.Theme switch
		{
			YobaBox.Core.Settings.Theme.Light => "light",
			YobaBox.Core.Settings.Theme.System => "dark",
			_ => "dark",
		};
	}
}
<!DOCTYPE html>
<html lang="en" data-theme="@theme" class="h-full">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] · account · YobaBox</title>
	<link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
	<meta name="yb-current-ws" content="@currentWs" />
	<script type="module" src="~/js/site.js" asp-append-version="true"></script>
</head>
<body class="min-h-full bg-base-100">
	<div class="drawer lg:drawer-open">
		<input id="account-sidebar-toggle" type="checkbox" class="drawer-toggle" />
		<div class="drawer-content flex flex-col min-h-screen">
			<header class="navbar bg-base-200 border-b border-base-300 px-2 lg:px-4 min-h-12" data-testid="account-navbar">
				<div class="flex-none lg:hidden">
					<label for="account-sidebar-toggle" class="btn btn-ghost btn-sm drawer-button" data-testid="account-nav-toggle">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
						</svg>
					</label>
				</div>
				<div class="flex-1 flex items-center gap-3 min-w-0">
					<a href="@backUrl" class="btn btn-ghost btn-sm gap-1" data-testid="account-back">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
						</svg>
						<span class="hidden sm:inline">@backLabel</span>
					</a>
					<span class="text-sm font-semibold" data-testid="account-context-label">Account settings</span>
				</div>
				<div class="flex-none flex items-center gap-1">
					@if (Nav.IsAuthenticated)
					{
						<form method="post" action="@Routes.Logout()" class="m-0">
							@Html.AntiForgeryToken()
							<button type="submit" class="btn btn-ghost btn-sm" data-testid="nav-signout" title="Sign out">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
								</svg>
							</button>
						</form>
					}
				</div>
			</header>

			<main class="flex-1 p-4 lg:p-6 max-w-4xl w-full mx-auto">
				@RenderBody()
			</main>

			<footer class="p-3 text-center text-xs opacity-60 border-t border-base-300" data-testid="footer-version">
				v@(Environment.GetEnvironmentVariable("APP_VERSION") ?? "dev")
				· @(Environment.GetEnvironmentVariable("GIT_SHORT_SHA") ?? "local")
			</footer>
		</div>

		<div class="drawer-side">
			<label for="account-sidebar-toggle" aria-label="close sidebar" class="drawer-overlay"></label>
			<partial name="_AccountSidebar" />
		</div>
	</div>
	@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
