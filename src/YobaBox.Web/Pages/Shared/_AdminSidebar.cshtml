@inject YobaBox.Web.Navigation.INavigationContext Nav
@{
	var path = Context.Request.Path.Value ?? string.Empty;
	bool At(string url) => string.Equals(path, url, StringComparison.OrdinalIgnoreCase);
	bool Under(string prefix) => path.StartsWith(prefix, StringComparison.OrdinalIgnoreCase);

	var ws = Nav.CurrentWorkspaceKey;
	var isAuthenticated = Nav.IsAuthenticated;
	var isSysAdmin = isAuthenticated
		&& Context.User.FindFirst(YobaBox.Core.Auth.YobaBoxClaims.IsSysAdmin)?.Value == "true";

	// Project sub-context: URL looks like /ui/{ws}/admin/projects/{key}/...
	string? projectKey = null;
	if (Under($"/ui/{ws}/admin/projects/"))
	{
		var rest = path.Substring($"/ui/{ws}/admin/projects/".Length);
		var slash = rest.IndexOf('/');
		var maybeKey = slash > 0 ? rest[..slash] : rest;
		if (!string.IsNullOrEmpty(maybeKey) && maybeKey != "new")
			projectKey = maybeKey;
	}
}
<aside class="bg-base-200 w-64 min-h-full border-r border-base-300 flex flex-col" data-testid="admin-sidebar">
	@if (isAuthenticated)
	{
		<div class="p-3 border-b border-base-300">
			<div class="text-xs opacity-50 uppercase tracking-wide">Workspace</div>
			<div class="font-mono text-sm" data-testid="admin-sidebar-ws">@ws</div>
		</div>

		<div class="px-3 pt-3 pb-1 text-xs opacity-50 uppercase tracking-wide">Workspace</div>
		<ul class="menu menu-sm w-full p-2 gap-0.5">
			<li>
				<a href="@Routes.WorkspaceAdmin(ws)" class="@(At(Routes.WorkspaceAdmin(ws)) || At(Routes.WorkspaceAdminMembers(ws)) ? "active" : "")" data-testid="admin-side-ws-members">Members</a>
			</li>
			<li>
				<a href="@Routes.WorkspaceAdminProjects(ws)" class="@(At(Routes.WorkspaceAdminProjects(ws)) ? "active" : "")" data-testid="admin-side-ws-projects">Projects</a>
			</li>
			<li>
				<a href="@Routes.SharedConfig(ws)" class="@(Under(Routes.SharedConfig(ws)) ? "active" : "")" data-testid="admin-side-ws-config">Shared config</a>
			</li>
			<li>
				<a href="/ui/@ws/admin/defaults" class="@(At($"/ui/{ws}/admin/defaults") ? "active" : "")" data-testid="admin-side-ws-defaults">Defaults</a>
			</li>
			<li>
				<a href="@Routes.WorkspaceAdminSettings(ws)" class="@(At(Routes.WorkspaceAdminSettings(ws)) ? "active" : "")" data-testid="admin-side-ws-settings">Info</a>
			</li>
		</ul>

		@if (projectKey is not null)
		{
			<div class="px-3 pt-3 pb-1 text-xs opacity-50 uppercase tracking-wide flex items-center justify-between">
				<span>Project</span>
				<span class="font-mono opacity-70 text-[10px]">@projectKey</span>
			</div>
			<ul class="menu menu-sm w-full p-2 gap-0.5">
				<li>
					<a href="@Routes.ProjectSettings(ws, projectKey)" class="@(At(Routes.ProjectSettings(ws, projectKey)) ? "active" : "")" data-testid="admin-side-proj-info">Info</a>
				</li>
				<li>
					<a href="/ui/@ws/admin/projects/@projectKey/log" class="@(At($"/ui/{ws}/admin/projects/{projectKey}/log") ? "active" : "")" data-testid="admin-side-proj-log">Log settings</a>
				</li>
				<li>
					<a href="@Routes.ProjectData(ws, projectKey)" class="@(At(Routes.ProjectData(ws, projectKey)) ? "active" : "")" data-testid="admin-side-proj-data">Data</a>
				</li>
			</ul>
		}

		@if (isSysAdmin)
		{
			<div class="px-3 pt-3 pb-1 text-xs opacity-50 uppercase tracking-wide">System</div>
			<ul class="menu menu-sm w-full p-2 gap-0.5">
				<li>
					<a href="@Routes.Sys()" class="@(At(Routes.Sys()) ? "active" : "")" data-testid="admin-side-sys-home">Overview</a>
				</li>
				<li>
					<a href="@Routes.SysWorkspaces()" class="@(Under(Routes.SysWorkspaces()) ? "active" : "")" data-testid="admin-side-sys-workspaces">Workspaces</a>
				</li>
				<li>
					<a href="@Routes.SysUsers()" class="@(At(Routes.SysUsers()) ? "active" : "")" data-testid="admin-side-sys-users">Users</a>
				</li>
				<li>
					<a href="/ui/sys/defaults" class="@(At("/ui/sys/defaults") ? "active" : "")" data-testid="admin-side-sys-defaults">Defaults</a>
				</li>
			</ul>
		}

		<div class="px-3 pt-3 pb-1 text-xs opacity-50 uppercase tracking-wide">Account</div>
		<ul class="menu menu-sm w-full p-2 gap-0.5">
			<li>
				<a href="/ui/me/account" class="@(At("/ui/me/account") ? "active" : "")" data-testid="admin-side-me-account">Profile</a>
			</li>
			<li>
				<a href="/ui/me/security" class="@(At("/ui/me/security") ? "active" : "")" data-testid="admin-side-me-security">Security</a>
			</li>
			<li>
				<a href="/ui/me/preferences" class="@(At("/ui/me/preferences") ? "active" : "")" data-testid="admin-side-me-preferences">Preferences</a>
			</li>
		</ul>
	}
</aside>
