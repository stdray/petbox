@model YobaBox.Core.Models.Project
@{
	Layout = null;
}

<form class="card bg-base-200 mb-4" data-testid="admin-project-create-form"
	hx-post="/admin/projects?handler=Create"
	hx-target="#project-form"
	hx-swap="outerHTML">
	@Html.AntiForgeryToken()
	<div class="card-body p-4">
		<h3 class="card-title text-sm">New Project</h3>
		<div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
			<label class="form-control">
				<span class="label-text">Key</span>
				<input type="text" name="Key" required
					class="input input-bordered input-sm font-mono"
					placeholder="my-project"
					data-testid="admin-project-create-key" />
			</label>
			<label class="form-control">
				<span class="label-text">Name</span>
				<input type="text" name="Name" required
					class="input input-bordered input-sm"
					placeholder="My Project"
					data-testid="admin-project-create-name" />
			</label>
			<label class="form-control">
				<span class="label-text">Description</span>
				<input type="text" name="Description"
					class="input input-bordered input-sm"
					data-testid="admin-project-create-desc" />
			</label>
		</div>
		<div class="card-actions mt-3">
			<button type="submit" class="btn btn-sm btn-primary" data-testid="admin-project-create-submit">Create</button>
			<button type="button" class="btn btn-sm btn-ghost"
				hx-get="/admin/projects?handler=CreateCancel"
				hx-target="#project-form"
				hx-swap="innerHTML"
				data-testid="admin-project-create-cancel">Cancel</button>
		</div>
	</div>
</form>
