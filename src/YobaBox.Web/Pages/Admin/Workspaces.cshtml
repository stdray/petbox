@page "/ui/admin/sys/workspaces"
@model YobaBox.Web.Pages.Admin.WorkspacesModel
@{
	ViewData["Title"] = "Workspaces";
	Layout = "_AdminLayout";
}

<div class="mb-4">
	<h1 class="text-2xl font-semibold" data-testid="admin-workspaces-title">Workspaces</h1>
	<p class="text-sm opacity-60">All tenants in this instance. <code class="font-mono">$system</code> is built-in and undeletable.</p>
</div>

<partial name="_SysTabs" />

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
	<div class="alert alert-error mb-3" data-testid="admin-workspaces-error">@Model.ErrorMessage</div>
}

<div class="flex items-center gap-3 mb-3">
	<h2 class="text-lg font-semibold">All workspaces</h2>
	<span class="badge badge-ghost">@Model.Workspaces.Count</span>
</div>

@if (Model.Workspaces.Count == 0)
{
	<div class="text-xs opacity-60 italic mb-4" data-testid="admin-workspaces-empty">No workspaces.</div>
}
else
{
	<div class="overflow-x-auto mb-6">
		<table class="table table-sm" data-testid="admin-workspaces-table">
			<thead>
				<tr>
					<th>Key</th>
					<th>Name</th>
					<th>Description</th>
					<th class="w-32"></th>
				</tr>
			</thead>
			<tbody>
				@foreach (var w in Model.Workspaces)
				{
					<tr data-testid="workspace-row">
						<td class="font-mono text-xs">@w.Key</td>
						<td><a href="@Routes.SysWorkspace(w.Key)" class="link link-hover" data-testid="admin-workspace-link">@w.Name</a>
							@if (w.Key == "$system")
							{
								<span class="badge badge-ghost badge-xs ml-1">built-in</span>
							}
						</td>
						<td class="text-sm opacity-70">@w.Description</td>
						<td>
							@if (w.Key != "$system")
							{
								<form method="post" asp-page-handler="Delete" asp-route-key="@w.Key"
									onsubmit="return confirm('Delete workspace @w.Key?')" style="display:inline">
									@Html.AntiForgeryToken()
									<button type="submit" class="btn btn-xs btn-ghost text-error" data-testid="admin-workspace-delete">Delete</button>
								</form>
							}
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
}

<h2 class="text-lg font-semibold mb-3">New workspace</h2>
<form method="post" asp-page-handler="Create" class="card bg-base-200 border border-base-300 mb-4 max-w-3xl" data-testid="admin-workspace-create-form">
	@Html.AntiForgeryToken()
	<div class="card-body p-4">
		<div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
			<label class="form-control">
				<span class="label-text">Key</span>
				<input type="text" name="Key" required
					class="input input-bordered input-sm font-mono"
					placeholder="my-workspace"
					pattern="[a-z0-9][a-z0-9\-]*"
					data-testid="admin-workspace-create-key" />
				<span class="text-xs opacity-60 mt-1">lowercase letters, digits, hyphens</span>
			</label>
			<label class="form-control">
				<span class="label-text">Name</span>
				<input type="text" name="Name" required
					class="input input-bordered input-sm"
					placeholder="My Workspace"
					data-testid="admin-workspace-create-name" />
			</label>
		</div>
		<label class="form-control mt-3">
			<span class="label-text">Description</span>
			<input type="text" name="Description"
				class="input input-bordered input-sm"
				data-testid="admin-workspace-create-desc" />
		</label>
		<div class="card-actions mt-3">
			<button type="submit" class="btn btn-sm btn-primary" data-testid="admin-workspace-create-submit">Create</button>
		</div>
	</div>
</form>
