@page "/ui/admin/ws/{workspaceKey}/projects/{projectKey}/data"
@model YobaBox.Web.Pages.Admin.ProjectDataModel
@{
	ViewData["Title"] = $"{Model.ProjectKey} — Data";
	Layout = "_AdminLayout";
}

<div class="mb-4 flex items-baseline gap-3 flex-wrap">
	<h1 class="text-2xl font-semibold">@Model.ProjectKey · data</h1>
	<span class="badge badge-ghost">@Model.DataDbs.Count DB(s)</span>
</div>

@if (Model.ProjectNotFound)
{
	<p class="text-error font-semibold" data-testid="project-data-error">Project not found</p>
	return;
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
	<div class="alert alert-error mb-3" data-testid="project-data-error-msg">@Model.ErrorMessage</div>
}

<section class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-6" data-testid="datadbs-list">
	@if (Model.DataDbs.Count == 0)
	{
		<div class="text-xs opacity-60 italic" data-testid="datadbs-empty">No databases yet. Create one below.</div>
	}
	else
	{
		@foreach (var d in Model.DataDbs)
		{
			<div class="card bg-base-200 border border-base-300" data-testid="datadb-card" data-db-name="@d.Name">
				<div class="card-body p-4">
					<div class="flex items-baseline justify-between">
						<a href="/ui/admin/ws/@Model.WorkspaceKey/projects/@Model.ProjectKey/data/@d.Name"
							class="font-mono font-semibold link link-hover" data-testid="datadb-open">@d.Name</a>
						<span class="text-xs opacity-60">@(d.MaxPageCount * 4 / 1024) MB quota</span>
					</div>
					@if (!string.IsNullOrEmpty(d.Description))
					{
						<p class="text-sm opacity-80">@d.Description</p>
					}
					<div class="card-actions justify-between mt-2">
						<span class="text-xs opacity-50 font-mono">@d.CreatedAt.ToString("yyyy-MM-dd")</span>
						<form method="post" asp-page-handler="Delete" asp-route-name="@d.Name"
							onsubmit="return confirm('Delete DataDb @d.Name? File and all data will be removed.')" style="display:inline">
							@Html.AntiForgeryToken()
							<button type="submit" class="btn btn-xs btn-ghost text-error" data-testid="datadb-delete">Delete</button>
						</form>
					</div>
				</div>
			</div>
		}
	}
</section>

<form method="post" asp-page-handler="Create" class="card bg-base-200 border border-base-300 max-w-3xl" data-testid="datadb-create-form">
	@Html.AntiForgeryToken()
	<div class="card-body p-4">
		<h3 class="card-title text-base">Create database</h3>
		<div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
			<label class="form-control">
				<span class="label-text">Name</span>
				<input type="text" name="name" required minlength="2"
					pattern="[a-z][a-z0-9_\-]*"
					class="input input-bordered input-sm font-mono"
					placeholder="cache"
					data-testid="datadb-create-name" />
				<span class="text-xs opacity-60 mt-1">Lowercase letters, digits, `_` or `-`. Starts with a letter.</span>
			</label>
			<label class="form-control">
				<span class="label-text">Max pages (×4 KB)</span>
				<input type="number" name="maxPageCount" min="1024"
					class="input input-bordered input-sm"
					placeholder="262144"
					data-testid="datadb-create-quota" />
				<span class="text-xs opacity-60 mt-1">Default 262144 ≈ 1 GB. Minimum 1024 ≈ 4 MB.</span>
			</label>
			<label class="form-control sm:col-span-2">
				<span class="label-text">Description (optional)</span>
				<input type="text" name="description"
					class="input input-bordered input-sm"
					placeholder="vote cache"
					data-testid="datadb-create-desc" />
			</label>
		</div>
		<div class="card-actions mt-3">
			<button type="submit" class="btn btn-sm btn-primary" data-testid="datadb-create-submit">Create</button>
		</div>
	</div>
</form>
