@page "/ui/{workspaceKey}/admin"
@model YobaBox.Web.Pages.Admin.WorkspaceAdminModel
@{
	ViewData["Title"] = $"{Model.WorkspaceKey} — admin overview";
	Layout = "_AdminLayout";
}

<div class="mb-4">
	<h1 class="text-2xl font-semibold" data-testid="ws-admin-overview-title">@(Model.Workspace?.Name ?? Model.WorkspaceKey)</h1>
	<p class="text-sm opacity-60 font-mono">@Model.WorkspaceKey</p>
	@if (!string.IsNullOrEmpty(Model.Workspace?.Description))
	{
		<p class="text-sm opacity-80 mt-2">@Model.Workspace.Description</p>
	}
</div>

@if (Model.Workspace is null)
{
	<div class="alert alert-error" data-testid="ws-admin-overview-error">Workspace not found.</div>
	return;
}

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3" data-testid="ws-admin-overview-stats">
	<a href="@Routes.WorkspaceAdminMembers(Model.WorkspaceKey)" class="card bg-base-200 hover:bg-base-300 transition" data-testid="ws-admin-stat-members">
		<div class="card-body p-4">
			<div class="text-xs opacity-60 uppercase">Members</div>
			<div class="text-3xl font-semibold">@Model.MemberCount</div>
		</div>
	</a>
	<a href="@Routes.WorkspaceAdminProjects(Model.WorkspaceKey)" class="card bg-base-200 hover:bg-base-300 transition" data-testid="ws-admin-stat-projects">
		<div class="card-body p-4">
			<div class="text-xs opacity-60 uppercase">Projects</div>
			<div class="text-3xl font-semibold">@Model.ProjectCount</div>
		</div>
	</a>
	<a href="@Routes.SharedConfig(Model.WorkspaceKey)" class="card bg-base-200 hover:bg-base-300 transition" data-testid="ws-admin-stat-config">
		<div class="card-body p-4">
			<div class="text-xs opacity-60 uppercase">Shared config bindings</div>
			<div class="text-3xl font-semibold">@Model.BindingCount</div>
		</div>
	</a>
	<a href="/ui/@Model.WorkspaceKey/admin/defaults" class="card bg-base-200 hover:bg-base-300 transition" data-testid="ws-admin-stat-defaults">
		<div class="card-body p-4">
			<div class="text-xs opacity-60 uppercase">Defaults</div>
			<div class="text-sm opacity-70 mt-2">Workspace-level setting overrides</div>
		</div>
	</a>
</div>

<section class="mt-6" data-testid="ws-admin-overview-projects-section">
	<h2 class="text-lg font-semibold mb-2">Projects</h2>
	@if (Model.Projects.Count == 0)
	{
		<p class="text-sm opacity-60 italic">No projects in this workspace yet. <a class="link" href="@Routes.WorkspaceAdminProjects(Model.WorkspaceKey)">Create one</a>.</p>
	}
	else
	{
		<ul class="menu menu-sm bg-base-200 rounded-box w-full">
			@foreach (var p in Model.Projects)
			{
				<li>
					<a href="@Routes.ProjectSettings(Model.WorkspaceKey, p.Key)" data-testid="ws-admin-project-row">
						<span class="font-mono">@p.Key</span>
						<span class="opacity-60 text-xs ml-2">@p.Name</span>
					</a>
				</li>
			}
		</ul>
	}
</section>
