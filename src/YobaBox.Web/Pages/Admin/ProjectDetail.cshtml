@page "/admin/projects/{key}"
@model YobaBox.Web.Pages.Admin.ProjectDetailModel
@{
	ViewData["Title"] = $"Project: {Model.Project?.Name ?? Model.Key}";
}

@if (Model.Project is null)
{
	<div class="alert alert-error" data-testid="project-detail-error">Project not found.</div>
	return;
}

<div class="flex items-center gap-3 mb-4">
	<a asp-page="/Admin/Projects" class="btn btn-sm btn-ghost">&larr; Projects</a>
	<h1 class="text-xl font-semibold" data-testid="project-detail-title">@Model.Project.Name</h1>
	<span class="text-sm opacity-60 font-mono">@Model.Project.Key</span>
</div>

<div class="flex items-center gap-3 mb-4">
	<h2 class="text-lg font-semibold">Services</h2>
	<span class="text-sm opacity-60">@Model.Services.Count</span>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
	<div class="alert alert-error mb-3">@Model.ErrorMessage</div>
}
@if (Model.NewKey is not null)
{
	<div class="alert alert-success mb-3" data-testid="project-key-created">
		New key: <code class="font-mono text-sm">@Model.NewKey</code>
	</div>
}

<div class="overflow-x-auto">
	<table class="table table-sm" data-testid="project-services-table">
		<thead>
			<tr>
				<th>Key</th>
				<th>Kind</th>
				<th>URL</th>
				<th>Health</th>
				<th></th>
			</tr>
		</thead>
		<tbody>
			@foreach (var s in Model.Services)
			{
				<tr data-testid="service-row">
					<td class="font-mono text-sm">@s.Key</td>
					<td>@s.Kind</td>
					<td class="text-sm max-w-xs truncate">@s.Url</td>
					<td><span class="badge badge-sm">@s.Health</span></td>
					<td>
						<form method="post" asp-page-handler="DeleteService" asp-route-serviceKey="@s.Key"
							onsubmit="return confirm('Delete service @s.Key?')" style="display:inline">
							@Html.AntiForgeryToken()
							<button type="submit" class="btn btn-xs btn-ghost text-error" data-testid="project-service-delete">Delete</button>
						</form>
					</td>
				</tr>
			}
		</tbody>
	</table>
</div>

<form method="post" asp-page-handler="CreateService" class="card bg-base-200 mb-4 mt-4" data-testid="project-service-create-form">
	@Html.AntiForgeryToken()
	<div class="card-body p-4">
		<h3 class="card-title text-sm">New Service</h3>
		<div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
			<label class="form-control">
				<span class="label-text">Key</span>
				<input type="text" name="serviceKey" required
					class="input input-bordered input-sm font-mono"
					placeholder="my-service"
					data-testid="project-service-create-key" />
			</label>
			<label class="form-control">
				<span class="label-text">Kind</span>
				<select name="Kind" class="select select-bordered select-sm" data-testid="project-service-create-kind">
					<option value="Web">Web</option>
					<option value="Bot">Bot</option>
					<option value="Cron">Cron</option>
					<option value="PoC">PoC</option>
				</select>
			</label>
			<label class="form-control">
				<span class="label-text">URL</span>
				<input type="text" name="Url"
					class="input input-bordered input-sm font-mono"
					placeholder="https://..."
					data-testid="project-service-create-url" />
			</label>
		</div>
		<div class="card-actions mt-3">
			<button type="submit" class="btn btn-sm btn-primary" data-testid="project-service-create-submit">Create</button>
		</div>
	</div>
</form>

<div class="divider"></div>

<div class="flex items-center gap-3 mb-4">
	<h2 class="text-lg font-semibold">API Keys</h2>
	<span class="text-sm opacity-60">@Model.Keys.Count</span>
</div>

<div class="overflow-x-auto">
	<table class="table table-sm" data-testid="project-keys-table">
		<thead>
			<tr>
				<th>Key (prefix)</th>
				<th>Scopes</th>
				<th>Created</th>
				<th></th>
			</tr>
		</thead>
		<tbody>
			@foreach (var k in Model.Keys)
			{
				<tr data-testid="key-row">
					<td class="font-mono text-sm">@(k.Key.Length > 12 ? k.Key[..12] + "..." : k.Key)</td>
					<td class="text-sm">@k.Scopes</td>
					<td class="text-xs opacity-70">@k.CreatedAt.ToString("yyyy-MM-dd")</td>
					<td>
						<form method="post" asp-page-handler="RevokeKey" asp-route-keyValue="@k.Key"
							onsubmit="return confirm('Revoke key @(k.Key[..Math.Min(12, k.Key.Length)])...?')" style="display:inline">
							@Html.AntiForgeryToken()
							<button type="submit" class="btn btn-xs btn-ghost text-error" data-testid="project-key-revoke">Revoke</button>
						</form>
					</td>
				</tr>
			}
		</tbody>
	</table>
</div>

<form method="post" asp-page-handler="CreateKey" class="card bg-base-200 mb-4 mt-4" data-testid="project-key-create-form">
	@Html.AntiForgeryToken()
	<div class="card-body p-4">
		<h3 class="card-title text-sm">New API Key</h3>
		<div class="flex flex-col gap-3">
			<label class="form-control">
				<span class="label-text">Scopes</span>
				<input type="text" name="Scopes" required
					class="input input-bordered input-sm font-mono"
					placeholder="logs:ingest,config:read"
					data-testid="project-key-create-scopes" />
			</label>
		</div>
		<div class="card-actions mt-3">
			<button type="submit" class="btn btn-sm btn-primary" data-testid="project-key-create-submit">Create</button>
		</div>
	</div>
</form>
