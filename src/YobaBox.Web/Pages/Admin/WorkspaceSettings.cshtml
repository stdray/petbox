@page "/ui/{workspaceKey}/admin/settings"
@model YobaBox.Web.Pages.Admin.WorkspaceSettingsModel
@{
	ViewData["Title"] = "Workspace settings";
	Layout = "_AdminLayout";
}

<div class="mb-4">
	<h1 class="text-2xl font-semibold" data-testid="ws-settings-title">@Model.WorkspaceKey workspace</h1>
	<p class="text-sm opacity-60">Workspace-level configuration. For per-project retention, open the project's Settings tab.</p>
</div>

<partial name="_WorkspaceAdminTabs" />

@if (Model.Workspace is null)
{
	<div class="alert alert-warning" data-testid="ws-settings-missing">Workspace not found.</div>
	return;
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
	<div class="alert alert-success mb-3" data-testid="ws-settings-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
	<div class="alert alert-error mb-3" data-testid="ws-settings-error">@Model.ErrorMessage</div>
}

<div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-6 max-w-3xl" data-testid="ws-settings-stats">
	<div class="card bg-base-200 border border-base-300">
		<div class="card-body p-3">
			<div class="text-xs opacity-60 uppercase tracking-wide">Projects</div>
			<div class="text-xl font-mono">@Model.ProjectCount</div>
		</div>
	</div>
	<div class="card bg-base-200 border border-base-300">
		<div class="card-body p-3">
			<div class="text-xs opacity-60 uppercase tracking-wide">Members</div>
			<div class="text-xl font-mono">@Model.MemberCount</div>
		</div>
	</div>
	<div class="card bg-base-200 border border-base-300">
		<div class="card-body p-3">
			<div class="text-xs opacity-60 uppercase tracking-wide">Created</div>
			<div class="text-sm font-mono">@Model.Workspace.CreatedAt.ToString("yyyy-MM-dd")</div>
		</div>
	</div>
</div>

<h2 class="text-lg font-semibold mb-3">Workspace info</h2>
<form method="post" asp-page-handler="Save" class="card bg-base-200 border border-base-300 mb-4 max-w-3xl" data-testid="ws-settings-form">
	@Html.AntiForgeryToken()
	<div class="card-body p-4">
		<label class="form-control">
			<span class="label-text">Key</span>
			<input type="text" value="@Model.Workspace.Key" readonly
				class="input input-bordered input-sm font-mono opacity-70" />
			<span class="text-xs opacity-60 mt-1">Workspace key is immutable.</span>
		</label>
		<label class="form-control mt-3">
			<span class="label-text">Name</span>
			<input type="text" name="Name" value="@Model.Name" required
				class="input input-bordered input-sm"
				data-testid="ws-settings-name" />
		</label>
		<label class="form-control mt-3">
			<span class="label-text">Description</span>
			<input type="text" name="Description" value="@Model.Description"
				class="input input-bordered input-sm"
				data-testid="ws-settings-description" />
		</label>
		<div class="card-actions mt-3">
			<button type="submit" class="btn btn-sm btn-primary" data-testid="ws-settings-save">Save</button>
		</div>
	</div>
</form>

<div class="text-xs opacity-50 max-w-3xl">
	Per-project retention override is on each project's Settings tab.
	Global defaults live on the system Defaults page (coming in Phase 23.4).
</div>
