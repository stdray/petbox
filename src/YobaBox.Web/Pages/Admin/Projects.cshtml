@page "/ui/{workspaceKey}/projects/new"
@model YobaBox.Web.Pages.Admin.ProjectsModel
@{
	ViewData["Title"] = "New project";
}

<div class="flex items-center gap-3 mb-4">
	<a href="@Routes.Workspace(Model.WorkspaceKey)" class="btn btn-sm btn-ghost" data-testid="admin-projects-back">&larr; Status</a>
	<h1 class="text-xl font-semibold" data-testid="admin-projects-title">New project</h1>
	<span class="badge badge-outline font-mono">@Model.WorkspaceKey</span>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
	<div class="alert alert-error mb-3" data-testid="admin-projects-error">@Model.ErrorMessage</div>
}

<form method="post" asp-page-handler="Create" class="card bg-base-200 mb-4 max-w-2xl" data-testid="admin-project-create-form">
	@Html.AntiForgeryToken()
	<div class="card-body p-4">
		<div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
			<label class="form-control">
				<span class="label-text">Key</span>
				<input type="text" name="key" required
					class="input input-bordered input-sm font-mono"
					placeholder="my-project"
					pattern="[a-z0-9][a-z0-9\-]*"
					data-testid="admin-project-create-key" />
				<span class="text-xs opacity-60 mt-1">lowercase letters, digits, hyphens</span>
			</label>
			<label class="form-control">
				<span class="label-text">Name</span>
				<input type="text" name="name" required
					class="input input-bordered input-sm"
					placeholder="My Project"
					data-testid="admin-project-create-name" />
			</label>
		</div>
		<label class="form-control mt-3">
			<span class="label-text">Description</span>
			<input type="text" name="description"
				class="input input-bordered input-sm"
				data-testid="admin-project-create-desc" />
		</label>
		<div class="card-actions mt-3">
			<button type="submit" class="btn btn-sm btn-primary" data-testid="admin-project-create-submit">Create</button>
			<a href="@Routes.Workspace(Model.WorkspaceKey)" class="btn btn-sm btn-ghost" data-testid="admin-project-create-cancel">Cancel</a>
		</div>
	</div>
</form>

@if (Model.ProjectsInWorkspace.Count > 0)
{
	<div class="divider"></div>
	<div class="text-sm opacity-70 mb-2">Existing projects in @Model.WorkspaceKey:</div>
	<ul class="menu menu-sm">
		@foreach (var p in Model.ProjectsInWorkspace)
		{
			<li><a href="@Routes.Project(Model.WorkspaceKey, p.Key)" class="font-mono text-xs" data-testid="admin-project-link">@p.Key @if (!string.IsNullOrWhiteSpace(p.Name)) { <text>· @p.Name</text> }</a></li>
		}
	</ul>
}
